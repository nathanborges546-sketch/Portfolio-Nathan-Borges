---
import Layout from '../layouts/Layout.astro';
import MoskatoSyncSandbox from '../components/MoskatoSyncSandbox.astro';
---

<Layout title="Menu Digital Personalizado | Nathan Borges">
  <div class="min-h-screen bg-darkBg text-textPrimary py-32 px-8 flex flex-col font-sora relative overflow-hidden">
    <!-- Glow Effects -->
    <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-brandCyan/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto w-full flex-1 flex flex-col z-10">
      <!-- Cabeçalho de Navegação -->
      <a href="/#projetos" class="inline-flex items-center gap-2 text-textSecondary hover:text-[#00f2fe] transition-colors mb-12 font-space text-sm tracking-widest uppercase group w-fit">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:-translate-x-1 transition-transform">
          <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Voltar para Projetos
      </a>
      
      <!-- Título da Página -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">Menu Digital <span class="text-[#00f2fe]">Personalizado</span></h1>
      </div>

      <!-- Grid de Cenário (Antes vs Depois) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
        
        <!-- Antes: O Caos Analógico -->
        <div class="bg-red-500/[0.02] border border-red-500/10 p-6 rounded-3xl flex flex-col gap-5">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400">
              <i class="fa-solid fa-circle-xmark text-sm"></i>
            </div>
            <h3 class="font-bold text-xl text-red-400 font-sora">Antes: O Caos Analógico</h3>
          </div>
          
          <div class="space-y-4">
            <div class="bg-[#0b0e14]/40 border border-white/5 p-4 rounded-2xl">
              <span class="text-xs font-bold text-red-400 uppercase tracking-widest block mb-1">Erros e Atrasos</span>
              <p class="text-textSecondary text-sm leading-relaxed font-sora">Operação baseada em comandas de papel. O dono corria de um lado para o outro, gerando confusão de escrita e pratos errados na cozinha.</p>
            </div>
            <div class="bg-[#0b0e14]/40 border border-white/5 p-4 rounded-2xl">
              <span class="text-xs font-bold text-red-400 uppercase tracking-widest block mb-1">Barreira de Idioma</span>
              <p class="text-textSecondary text-sm leading-relaxed font-sora">Dificuldade extrema para atender turistas internacionais que não falavam albanês nem inglês.</p>
            </div>
            <div class="bg-[#0b0e14]/40 border border-white/5 p-4 rounded-2xl">
              <span class="text-xs font-bold text-red-400 uppercase tracking-widest block mb-1">Insegurança de Rede</span>
              <p class="text-textSecondary text-sm leading-relaxed font-sora">A internet instável da costa da Albânia impedia o uso de sistemas comuns baseados em nuvem.</p>
            </div>
          </div>
        </div>

        <!-- Depois: O Ecossistema Moskato -->
        <div class="bg-emerald-500/[0.02] border border-emerald-500/10 p-6 rounded-3xl flex flex-col gap-5">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400">
              <i class="fa-solid fa-circle-check text-sm"></i>
            </div>
            <h3 class="font-bold text-xl text-emerald-400 font-sora">Depois: O Ecossistema Moskato</h3>
          </div>
          
          <div class="space-y-4">
            <div class="bg-[#0b0e14]/40 border border-white/5 p-4 rounded-2xl">
              <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest block mb-1">Fricção Zero</span>
              <p class="text-textSecondary text-sm leading-relaxed font-sora">Cardápio digital onde o cliente pede de forma autônoma e os pratos chegam à cozinha em menos de 100ms.</p>
            </div>
            <div class="bg-[#0b0e14]/40 border border-white/5 p-4 rounded-2xl">
              <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest block mb-1">Tradução Nativa</span>
              <p class="text-textSecondary text-sm leading-relaxed font-sora">Sistema totalmente localizado (Inglês, Albanês, Alemão e Polonês), quebrando barreiras linguísticas e aumentando as vendas.</p>
            </div>
            <div class="bg-[#0b0e14]/40 border border-white/5 p-4 rounded-2xl">
              <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest block mb-1">100% Offline-First</span>
              <p class="text-textSecondary text-sm leading-relaxed font-sora">O software opera em uma rede local fechada. Funciona perfeitamente mesmo se a internet da região cair, blindando o faturamento.</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Sandbox Interativo -->
      <MoskatoSyncSandbox />
    </div>
  </div>
</Layout>
