---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contato | Nathan Borges">
	<section class="min-h-screen flex flex-col justify-center px-10 md:px-20 lg:px-40">
		<span class="text-white/20 font-sans text-sm tracking-[0.3em] uppercase mb-10">Vamos conversar</span>
		<h1 class="font-sans text-5xl md:text-7xl lg:text-9xl font-extrabold tracking-tighter text-white leading-[0.95] mb-12">
			Agende uma Auditoria.
		</h1>
		<p class="font-body text-xl md:text-2xl text-white/40 max-w-2xl leading-relaxed mb-12">
			Tem um gargalo na sua operação? Vamos identificar o ponto exato de atrito.
		</p>
		
		<div class="flex flex-col sm:flex-row sm:items-center gap-8 mb-20">
			<a href="#" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/nathanborges546/30min'});return false;" class="inline-flex items-center justify-center px-8 py-4 bg-off-white text-deep-blue font-sans font-semibold rounded-full hover:bg-off-white/90 transition-transform hover:scale-105 active:scale-95 w-max">
				Agendar Auditoria Gratuita (30min)
			</a>
			<a href="mailto:contato@nathanborges.com" class="text-off-white/60 font-sans hover:text-off-white transition-colors">contato@nathanborges.com</a>
		</div>

		<a href="/" class="text-white/50 hover:text-white transition-colors">← Voltar para Home</a>
	</section>
</Layout>
