---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contato | Nathan Borges">
	<section class="min-h-screen flex flex-col justify-center px-10 md:px-20 lg:px-40">
		<span class="text-white/20 font-sans text-sm tracking-[0.3em] uppercase mb-10">Vamos conversar</span>
		<h1 class="font-sans text-5xl md:text-7xl lg:text-9xl font-extrabold tracking-tighter text-white leading-[0.95] mb-12">
			Agende uma Auditoria.
		</h1>
		<p class="font-body text-xl md:text-2xl text-white/40 max-w-2xl leading-relaxed mb-12">
			Tem um gargalo na sua operação? Vamos identificar o ponto exato de atrito.
		</p>
		<a href="mailto:contato@nathanborges.com" class="text-azure-tech text-2xl font-sans hover:underline underline-offset-8 transition-all">contato@nathanborges.com</a>
		<a href="/" class="mt-20 text-white/50 hover:text-white transition-colors">← Voltar para Home</a>
	</section>
</Layout>
