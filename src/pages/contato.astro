---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Conexão Técnica | Nathan Borges">
  <section class="min-h-screen flex flex-col justify-center py-32 px-8 overflow-hidden bg-darkBg">
    <div class="max-w-7xl mx-auto w-full z-10">
      
      <!-- Voltar Home -->
      <span class="text-brandCyan font-space text-xs tracking-[0.3em] uppercase mb-8 block opacity-0 animate-fade-in-up">
        CONEXÃO TÉCNICA
      </span>
      
      <h1 class="font-sora text-4xl md:text-6xl font-bold tracking-tighter text-textPrimary leading-[1.1] mb-8 opacity-0 animate-fade-in-up [animation-delay:100ms] max-w-4xl">
        Vamos escalar a eficiência do seu produto?
      </h1>
      
      <p class="font-sora text-lg md:text-xl text-textSecondary max-w-3xl leading-relaxed mb-16 opacity-0 animate-fade-in-up [animation-delay:200ms]">
        Se você busca um desenvolvedor sênior que domine arquitetura de automação, IA e design centrado no usuário para integrar seu time fixo ou projeto de alta escala, vamos conversar.
      </p>
      
      <div class="flex flex-col sm:flex-row sm:items-center gap-6 mb-20 opacity-0 animate-fade-in-up [animation-delay:300ms]">
        <!-- Botão WhatsApp -->
        <a href="https://wa.me/5564993335277" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-10 py-4 bg-brandCyan text-textPrimary font-space font-bold rounded-full hover:brightness-110 transition-all hover:scale-105 active:scale-95 uppercase tracking-widest text-xs shadow-[0_0_20px_rgba(28,105,183,0.2)]">
          CHAMAR NO WHATSAPP PARA ENTREVISTA
        </a>
        
        <!-- Botão Calendly -->
        <a href="#" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/nathanborges546/30min'});return false;" class="inline-flex items-center justify-center px-10 py-4 border border-surface text-textSecondary hover:text-textPrimary transition-all rounded-full font-space text-sm uppercase tracking-widest hover:scale-105 active:scale-95">
          VER AGENDA TÉCNICA VIA CALENDLY
        </a>
      </div>

      <div class="flex flex-col gap-4 opacity-0 animate-fade-in-up [animation-delay:400ms]">
        <p class="text-textSecondary font-space text-xs uppercase tracking-widest">Direct Info</p>
        <a href="mailto:nathanborges546@gmail.com" class="text-textPrimary text-xl md:text-2xl font-sora font-bold hover:text-brandCyan transition-colors">nathanborges546@gmail.com</a>
      </div>

      <a href="/" class="mt-20 text-textSecondary hover:text-textPrimary transition-colors font-sora text-sm inline-flex items-center gap-2">
        ← Voltar para Home
      </a>

    </div>
  </section>
</Layout>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up { animation: fade-in-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards; }
</style>
