---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectSwitcher from '../components/ProjectSwitcher.astro';
import Process from '../components/Process.astro';
import Reviews from '../components/Reviews.astro';
---

<Layout title="Engenharia da Conversão | Nathan Borges">
	<main>
		<Hero />
		<ProjectSwitcher />
		<Process />
		<Reviews />
	</main>

	<footer class="py-12 px-10 border-t border-white/5 bg-darkBg text-center flex flex-col items-center gap-8">
		<div class="flex items-center gap-2 px-3 py-1 bg-surface border border-white/5 rounded-full inline-flex">
			<span class="w-2 h-2 rounded-full bg-brandCyan animate-pulse"></span>
			<span class="text-brandCyan/80 font-space text-xs tracking-wide">● System Status: Optimal (INP &lt; 200ms)</span>
		</div>
		
		<div class="flex items-center gap-6 text-textSecondary font-space text-sm">
			<a href="https://wa.me/5564993335277" target="_blank" rel="noopener noreferrer" class="hover:text-brandCyan transition-colors">WhatsApp</a>
			<a href="https://www.instagram.com/nathanb.exe/" target="_blank" rel="noopener noreferrer" class="hover:text-brandCyan transition-colors">Instagram</a>
			<a href="https://www.behance.net/nathanborges546" target="_blank" rel="noopener noreferrer" class="hover:text-brandCyan transition-colors">Behance</a>
		</div>

		<p class="text-textSecondary/40 text-xs font-space">© 2026 Nathan Borges. Projetando a Engenharia da Conversão.</p>
	</footer>
</Layout>
