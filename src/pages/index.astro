---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectSwitcher from '../components/ProjectSwitcher.astro';
import Process from '../components/Process.astro';
import Reviews from '../components/Reviews.astro';
---

<Layout title="Nathan Borges | Engenharia de Sistemas & UX">
	<main>
		<Hero />
		<ProjectSwitcher />
		<Process />
		<Reviews />
	</main>

	<footer class="py-24 px-8 border-t border-surface/30 bg-darkBg">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
      
      <!-- Info Col -->
      <div class="flex flex-col items-center md:items-start gap-6">
        <div class="flex items-center gap-3">
          <img src="/logo.png" alt="Nathan Borges" class="h-6 w-auto" />
          <span class="text-textSecondary font-sora text-sm font-bold tracking-tight">Nathan Borges</span>
        </div>
        <div class="flex flex-col items-center md:items-start gap-2">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface border border-brandCyan/10 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-brandCyan"></span>
            <span class="text-textSecondary font-space text-[10px] uppercase tracking-widest leading-none">Stack: Astro 5 • Tailwind • INP &lt; 200ms</span>
          </div>
          <p class="text-textSecondary text-sm font-sora text-center md:text-left">© 2026 Nathan Borges. Arquitetando sistemas de alta performance.</p>
        </div>
      </div>

      <!-- Social & Links Col -->
      <div class="flex flex-col items-center md:items-end gap-8 w-full md:w-auto">
        <!-- Botão Agenda Mobile (Aparece apenas no celular) -->
        <button onclick="Calendly.initPopupWidget({url: 'https://calendly.com/nathanborges546/30min'});return false;" class="md:hidden w-full py-4 bg-brandCyan text-textPrimary font-space font-bold rounded-full uppercase tracking-widest text-xs shadow-[0_0_20px_rgba(28,105,183,0.3)]">
          AGENDAR CONSULTA
        </button>

        <div class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-4 font-space text-xs tracking-widest uppercase">
          <a href="#" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/nathanborges546/30min'});return false;" class="hidden md:block text-textSecondary hover:text-brandCyan transition-colors">Agenda</a>
          <a href="mailto:nathanborges546@gmail.com" class="text-textSecondary hover:text-brandCyan transition-colors break-all text-center">E-mail</a>
          <a href="https://www.behance.net/nathanborges546" target="_blank" class="text-textSecondary hover:text-brandCyan transition-colors">Behance</a>
          <a href="https://www.linkedin.com/in/nathan-borges-298aa5203/" target="_blank" class="text-textSecondary hover:text-brandCyan transition-colors">LinkedIn</a>
          <a href="https://wa.me/5564993335277" target="_blank" class="text-textSecondary hover:text-brandCyan transition-colors">WhatsApp</a>
        </div>
      </div>
    </div>
	</footer>
</Layout>
