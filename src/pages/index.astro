---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectSwitcher from '../components/ProjectSwitcher.astro';
import Process from '../components/Process.astro';
import Reviews from '../components/Reviews.astro';
---

<Layout title="Engenharia da Conversão | Nathan Borges">
	<main>
		<Hero />
		<ProjectSwitcher />
		<Process />
		<Reviews />
	</main>

	<footer class="py-24 px-6 md:px-20 lg:px-40 border-t border-surface/30 bg-darkBg">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
      <div class="flex flex-col items-center md:items-start gap-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface border border-brandCyan/10 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-brandCyan"></span>
          <span class="text-textSecondary font-space text-[10px] uppercase tracking-widest leading-none">Stack: Astro 5 • Tailwind • INP &lt; 200ms</span>
        </div>
        <p class="text-textSecondary text-sm font-sora">© 2026 Nathan Borges. Arquitetando sistemas de alta performance.</p>
      </div>

      <div class="flex items-center gap-8 font-space text-xs tracking-widest uppercase">
        <a href="https://github.com/nathanborges546" target="_blank" class="text-textSecondary hover:text-brandCyan transition-colors">GitHub</a>
        <a href="https://linkedin.com/in/nathanborges" target="_blank" class="text-textSecondary hover:text-brandCyan transition-colors">LinkedIn</a>
        <a href="https://wa.me/5511999999999" target="_blank" class="text-textSecondary hover:text-brandCyan transition-colors">WhatsApp</a>
      </div>
    </div>
	</footer>
</Layout>
