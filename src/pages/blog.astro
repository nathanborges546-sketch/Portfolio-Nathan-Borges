---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog | Nathan Borges">
	<section class="min-h-screen flex flex-col justify-center px-6 md:px-20 lg:px-40 bg-darkBg">
		<span class="text-brandCyan font-space text-xs tracking-widest uppercase mb-8">Pensamento Estratégico</span>
		<h1 class="font-sora text-4xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-textPrimary leading-[1.05] mb-8">
			Notas sobre Engenharia de Conversão.
		</h1>
		<p class="font-sora text-lg md:text-xl text-textSecondary max-w-2xl leading-relaxed mb-12">
			Artigos e insights práticos sobre a intersecção de código, usabilidade e a evolução do mercado digital em 2026.
		</p>
		<a href="/" class="text-textSecondary hover:text-brandCyan transition-colors font-space text-sm">← Voltar para Home</a>
	</section>
</Layout>
