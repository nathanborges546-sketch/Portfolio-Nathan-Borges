---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog | Nathan Borges">
	<section class="min-h-screen flex flex-col justify-center px-10 md:px-20 lg:px-40">
		<span class="text-white/20 font-sans text-sm tracking-[0.3em] uppercase mb-10">Pensamento Estratégico</span>
		<h1 class="font-sans text-5xl md:text-7xl lg:text-9xl font-extrabold tracking-tighter text-white leading-[0.95] mb-12">
			Notas sobre Eficiência.
		</h1>
		<p class="font-body text-xl md:text-2xl text-white/40 max-w-2xl leading-relaxed">
			Artigos em breve.
		</p>
		<a href="/" class="mt-12 text-white/50 hover:text-white transition-colors">← Voltar para Home</a>
	</section>
</Layout>
