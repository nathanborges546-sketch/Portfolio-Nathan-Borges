  /* Mobile Responsiveness Optimization */
  @media (max-width: 768px) {
    .modal-content {
      padding: 1.5rem !important;
      max-height: 92vh !important;
      border-radius: 1.5rem !important;
      gap: 1.25rem !important;
    }
    .modal-content.maximized {
      max-height: 100vh !important;
      border-radius: 0px !important;
      padding: 1.25rem !important;
    }
    .sandbox-modal {
      padding: 0.5rem !important;
    }
  }

  /* Reveal Cards styling */
  .reveal-card {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }
  .reveal-card .reveal-content {
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                opacity 0.3s ease-out,
                margin-top 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }
  
  /* Desktop hover interaction */
  @media (hover: hover) {
    .reveal-card:hover {
      background-color: rgba(28, 105, 183, 0.04) !important;
    }
    .reveal-card.border-red-500\/10:hover {
      background-color: rgba(239, 68, 68, 0.03) !important;
    }
    .reveal-card:hover .reveal-content {
      max-height: 400px !important;
      opacity: 1 !important;
      margin-top: 1rem !important;
      pointer-events: auto !important;
    }
    .reveal-card:hover .reveal-indicator {
      transform: scale(1.15) !important;
      color: #36d6d6 !important;
    }
    .reveal-card.border-red-500\/10:hover .reveal-indicator {
      color: #ef4444 !important;
    }
  }

  /* Click/Touch toggled revealed state */
  .reveal-card.revealed {
    background-color: rgba(28, 105, 183, 0.04) !important;
  }
  .reveal-card.revealed.border-red-500\/10 {
    background-color: rgba(239, 68, 68, 0.03) !important;
    border-color: rgba(239, 68, 68, 0.3) !important;
  }
  .reveal-card.revealed.border-white\/5 {
    border-color: rgba(54, 214, 214, 0.3) !important;
  }
  .reveal-card.revealed .reveal-content {
    max-height: 400px !important;
    opacity: 1 !important;
    margin-top: 1rem !important;
    pointer-events: auto !important;
  }
  .reveal-card.revealed .reveal-indicator {
    transform: scale(1.15) !important;
    color: #36d6d6 !important;
  }
  .reveal-card.revealed.border-red-500\/10 .reveal-indicator {
    color: #ef4444 !important;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const openBtns = document.querySelectorAll('.open-sandbox-btn');
    const closeBtns = document.querySelectorAll('.close-modal-btn');
    const maxBtns = document.querySelectorAll('.maximize-modal-btn');
    const revealCards = document.querySelectorAll('.reveal-card');
    
    // Reveal Cards click toggle
    revealCards.forEach(card => {
      card.addEventListener('click', (e) => {
        if (window.getSelection()?.toString()) return;
        card.classList.toggle('revealed');
      });
    });
    
    // Open modal logic
    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-sandbox-id');
        const modal = document.getElementById(`modal-${id}`);
        if (modal) {
          modal.classList.remove('hidden');
          setTimeout(() => {
            modal.classList.remove('opacity-0', 'pointer-events-none');
            modal.classList.add('opacity-100', 'pointer-events-auto');
            const inner = modal.querySelector('.modal-content');
            inner?.classList.remove('scale-95');
            inner?.classList.add('scale-100');
          }, 50);
          document.body.style.overflow = 'hidden';
        }
      });
    });

    // Close modal logic
    closeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modal = btn.closest('.sandbox-modal');
        if (modal) {
          modal.classList.remove('opacity-100', 'pointer-events-auto');
          modal.classList.add('opacity-0', 'pointer-events-none');
          
          const inner = modal.querySelector('.modal-content');
          inner?.classList.remove('scale-100');
          inner?.classList.add('scale-95');
          
          setTimeout(() => {
            modal.classList.add('hidden');
            
            // Reset maximized classes on closing
            if (inner?.classList.contains('maximized')) {
              inner.classList.remove('maximized');
              const maxBtn = inner.querySelector('.maximize-modal-btn');
              const iconExpand = maxBtn?.querySelector('.icon-expand');
              const iconRestore = maxBtn?.querySelector('.icon-restore');
              iconExpand?.classList.remove('hidden');
              iconRestore?.classList.add('hidden');
            }
          }, 300);
          document.body.style.overflow = '';
        }
      });
    });

    // Maximize modal logic
    maxBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modalContent = btn.closest('.modal-content');
        const iconExpand = btn.querySelector('.icon-expand');
        const iconRestore = btn.querySelector('.icon-restore');
        
        if (modalContent) {
          modalContent.classList.toggle('maximized');
          const isMax = modalContent.classList.contains('maximized');
          
          if (isMax) {
            iconExpand?.classList.add('hidden');
            iconRestore?.classList.remove('hidden');
          } else {
            iconExpand?.classList.remove('hidden');
            iconRestore?.classList.add('hidden');
          }
        }
      });
    });
  });
</script>
