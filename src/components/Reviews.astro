---
const reviews = [
  {
    name: "Vasil J.",
    company: "Moskato Camping",
    photoHash: Buffer.from("/reviews/Vasil J.avif").toString('base64'),
    textEn: "The system you built for me made our service incredibly fast and efficient. Customers place their orders instantly, the kitchen starts preparing them right away, and I can focus entirely on guest relationships and payments. It's an absolute game-changer.",
    textPt: "Esse sistema que criou pra mim tornou nosso atendimento incrivelmente rápido e eficiente. O cliente faz o pedido instantaneamente, a cozinha já começa a preparar na hora, e eu posso focar totalmente no relacionamento com os clientes e nos pagamentos. É uma mão na roda.",
    isTranslatable: true
  },
  {
    name: "Guterberg G.",
    company: "Platly",
    photoHash: Buffer.from("/reviews/Guterberg G.avif").toString('base64'),
    text: "Agora meu time pode focar em prospectar os parceiros de forma certeira e automatizada, código limpo, componentizado e documentado, com uma interface intuitiva e didática."
  },
  {
    name: "Henrique B.",
    company: "Nexus",
    photoHash: Buffer.from("/reviews/Henrique B..avif").toString('base64'),
    text: "O redesenho dos nossos fluxos críticos mobile eliminou os erros de input dos usuários, estabilizando nossa taxa de conversão. Trabalho excelente."
  },
  {
    name: "Allice L.",
    company: "Lirius Perfumes",
    photoHash: Buffer.from("/reviews/Allice L.avif").toString('base64'),
    text: "Meu site agora está organizado, rápido e convertendo muito mais que antes."
  },
  {
    name: "Frederick A.",
    company: "Takuma Sun",
    photoHash: Buffer.from("/reviews/Frederick A.avif").toString('base64'),
    text: "O site está na pegada do surf agora, fluido e leve, e com uma animação genial imitando as ondas."
  }
];
---

<section class="py-32 bg-darkBg overflow-hidden border-t border-surface/30">
  <div class="px-8 mb-16">
    <h2 class="text-3xl md:text-5xl font-sora font-bold text-textPrimary tracking-tight mb-4 text-center">O impacto técnico no ecossistema</h2>
  </div>

  <!-- Marquee Wrapper -->
  <div class="relative flex overflow-hidden group py-20 gap-6">
    
    <!-- Track Animado 1 -->
    <div class="flex shrink-0 min-w-full gap-6 animate-marquee group-hover:[animation-play-state:paused]">
      {reviews.map((review, index) => (
        <div class="review-card-container w-[350px] shrink-0 bg-surface border border-brandCyan/5 rounded-[32px] p-8 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] hover:scale-110 hover:z-50 hover:shadow-[0_20px_50px_rgba(0,0,0,0.8)] cursor-pointer flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-4 mb-6">
              <canvas 
                class="review-avatar-canvas w-12 h-12 rounded-full border border-brandCyan/20 bg-darkBg pointer-events-none select-none"
                data-hash={review.photoHash}
              ></canvas>
              <div>
                <p class="text-textPrimary font-sora font-bold text-sm whitespace-normal leading-none">{review.company}</p>
                <p class="text-[#36d6d6] font-space text-[10px] uppercase tracking-widest mt-1 reviewer-name">{review.name}</p>
              </div>
            </div>
            <p class="review-text-content text-textSecondary font-sora text-sm leading-relaxed whitespace-normal break-words italic">
              "{review.isTranslatable ? review.textEn : review.text}"
            </p>
          </div>
          {review.isTranslatable && (
            <button 
              class="translate-review-btn mt-4 text-[10px] font-space text-brandCyan/70 hover:text-brandCyan flex items-center gap-1 transition-all active:scale-95 cursor-pointer uppercase tracking-wider bg-transparent border-none p-0 w-fit"
              data-en={review.textEn}
              data-pt={review.textPt}
              data-current="en"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Traduzir para o Português
            </button>
          )}
        </div>
      ))}
    </div>

    <!-- Track Animado 2 (Duplicado para o Loop) -->
    <div class="flex shrink-0 min-w-full gap-6 animate-marquee group-hover:[animation-play-state:paused]" aria-hidden="true">
      {reviews.map((review, index) => (
        <div class="review-card-container w-[350px] shrink-0 bg-surface border border-brandCyan/5 rounded-[32px] p-8 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] hover:scale-110 hover:z-50 hover:shadow-[0_20px_50px_rgba(0,0,0,0.8)] cursor-pointer flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-4 mb-6">
              <canvas 
                class="review-avatar-canvas w-12 h-12 rounded-full border border-brandCyan/20 bg-darkBg pointer-events-none select-none"
                data-hash={review.photoHash}
              ></canvas>
              <div>
                <p class="text-textPrimary font-sora font-bold text-sm whitespace-normal leading-none">{review.company}</p>
                <p class="text-[#36d6d6] font-space text-[10px] uppercase tracking-widest mt-1 reviewer-name">{review.name}</p>
              </div>
            </div>
            <p class="review-text-content text-textSecondary font-sora text-sm leading-relaxed whitespace-normal break-words italic">
              "{review.isTranslatable ? review.textEn : review.text}"
            </p>
          </div>
          {review.isTranslatable && (
            <button 
              class="translate-review-btn mt-4 text-[10px] font-space text-brandCyan/70 hover:text-brandCyan flex items-center gap-1 transition-all active:scale-95 cursor-pointer uppercase tracking-wider bg-transparent border-none p-0 w-fit"
              data-en={review.textEn}
              data-pt={review.textPt}
              data-current="en"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Traduzir para o Português
            </button>
          )}
        </div>
      ))}
    </div>

    <!-- Fade effects nas bordas -->
    <div class="pointer-events-none absolute inset-y-0 left-0 w-16 md:w-40 bg-gradient-to-r from-darkBg to-transparent z-40"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-16 md:w-40 bg-gradient-to-l from-darkBg to-transparent z-40"></div>

  </div>

  <!-- Modal de Zoom do Depoimento (Centralizado na Tela) -->
  <div id="review-zoom-modal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-[#0b0e14]/90 backdrop-blur-xl opacity-0 pointer-events-none transition-all duration-500">
    <div class="bg-[#161b22] border border-white/10 rounded-[32px] p-8 md:p-10 max-w-lg w-full shadow-[0_0_50px_rgba(54,214,214,0.15)] transform scale-95 transition-all duration-500 flex flex-col gap-6 relative" id="review-zoom-modal-content">
      
      <!-- Botão de Fechar -->
      <button id="btn-close-review-modal" class="absolute top-6 right-6 w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-textSecondary hover:text-textPrimary transition-all cursor-pointer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="flex items-center gap-4">
        <canvas 
          id="modal-review-avatar"
          class="w-14 h-14 rounded-full border border-brandCyan/20 bg-darkBg pointer-events-none select-none"
        ></canvas>
        <div>
          <p id="modal-review-company" class="text-textPrimary font-sora font-extrabold text-base leading-none"></p>
          <p id="modal-review-name" class="text-[#36d6d6] font-space text-[10px] uppercase tracking-widest mt-1.5 font-bold"></p>
        </div>
      </div>

      <div class="relative mt-2">
        <svg class="absolute -top-6 -left-6 text-white/[0.02] w-16 h-16 pointer-events-none" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.154c-2.416.913-3.979 3.633-3.979 5.844h3.983v10h-10z"/>
        </svg>
        <p id="modal-review-text" class="text-textPrimary font-sora text-base leading-relaxed italic relative z-10 pl-2">
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    // 1. Decode Base64 and draw on Canvas dynamically (anti-copy/no-src-in-code)
    const canvases = document.querySelectorAll('.review-avatar-canvas');
    canvases.forEach(canvas => {
      const hash = canvas.getAttribute('data-hash');
      if (!hash) return;
      
      try {
        const decodedPath = atob(hash);
        const ctx = (canvas as HTMLCanvasElement).getContext('2d');
        if (!ctx) return;
        
        const img = new Image();
        img.src = decodedPath;
        img.onload = () => {
          // Retina high-resolution size scaling
          const size = 96;
          (canvas as HTMLCanvasElement).width = size;
          (canvas as HTMLCanvasElement).height = size;
          
          // Draw circular crop
          ctx.beginPath();
          ctx.arc(size / 2, size / 2, size / 2, 0, Math.PI * 2);
          ctx.closePath();
          ctx.clip();
          
          // Draw image
          ctx.drawImage(img, 0, 0, size, size);
        };
      } catch (err) {
        console.error('Secure avatar decryption failed', err);
      }
    });

    // 2. Prevent right-click / drag on secure canvases
    document.addEventListener('contextmenu', (e) => {
      if ((e.target as HTMLElement).classList.contains('review-avatar-canvas')) {
        e.preventDefault();
      }
    });
    document.addEventListener('dragstart', (e) => {
      if ((e.target as HTMLElement).classList.contains('review-avatar-canvas')) {
        e.preventDefault();
      }
    });

    // 3. Translation synchronization
    const translateBtns = document.querySelectorAll('.translate-review-btn');
    translateBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        
        const cardContainer = btn.closest('.review-card-container');
        if (!cardContainer) return;
        
        const companyName = cardContainer.querySelector('.text-textPrimary')?.textContent;
        const currentLang = btn.getAttribute('data-current') || 'en';
        const textEn = btn.getAttribute('data-en') || '';
        const textPt = btn.getAttribute('data-pt') || '';
        
        const allCardContainers = document.querySelectorAll('.review-card-container');
        allCardContainers.forEach(container => {
          const name = container.querySelector('.text-textPrimary')?.textContent;
          if (name === companyName) {
            const textEl = container.querySelector('.review-text-content');
            const tBtn = container.querySelector('.translate-review-btn');
            
            if (textEl && tBtn) {
              if (currentLang === 'en') {
                textEl.textContent = `"${textPt}"`;
                tBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> View in English';
                tBtn.setAttribute('data-current', 'pt');
              } else {
                textEl.textContent = `"${textEn}"`;
                tBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Traduzir para o Português';
                tBtn.setAttribute('data-current', 'en');
              }
            }
          }
        });
      });
    });

    // 4. Modal Zoom Logic (Centralizado no clique/hover com grace-period)
    const modal = document.getElementById('review-zoom-modal');
    const modalContent = document.getElementById('review-zoom-modal-content');
    const btnCloseModal = document.getElementById('btn-close-review-modal');
    
    const modalCompany = document.getElementById('modal-review-company');
    const modalName = document.getElementById('modal-review-name');
    const modalText = document.getElementById('modal-review-text');
    const modalAvatar = document.getElementById('modal-review-avatar') as HTMLCanvasElement;
    
    const cards = document.querySelectorAll('.review-card-container');
    let openedByHover = false;
    let hoverTimeout: any = null;

    function openModal(card: Element, isHover: boolean) {
      if (!modal || !modalContent || !modalCompany || !modalName || !modalText) return;

      const company = card.querySelector('.text-textPrimary')?.textContent || '';
      const name = card.querySelector('.reviewer-name')?.textContent || '';
      const text = card.querySelector('.review-text-content')?.textContent || '';
      const canvasSrc = card.querySelector('.review-avatar-canvas') as HTMLCanvasElement;

      modalCompany.textContent = company;
      modalName.textContent = name;
      modalText.textContent = text;

      // Draw avatar onto modal canvas
      if (canvasSrc && modalAvatar) {
        modalAvatar.width = 112;
        modalAvatar.height = 112;
        const mCtx = modalAvatar.getContext('2d');
        if (mCtx) {
          mCtx.clearRect(0, 0, 112, 112);
          mCtx.drawImage(canvasSrc, 0, 0, 112, 112);
        }
      }

      openedByHover = isHover;

      modal.classList.remove('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-95');
      modalContent.classList.add('scale-100');
    }

    function closeModal() {
      if (!modal || !modalContent) return;
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
      openedByHover = false;
    }

    cards.forEach(card => {
      // Hover Interactions
      card.addEventListener('mouseenter', () => {
        if (hoverTimeout) clearTimeout(hoverTimeout);
        openModal(card, true);
      });

      card.addEventListener('mouseleave', () => {
        if (openedByHover) {
          hoverTimeout = setTimeout(() => {
            closeModal();
          }, 150); // 150ms grace period to transit cursor to modal
        }
      });

      // Click Interaction (Persistent)
      card.addEventListener('click', (e) => {
        // Prevent click if clicking the translation button
        if ((e.target as HTMLElement).closest('.translate-review-btn')) return;
        
        if (hoverTimeout) clearTimeout(hoverTimeout);
        openModal(card, false);
      });
    });

    // Close actions
    btnCloseModal?.addEventListener('click', () => {
      closeModal();
    });

    modal?.addEventListener('click', () => {
      if (!openedByHover) closeModal();
    });

    modalContent?.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    modalContent?.addEventListener('mouseenter', () => {
      if (hoverTimeout) clearTimeout(hoverTimeout);
    });

    modalContent?.addEventListener('mouseleave', () => {
      if (openedByHover) {
        closeModal();
      }
    });
  });
</script>
