---
const reviews = [
  {
    name: "Diretor de Engenharia",
    role: "SaaS B2B",
    text: "O Nathan possui uma habilidade rara: ele entende a fundo a engenharia de dados em Python, mas não ignora o impacto do UX Writing na retenção do usuário. Um ativo indispensável para qualquer squad sênior."
  },
  {
    name: "Tech Lead",
    role: "Operações Corporativas",
    text: "Os scripts e a automação de pipeline que ele desenhou reduziram nosso esforço manual de prospecção em mais de 80%. Código limpo, componentizado e documentado."
  },
  {
    name: "Product Manager",
    role: "E-commerce",
    text: "Ele domina o microcopy e as heurísticas de interface. O redesenho dos nossos fluxos críticos mobile eliminou os erros de input dos usuários, estabilizando nossa taxa de conversão."
  },
  {
    name: "Engineering Manager",
    role: "Fintech",
    text: "Excepcional em traduzir requisitos de negócios complexos em arquiteturas escaláveis. Sua visão de UX dentro do código economiza meses de retrabalho."
  }
];

// Duplicamos o array para criar o efeito infinito contínuo no marquee
const marqueeItems = [...reviews, ...reviews];
---

<section class="py-32 bg-darkBg overflow-hidden border-t border-surface/30">
  <div class="px-8 mb-16">
    <h2 class="text-3xl md:text-5xl font-sora font-bold text-textPrimary tracking-tight mb-4 text-center">O impacto técnico no ecossistema</h2>
  </div>

  <!-- Marquee Wrapper -->
  <div class="relative flex overflow-hidden group py-20 gap-6">
    
    <!-- Track Animado 1 -->
    <div class="flex shrink-0 min-w-full gap-6 animate-marquee group-hover:[animation-play-state:paused]">
      {reviews.map((review, index) => (
        <div class="w-[350px] shrink-0 bg-surface border border-brandCyan/5 rounded-[32px] p-8 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] hover:scale-150 hover:z-50 hover:shadow-[0_20px_50px_rgba(0,0,0,0.8)] cursor-default">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-full bg-darkBg border border-brandCyan/20 flex items-center justify-center">
              <span class="text-brandCyan font-space text-sm font-bold">{review.name.charAt(0)}</span>
            </div>
            <div>
              <p class="text-textPrimary font-sora font-bold text-sm whitespace-normal leading-none">{review.name}</p>
              <p class="text-blue-400 font-space text-[10px] uppercase tracking-widest mt-1">{review.role}</p>
            </div>
          </div>
          <p class="text-textSecondary font-sora text-sm leading-relaxed whitespace-normal break-words italic">
            "{review.text}"
          </p>
        </div>
      ))}
    </div>

    <!-- Track Animado 2 (Duplicado para o Loop) -->
    <div class="flex shrink-0 min-w-full gap-6 animate-marquee group-hover:[animation-play-state:paused]" aria-hidden="true">
      {reviews.map((review, index) => (
        <div class="w-[350px] shrink-0 bg-surface border border-brandCyan/5 rounded-[32px] p-8 transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] hover:scale-150 hover:z-50 hover:shadow-[0_20px_50px_rgba(0,0,0,0.8)] cursor-default">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-full bg-darkBg border border-brandCyan/20 flex items-center justify-center">
              <span class="text-brandCyan font-space text-sm font-bold">{review.name.charAt(0)}</span>
            </div>
            <div>
              <p class="text-textPrimary font-sora font-bold text-sm whitespace-normal leading-none">{review.name}</p>
              <p class="text-blue-400 font-space text-[10px] uppercase tracking-widest mt-1">{review.role}</p>
            </div>
          </div>
          <p class="text-textSecondary font-sora text-sm leading-relaxed whitespace-normal break-words italic">
            "{review.text}"
          </p>
        </div>
      ))}
    </div>

    <!-- Fade effects nas bordas -->
    <div class="pointer-events-none absolute inset-y-0 left-0 w-16 md:w-40 bg-gradient-to-r from-darkBg to-transparent z-40"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-16 md:w-40 bg-gradient-to-l from-darkBg to-transparent z-40"></div>

  </div>
</section>
