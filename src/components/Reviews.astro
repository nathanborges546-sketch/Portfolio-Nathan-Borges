---
const reviews = [
  {
    name: "Vasil J.",
    company: "Moskato Camping",
    photoHash: Buffer.from("/reviews/Vasil J.avif").toString('base64'),
    textEn: "The system you built for me made our service incredibly fast and efficient. Customers place their orders instantly, the kitchen starts preparing them right away, and I can focus entirely on guest relationships and payments. It's an absolute game-changer.",
    textPt: "Esse sistema que criou pra mim tornou nosso atendimento incrivelmente rápido e eficiente. O cliente faz o pedido instantaneamente, a cozinha já começa a preparar na hora, e eu posso focar totalmente no relacionamento com os clientes e nos pagamentos. É uma mão na roda.",
    isTranslatable: true
  },
  {
    name: "Guterberg G.",
    company: "Platly",
    photoHash: Buffer.from("/reviews/Guterberg G.avif").toString('base64'),
    text: "Agora meu time pode focar em prospectar os parceiros de forma certeira e automatizada, código limpo, componentizado e documentado, com uma interface intuitiva e didática."
  },
  {
    name: "Henrique B.",
    company: "Nexus",
    photoHash: Buffer.from("/reviews/Henrique B..avif").toString('base64'),
    text: "O redesenho dos nossos fluxos críticos mobile eliminou os erros de input dos usuários, estabilizando nossa taxa de conversão. Trabalho excelente."
  },
  {
    name: "Allice L.",
    company: "Lirius Perfumes",
    photoHash: Buffer.from("/reviews/Allice L.avif").toString('base64'),
    text: "Meu site agora está organizado, rápido e convertendo muito mais que antes."
  },
  {
    name: "Frederick A.",
    company: "Takuma Sun",
    photoHash: Buffer.from("/reviews/Frederick A.avif").toString('base64'),
    text: "O site está na pegada do surf agora, fluido e leve, e com uma animação genial imitando as ondas."
  }
];
---

<section class="py-32 bg-darkBg overflow-hidden border-t border-surface/30">
  <div class="px-8 mb-16">
    <h2 class="text-3xl md:text-5xl font-sora font-bold text-textPrimary tracking-tight mb-4 text-center">O impacto técnico no ecossistema</h2>
  </div>

  <!-- Marquee Wrapper -->
  <div class="relative overflow-hidden group py-16">
    
    <!-- Shift Wrapper: Permite o deslocamento horizontal suave para centralização -->
    <div id="marquee-shift-wrapper" class="flex gap-6 w-max transition-transform duration-600 ease-[cubic-bezier(0.25,1,0.5,1)]">
      
      <!-- Track Animado 1 -->
      <div class="flex shrink-0 gap-6 animate-marquee group-hover:[animation-play-state:paused] marquee-track">
        {reviews.map((review, index) => (
          <div class="review-card-container w-[350px] shrink-0 bg-surface border border-brandCyan/5 rounded-[32px] p-8 cursor-pointer flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <canvas 
                  class="review-avatar-canvas w-12 h-12 rounded-full border border-brandCyan/20 bg-darkBg pointer-events-none select-none"
                  data-hash={review.photoHash}
                ></canvas>
                <div>
                  <p class="text-textPrimary font-sora font-bold text-sm whitespace-normal leading-none">{review.company}</p>
                  <p class="text-[#1C69B7] font-space text-[10px] uppercase tracking-widest mt-1 reviewer-name">{review.name}</p>
                </div>
              </div>
              <p class="review-text-content text-textSecondary font-sora text-sm leading-relaxed whitespace-normal break-words italic">
                "{review.isTranslatable ? review.textEn : review.text}"
              </p>
            </div>
            {review.isTranslatable && (
              <button 
                class="translate-review-btn mt-4 text-[10px] font-space text-brandCyan/70 hover:text-brandCyan flex items-center gap-1 transition-all active:scale-95 cursor-pointer uppercase tracking-wider bg-transparent border-none p-0 w-fit"
                data-en={review.textEn}
                data-pt={review.textPt}
                data-current="en"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Traduzir para o Português
              </button>
            )}
          </div>
        ))}
      </div>

      <!-- Track Animado 2 (Duplicado para o Loop) -->
      <div class="flex shrink-0 gap-6 animate-marquee group-hover:[animation-play-state:paused] marquee-track" aria-hidden="true">
        {reviews.map((review, index) => (
          <div class="review-card-container w-[350px] shrink-0 bg-surface border border-brandCyan/5 rounded-[32px] p-8 cursor-pointer flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <canvas 
                  class="review-avatar-canvas w-12 h-12 rounded-full border border-brandCyan/20 bg-darkBg pointer-events-none select-none"
                  data-hash={review.photoHash}
                ></canvas>
                <div>
                  <p class="text-textPrimary font-sora font-bold text-sm whitespace-normal leading-none">{review.company}</p>
                  <p class="text-[#1C69B7] font-space text-[10px] uppercase tracking-widest mt-1 reviewer-name">{review.name}</p>
                </div>
              </div>
              <p class="review-text-content text-textSecondary font-sora text-sm leading-relaxed whitespace-normal break-words italic">
                "{review.isTranslatable ? review.textEn : review.text}"
              </p>
            </div>
            {review.isTranslatable && (
              <button 
                class="translate-review-btn mt-4 text-[10px] font-space text-brandCyan/70 hover:text-brandCyan flex items-center gap-1 transition-all active:scale-95 cursor-pointer uppercase tracking-wider bg-transparent border-none p-0 w-fit"
                data-en={review.textEn}
                data-pt={review.textPt}
                data-current="en"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Traduzir para o Português
              </button>
            )}
          </div>
        ))}
      </div>

    </div>

    <!-- Fade effects nas bordas -->
    <div class="pointer-events-none absolute inset-y-0 left-0 w-16 md:w-40 bg-gradient-to-r from-darkBg to-transparent z-40"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-16 md:w-40 bg-gradient-to-l from-darkBg to-transparent z-40"></div>

  </div>
</section>

<!-- Efeitos CSS Spotlight de Transições Fluidas -->
<style is:global>
  /* Transições suaves e independentes para todos os elementos das reviews */
  .review-card-container {
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1) !important;
  }

  /* Quando houver foco ou hover em qualquer lugar do shift wrapper, reduz as demais reviews */
  #marquee-shift-wrapper:hover .review-card-container,
  #marquee-shift-wrapper.has-active .review-card-container {
    opacity: 0.35;
    filter: blur(1.5px);
    transform: scale(0.92);
  }

  /* Zoom Premium do comentário focado/hovered */
  #marquee-shift-wrapper:hover .review-card-container:hover,
  #marquee-shift-wrapper .review-card-container.active-card {
    opacity: 1 !important;
    filter: none !important;
    transform: scale(1.18) !important;
    z-index: 50 !important;
    border-color: rgba(54, 214, 214, 0.45) !important;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.9), 0 0 35px rgba(54, 214, 214, 0.35) !important;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // 1. Decode Base64 and draw on Canvas dynamically (anti-copy/no-src-in-code)
    const canvases = document.querySelectorAll('.review-avatar-canvas');
    canvases.forEach(canvas => {
      const hash = canvas.getAttribute('data-hash');
      if (!hash) return;
      
      try {
        const decodedPath = atob(hash);
        const ctx = (canvas as HTMLCanvasElement).getContext('2d');
        if (!ctx) return;
        
        const img = new Image();
        img.src = decodedPath;
        img.onload = () => {
          const size = 96;
          (canvas as HTMLCanvasElement).width = size;
          (canvas as HTMLCanvasElement).height = size;
          
          ctx.beginPath();
          ctx.arc(size / 2, size / 2, size / 2, 0, Math.PI * 2);
          ctx.closePath();
          ctx.clip();
          
          ctx.drawImage(img, 0, 0, size, size);
        };
      } catch (err) {
        console.error('Secure avatar decryption failed', err);
      }
    });

    // 2. Prevent right-click / drag on secure canvases
    document.addEventListener('contextmenu', (e) => {
      if ((e.target as HTMLElement).classList.contains('review-avatar-canvas')) {
        e.preventDefault();
      }
    });
    document.addEventListener('dragstart', (e) => {
      if ((e.target as HTMLElement).classList.contains('review-avatar-canvas')) {
        e.preventDefault();
      }
    });

    // 3. Translation synchronization
    const translateBtns = document.querySelectorAll('.translate-review-btn');
    translateBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        
        const cardContainer = btn.closest('.review-card-container');
        if (!cardContainer) return;
        
        const companyName = cardContainer.querySelector('.text-textPrimary')?.textContent;
        const currentLang = btn.getAttribute('data-current') || 'en';
        const textEn = btn.getAttribute('data-en') || '';
        const textPt = btn.getAttribute('data-pt') || '';
        
        const allCardContainers = document.querySelectorAll('.review-card-container');
        allCardContainers.forEach(container => {
          const name = container.querySelector('.text-textPrimary')?.textContent;
          if (name === companyName) {
            const textEl = container.querySelector('.review-text-content');
            const tBtn = container.querySelector('.translate-review-btn');
            
            if (textEl && tBtn) {
              if (currentLang === 'en') {
                textEl.textContent = `"${textPt}"`;
                tBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> View in English';
                tBtn.setAttribute('data-current', 'pt');
              } else {
                textEl.textContent = `"${textEn}"`;
                tBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="inline mr-1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> Traduzir para o Português';
                tBtn.setAttribute('data-current', 'en');
              }
            }
          }
        });
      });
    });

    // 4. Mecanismo de Alinhamento Horizontal (Shift Spotlight)
    const shiftWrapper = document.getElementById('marquee-shift-wrapper');
    const cards = document.querySelectorAll('.review-card-container');
    let activeCard: Element | null = null;
    let isLocked = false;

    function centerCard(card: Element, locked = false) {
      if (!shiftWrapper) return;
      
      // Se houver trava de clique ativo, ignora hovers genéricos
      if (isLocked && !locked) return;

      cards.forEach(c => c.classList.remove('active-card'));
      
      activeCard = card;
      isLocked = locked;
      
      card.classList.add('active-card');
      shiftWrapper.classList.add('has-active');

      // Força pausa total nas tracks de animação via inline CSS
      const tracks = shiftWrapper.querySelectorAll('.marquee-track');
      tracks.forEach(track => {
        (track as HTMLElement).style.animationPlayState = 'paused';
      });

      // Cálculo de centralização no viewport
      const rect = card.getBoundingClientRect();
      const cardCenter = rect.left + rect.width / 2;
      const viewportCenter = window.innerWidth / 2;
      
      // Lê o transform atual do shiftWrapper para evitar incrementos errados
      const currentTransform = window.getComputedStyle(shiftWrapper).transform;
      let currentX = 0;
      if (currentTransform && currentTransform !== 'none') {
        const matrixValues = currentTransform.match(/matrix.*\((.+)\)/);
        if (matrixValues) {
          const values = matrixValues[1].split(', ');
          currentX = parseFloat(values[4]);
        }
      }

      // O novo X é o atual mais o deslocamento necessário para alinhar ao centro
      const newX = currentX + (viewportCenter - cardCenter);
      shiftWrapper.style.transform = `translateX(${newX}px)`;
    }

    function resetCenter() {
      if (!shiftWrapper || isLocked) return;

      cards.forEach(c => c.classList.remove('active-card'));
      shiftWrapper.classList.remove('has-active');
      shiftWrapper.style.transform = 'none';

      // Libera as tracks para voltarem a rodar normalmente
      const tracks = shiftWrapper.querySelectorAll('.marquee-track');
      tracks.forEach(track => {
        (track as HTMLElement).style.animationPlayState = '';
      });

      activeCard = null;
    }

    function forceReset() {
      isLocked = false;
      resetCenter();
    }

    // Registra os ouvintes
    cards.forEach(card => {
      // Evento de entrada do Mouse (Desktop)
      card.addEventListener('mouseenter', () => {
        centerCard(card, false);
      });

      // Evento de saída do Mouse (Desktop)
      card.addEventListener('mouseleave', () => {
        resetCenter();
      });

      // Evento de Clique / Toque (Mobile & Desktop - Persistente/Travado)
      card.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.translate-review-btn')) return;
        e.stopPropagation();
        
        // Se clicar no card que já está travado, destrava
        if (activeCard === card && isLocked) {
          forceReset();
        } else {
          centerCard(card, true);
        }
      });
    });

    // Clique fora das reviews destrava e reinicia a rolagem
    document.addEventListener('click', (e) => {
      if (!e.target || !(e.target as HTMLElement).closest('.review-card-container')) {
        forceReset();
      }
    });

    // Reposiciona em caso de redimensionamento da janela
    window.addEventListener('resize', () => {
      if (activeCard && isLocked && shiftWrapper) {
        shiftWrapper.style.transform = 'none';
        setTimeout(() => {
          if (activeCard) centerCard(activeCard, true);
        }, 50);
      }
    });
  });
</script>

