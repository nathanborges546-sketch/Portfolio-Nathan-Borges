              <i class="fa-solid fa-check animate-bounce text-[10px]"></i>
            </div>
            <span class="text-xs font-bold text-textPrimary">Todos os Leads Foram Contactados!</span>
            <p class="text-[10px] text-textSecondary mt-1 font-space">Acompanhe a esteira de follow up ao lado para converter em vendas.</p>
          </div>
        `;
