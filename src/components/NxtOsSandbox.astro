---
// src/components/NxtOsSandbox.astro
---

<div class="w-full flex flex-col font-sora mt-4 opacity-0 animate-fade-in-up [animation-delay:200ms]">
  
  <!-- Painel de Métricas e KPIs (Dashboard) -->
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
    <div class="bg-[#0b0e14]/60 border border-white/5 p-4 rounded-2xl flex flex-col justify-between shadow-inner">
      <span class="text-[9px] font-space text-[#8b949e] uppercase tracking-widest font-bold">Total de Leads</span>
      <div class="text-2xl font-bold text-white mt-1" id="dash-total">6</div>
      <div class="text-[9px] text-[#8b949e] mt-1 font-space">Sincronizados Notion</div>
    </div>
    <div class="bg-[#0b0e14]/60 border border-white/5 p-4 rounded-2xl flex flex-col justify-between shadow-inner">
      <span class="text-[9px] font-space text-[#00f2fe] uppercase tracking-widest font-bold">Contatados</span>
      <div class="text-2xl font-bold text-[#00f2fe] mt-1" id="dash-contacted">3</div>
      <div class="text-[9px] text-[#8b949e] mt-1 font-space">Pelo Script de Abordagem</div>
    </div>
    <div class="bg-[#0b0e14]/60 border border-white/5 p-4 rounded-2xl flex flex-col justify-between shadow-inner">
      <span class="text-[9px] font-space text-emerald-400 uppercase tracking-widest font-bold">Taxa de Resposta</span>
      <div class="text-2xl font-bold text-emerald-400 mt-1" id="dash-response">50.0%</div>
      <div class="text-[9px] text-[#8b949e] mt-1 font-space">Feedbacks Ativos</div>
    </div>
    <div class="bg-[#0b0e14]/60 border border-white/5 p-4 rounded-2xl flex flex-col justify-between shadow-inner">
      <span class="text-[9px] font-space text-blue-400 uppercase tracking-widest font-bold">Reuniões</span>
      <div class="text-2xl font-bold text-blue-400 mt-1" id="dash-meetings">1</div>
      <div class="text-[9px] text-[#8b949e] mt-1 font-space">Agendadas via Link</div>
    </div>
    <div class="bg-[#0b0e14]/60 border border-white/5 p-4 rounded-2xl flex flex-col justify-between shadow-inner col-span-2 lg:col-span-1">
      <span class="text-[9px] font-space text-amber-500 uppercase tracking-widest font-bold">LTV / Capital Convertido</span>
      <div class="text-2xl font-bold text-amber-500 mt-1" id="dash-ltv">R$ 5.000,00</div>
      <div class="text-[9px] text-[#8b949e] mt-1 font-space">Contratos B2B Fechados</div>
    </div>
  </div>

  <!-- Layout de Duas Colunas -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
    
    <!-- Coluna da Esquerda: Central de Prospecção Ativa (Disparos) -->
    <div class="lg:col-span-7 flex flex-col gap-6 bg-[#0b0e14]/40 border border-white/5 p-6 rounded-3xl">
      <div class="flex items-center justify-between border-b border-white/5 pb-4">
        <div>
          <h3 class="text-lg font-bold text-[#f0f6fc]">🎯 Central de Disparos Ativos</h3>
          <p class="text-xs text-[#8b949e] mt-1">Configure regras de roteamento, fallbacks e acione em lote.</p>
        </div>
        <span class="text-[10px] font-space bg-brandCyan/10 text-brandCyan border border-brandCyan/20 px-3 py-1 rounded-full uppercase tracking-wider font-semibold">NXT OS CORE</span>
      </div>

      <!-- PAINEL DE AUTOMAÇÃO AVANÇADA -->
      <div class="bg-[#0b0e14]/60 border border-white/5 rounded-2xl p-5 flex flex-col gap-4 shadow-inner">
        <div class="flex items-center justify-between border-b border-white/5 pb-3">
          <span class="text-[10px] font-space text-[#00f2fe] uppercase tracking-widest font-bold flex items-center gap-1.5">
            <i class="fa-solid fa-gears animate-spin [animation-duration:12s]"></i> Painel de Automação Avançada
          </span>
          <span class="text-[8px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-semibold uppercase tracking-wider">Scheduler Active</span>
        </div>

        <!-- Linha 1: Scheduler & Data/Hora -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-[9px] text-[#8b949e] font-bold uppercase tracking-wider font-space">Janela de Disparo (Agendamento)</label>
            <div class="flex gap-2">
              <input type="date" id="scheduler-date" class="bg-[#0b0e14] border border-white/10 rounded-xl px-3 py-2 text-xs text-white outline-none focus:border-brandCyan/50 font-sora cursor-pointer w-full" value="2026-05-18" />
              <input type="time" id="scheduler-time" class="bg-[#0b0e14] border border-white/10 rounded-xl px-3 py-2 text-xs text-white outline-none focus:border-brandCyan/50 font-sora cursor-pointer w-full" value="15:00" />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[9px] text-[#8b949e] font-bold uppercase tracking-wider font-space">Roteamento Multicanal (Prioridade)</label>
            <select id="automation-strategy" class="bg-[#0b0e14] border border-white/10 rounded-xl px-3 py-2.5 text-xs text-white outline-none focus:border-brandCyan/50 font-sora cursor-pointer w-full">
              <option value="priority-whatsapp" selected>Prioridade WhatsApp (Smart Fallback)</option>
              <option value="priority-email">Prioridade E-mail (Smart Fallback)</option>
              <option value="simultaneous">WhatsApp & E-mail Simultâneo</option>
            </select>
          </div>
        </div>

        <!-- Linha 2: Sliders de dias para CRM -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-white/5 pt-3">
          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between items-center text-[9px] text-[#8b949e] font-bold uppercase tracking-wider font-space">
              <span>Intervalo Follow Up</span>
              <span id="label-val-followup" class="text-brandCyan font-bold text-xs">3 dias</span>
            </div>
            <input type="range" id="slider-followup" min="1" max="10" value="3" class="w-full h-1 bg-[#0b0e14] border border-white/10 rounded-lg appearance-none cursor-pointer accent-[#00f2fe]" />
          </div>

          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between items-center text-[9px] text-[#8b949e] font-bold uppercase tracking-wider font-space">
              <span>Arquivar sem resposta após</span>
              <span id="label-val-archive" class="text-red-400 font-bold text-xs">7 dias</span>
            </div>
            <input type="range" id="slider-archive" min="3" max="15" value="7" class="w-full h-1 bg-[#0b0e14] border border-white/10 rounded-lg appearance-none cursor-pointer accent-red-500" />
          </div>
        </div>

        <!-- Ação do Bulk Scheduler -->
        <div class="flex gap-3 items-stretch mt-1">
          <button id="btn-run-automation" class="flex-1 bg-gradient-to-r from-[#00f2fe] to-blue-500 text-[#0b0e14] font-space font-bold text-xs tracking-wider uppercase py-3.5 px-6 rounded-xl hover:brightness-110 active:scale-95 transition-all flex items-center justify-center gap-2 cursor-pointer shadow-lg shadow-brandCyan/10">
            <i class="fa-solid fa-play"></i> Iniciar Automação Programada em Lote
          </button>
          
          <button id="btn-reset-leads" class="bg-white/5 border border-white/10 text-gray-400 hover:text-white px-4 rounded-xl hover:bg-white/10 transition-all flex items-center justify-center cursor-pointer" title="Reiniciar Simulação">
            <i class="fa-solid fa-arrows-rotate text-xs"></i>
          </button>
        </div>
      </div>

      <!-- Console de Logs da Automação NXT OS -->
      <div id="automation-console-box" class="bg-[#0b0e14]/85 border border-white/10 rounded-2xl p-4 font-mono text-[10px] text-emerald-400 leading-relaxed shadow-inner hidden">
        <div class="flex items-center justify-between border-b border-white/5 pb-2 mb-2">
          <span class="text-gray-400 font-space uppercase tracking-wider font-bold text-[9px]">🖥️ Console de Execução NXT OS (automacao_nxt.py)</span>
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        </div>
        <div id="automation-console-logs" class="flex flex-col gap-1 pr-1 max-h-[110px] overflow-y-auto scrollbar-thin">
          <!-- Logs will stream here dynamically -->
        </div>
      </div>

      <!-- Customizador de Scripts (Abas Rápidas) -->
      <div class="bg-[#0b0e14]/60 border border-white/5 rounded-2xl p-4">
        <span class="text-[9px] font-space text-[#8b949e] uppercase tracking-wider block mb-3 font-bold">📜 Customizar Script Padrão</span>
        
        <div class="flex gap-2 border-b border-white/5 pb-2 mb-3">
          <button class="script-tab-btn active text-xs font-semibold px-3 py-1.5 rounded-lg transition-all" data-channel="whatsapp">
            <i class="fa-brands fa-whatsapp text-emerald-400"></i> WhatsApp
          </button>
          <button class="script-tab-btn text-xs font-semibold px-3 py-1.5 rounded-lg transition-all" data-channel="email">
            <i class="fa-regular fa-envelope text-blue-400"></i> E-mail
          </button>
          <button class="script-tab-btn text-xs font-semibold px-3 py-1.5 rounded-lg transition-all" data-channel="linkedin">
            <i class="fa-brands fa-linkedin text-sky-400"></i> LinkedIn
          </button>
        </div>

        <!-- Inputs de Script -->
        <div class="space-y-3">
          <textarea id="script-input-whatsapp" class="w-full bg-[#0b0e14] border border-white/5 rounded-xl p-3 text-xs text-[#f0f6fc] focus:border-brandCyan/50 outline-none leading-relaxed custom-textarea font-sora" rows="3">Olá! Sou o Nathan da NXT. Analisei o site da [Empresa] e notei algo crítico: [Diagnóstico]. Acredito que corrigindo isso podemos destravar mais vendas. Topa uma breve conversa?</textarea>
          <textarea id="script-input-email" class="w-full bg-[#0b0e14] border border-white/5 rounded-xl p-3 text-xs text-[#f0f6fc] focus:border-brandCyan/50 outline-none leading-relaxed hidden custom-textarea font-sora" rows="3">Prezado(a) Diretor(a),\n\nRealizei um diagnóstico técnico no site da [Empresa] e identifiquei falhas que prejudicam a captação de leads:\n\n[Diagnóstico]\n\nDesenvolvi um pipeline que resolve essas brechas. Gostaria de receber a solução?\n\nAtenciosamente,\nNathan - NXT OS</textarea>
          <textarea id="script-input-linkedin" class="w-full bg-[#0b0e14] border border-white/5 rounded-xl p-3 text-xs text-[#f0f6fc] focus:border-brandCyan/50 outline-none leading-relaxed hidden custom-textarea font-sora" rows="3">Olá! Vi o trabalho da [Empresa] no mercado e notei pontos fortes. Mas também reparei que vocês sofrem com [Diagnóstico]. Tem interesse em ver como otimizar isso?</textarea>
        </div>
        <p class="text-[9px] text-[#8b949e] mt-2 font-space leading-relaxed"><i class="fa-solid fa-info-circle"></i> As tags <strong class="text-white">[Empresa]</strong> e <strong class="text-white">[Diagnóstico]</strong> são substituídas automaticamente em tempo real.</p>
      </div>

      <!-- Fila de Leads Ativa -->
      <div class="flex flex-col gap-4" id="leads-queue-container">
        <!-- Renders leads here dynamically -->
      </div>
    </div>

    <!-- Coluna da Direita: Central CRM & Esteira de Follow Up -->
    <div class="lg:col-span-5 flex flex-col gap-6 bg-[#0b0e14]/40 border border-white/5 p-6 rounded-3xl">
      <div class="flex items-center justify-between border-b border-white/5 pb-4">
        <div>
          <h3 class="text-lg font-bold text-[#f0f6fc]">🔁 Esteira de Follow Up</h3>
          <p class="text-xs text-[#8b949e] mt-1">Acompanhe retornos e evite perda de negociações.</p>
        </div>
        <span class="text-[10px] font-space bg-amber-500/10 text-amber-500 border border-amber-500/20 px-3 py-1 rounded-full uppercase tracking-wider font-semibold">NOTION SYNCED</span>
      </div>

      <!-- Lista de Follow-Up -->
      <div class="flex-1 flex flex-col gap-4 overflow-y-auto max-h-[750px] pr-1" id="follow-up-container">
        <!-- Renders follow up cards here dynamically -->
      </div>
      
      <div class="text-[9px] text-[#8b949e]/40 pt-3 border-t border-white/5 flex justify-between font-space font-semibold">
        <span>Sistemas integrados: notion_crm • gemini_agent.py</span>
        <span>Ação Inteligente (RID)</span>
      </div>
    </div>

  </div>

  <!-- Popup Modal de Visualização de Script -->
  <div id="script-preview-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0b0e14]/80 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500">
    <div class="bg-[#161b22] border border-white/10 rounded-3xl p-6 max-w-lg w-full shadow-2xl transform scale-95 transition-all duration-500 flex flex-col gap-5" id="script-preview-modal-content">
      <div class="flex items-start justify-between">
        <div>
          <span class="font-space text-[10px] text-brandCyan uppercase tracking-widest font-semibold" id="modal-top-label">ABORDAGEM PRONTAMENTE GERADA</span>
          <h4 class="text-xl font-bold text-[#f0f6fc] mt-1 tracking-tight" id="modal-lead-title">Script para Somos6digital</h4>
        </div>
        <div class="w-8 h-8 rounded-full bg-brandCyan/10 border border-brandCyan/20 flex items-center justify-center text-brandCyan text-sm">
          <i class="fa-solid fa-wand-magic-sparkles"></i>
        </div>
      </div>

      <!-- Bloco de Código / Mensagem Final -->
      <div class="bg-[#0b0e14] border border-white/5 p-4 rounded-2xl relative">
        <pre class="text-xs text-gray-300 leading-relaxed font-sans whitespace-pre-wrap select-all pr-12 font-sora" id="modal-script-text"></pre>
        <button id="btn-copy-modal" class="absolute top-4 right-4 w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white transition-all active:scale-95 cursor-pointer">
          <i class="fa-solid fa-copy text-xs"></i>
        </button>
      </div>

      <!-- Popover de Registro de Canal -->
      <div class="bg-[#1e2530]/55 border border-white/5 p-4 rounded-2xl flex flex-col gap-3">
        <div>
          <span class="text-xs font-bold text-white font-space">Confirmar Envio e Registrar Canal</span>
          <p class="text-[10px] text-gray-400 mt-1">Ao registrar, o lead é automaticamente atualizado no Notion CRM e movido para a esteira de acompanhamento.</p>
        </div>
        
        <div class="flex gap-2">
          <select id="modal-select-channel" class="flex-1 bg-[#0b0e14] border border-white/10 rounded-xl px-3 py-2.5 text-xs text-white outline-none focus:border-brandCyan/50 font-sora cursor-pointer">
            <option value="WhatsApp">WhatsApp</option>
            <option value="E-mail">E-mail</option>
            <option value="LinkedIn">LinkedIn</option>
          </select>
          <button id="btn-save-modal" class="bg-[#00f2fe] text-[#0b0e14] font-space font-bold text-xs tracking-wider uppercase py-3 px-6 rounded-xl hover:brightness-110 active:scale-95 transition-all cursor-pointer">
            Registrar e Mover CRM
          </button>
        </div>
      </div>

      <button id="btn-close-modal" class="w-full bg-white/5 text-gray-400 hover:text-white font-space font-semibold text-xs tracking-wider uppercase py-3.5 px-4 rounded-xl transition-all duration-300 border border-white/5 cursor-pointer">
        Cancelar e Voltar
      </button>
    </div>
  </div>

  <!-- Elemento de Confetes Canvas de Comemoração -->
  <canvas id="confetti-canvas" class="fixed inset-0 z-40 pointer-events-none w-full h-full"></canvas>

</div>

<script>
  const INITIAL_QUEUE = [
    {
      id: '1',
      empresa: 'Somos6digital',
      site: 'https://somos6digital.com.br',
      telefone: '5511999991111',
      email: 'contato@somos6digital.com.br',
      linkedin: 'https://linkedin.com/company/somos6digital',
      instagram: 'https://instagram.com/somos6digital',
      diagnostico: 'Ausência de Pixel do Meta no checkout, tempo de carregamento mobile de 4.8s (LCP crítico) e falta de formulário de captura rápida na home.',
      status: 'Aguardando Disparo',
      hasWhatsApp: true,
      hasEmail: true
    },
    {
      id: '2',
      empresa: 'Actwork',
      site: 'https://actwork.com.br',
      telefone: '',
      email: 'vendas@actwork.com.br',
      linkedin: 'https://linkedin.com/company/actwork',
      instagram: 'https://instagram.com/actwork',
      diagnostico: 'Formulário de contato principal quebrado (retorna erro 500 no console), sem pixel de rastreamento de anúncios e ausência de SSL ativo no subdomínio de blog.',
      status: 'Aguardando Disparo',
      hasWhatsApp: false,
      hasEmail: true
    },
    {
      id: '3',
      empresa: 'Bazooka Design',
      site: 'https://bazooka.pt',
      telefone: '',
      email: '',
      linkedin: 'https://linkedin.com/company/bazooka',
      instagram: 'https://instagram.com/bazookadesign',
      diagnostico: 'Perfil do Instagram sem link direto para o WhatsApp, velocidade de página baixa por imagens sem otimização (WebP) e falta de cabeçalho de conversão evidente.',
      status: 'Aguardando Disparo',
      hasWhatsApp: false,
      hasEmail: false
    }
  ];

  const INITIAL_FOLLOWUP = [
    {
      id: '4',
      empresa: 'Ramper B2B',
      site: 'https://ramper.com.br',
      telefone: '5511999056763',
      email: 'leads@ramper.com.br',
      linkedin: 'https://linkedin.com/company/ramper',
      instagram: 'https://instagram.com/ramper',
      diagnostico: 'Contatos duplicados na base do comercial, números desformatados e falta de follow up de leads frios.',
      status: 'Tentativa de contato',
      canal: 'WhatsApp',
      diasPassados: 4
    },
    {
      id: '5',
      empresa: 'Reev CRM',
      site: 'https://reev.co',
      telefone: '553133334444',
      email: 'contato@reev.co',
      linkedin: 'https://linkedin.com/company/reev',
      instagram: 'https://instagram.com/reev',
      diagnostico: 'Lentidão crítica de carregamento mobile e formulário quebrado de captura de leads no blog principal.',
      status: 'Follow up',
      canal: 'LinkedIn',
      diasPassados: 11
    },
    {
      id: '6',
      empresa: 'Somos6digital SP',
      site: 'https://somos6digital.com.br',
      telefone: '5511999991112',
      email: 'comercial@somos6digital.com.br',
      linkedin: '',
      instagram: '',
      diagnostico: 'Duplicado no funil físico, sem automação de follow up e perda crítica de LTV mensal.',
      status: 'Convertido',
      canal: 'E-mail',
      diasPassados: 15
    }
  ];

  let activeQueueLeads = JSON.parse(JSON.stringify(INITIAL_QUEUE));
  let activeFollowUpLeads = JSON.parse(JSON.stringify(INITIAL_FOLLOWUP));

  let currentSelectedChannel = 'whatsapp';
  let leadToProspectId = '';

  const EXCHANGE_LTV_RATE = 5000.00;

  function initNxtOsSimulation() {
    // DOM Elements
    const queueContainer = document.getElementById('leads-queue-container');
    const followUpContainer = document.getElementById('follow-up-container');
    
    // Sliders
    const sliderFollowUp = document.getElementById('slider-followup') as HTMLInputElement;
    const sliderArchive = document.getElementById('slider-archive') as HTMLInputElement;
    const labelFollowUp = document.getElementById('label-val-followup');
    const labelArchive = document.getElementById('label-val-archive');
    const selectStrategy = document.getElementById('automation-strategy') as HTMLSelectElement;

    // Advanced Automation Elements
    const btnRunAutomation = document.getElementById('btn-run-automation');
    const btnResetLeads = document.getElementById('btn-reset-leads');
    const consoleBox = document.getElementById('automation-console-box');
    const consoleLogs = document.getElementById('automation-console-logs');

    // Scheduler inputs
    const schedulerDate = document.getElementById('scheduler-date') as HTMLInputElement;
    const schedulerTime = document.getElementById('scheduler-time') as HTMLInputElement;

    // Script Customization Tabs
    const scriptTabBtns = document.querySelectorAll('.script-tab-btn');
    const textareaWa = document.getElementById('script-input-whatsapp') as HTMLTextAreaElement;
    const textareaEmail = document.getElementById('script-input-email') as HTMLTextAreaElement;
    const textareaLinkedin = document.getElementById('script-input-linkedin') as HTMLTextAreaElement;
    
    // Script Preview Modal Elements
    const previewModal = document.getElementById('script-preview-modal');
    const previewModalContent = document.getElementById('script-preview-modal-content');
    const modalLeadTitle = document.getElementById('modal-lead-title');
    const modalScriptText = document.getElementById('modal-script-text');
    const modalSelectChannel = document.getElementById('modal-select-channel') as HTMLSelectElement;
    
    const btnCloseModal = document.getElementById('btn-close-modal');
    const btnCopyModal = document.getElementById('btn-copy-modal');
    const btnSaveModal = document.getElementById('btn-save-modal');

    // Re-render leads when strategy changes
    selectStrategy?.addEventListener('change', () => {
      renderQueueUI();
    });

    // Slider Listeners
    sliderFollowUp?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      if (labelFollowUp) labelFollowUp.innerText = `${val} ${val === '1' ? 'dia' : 'dias'}`;
      renderFollowUpUI();
    });

    sliderArchive?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      if (labelArchive) labelArchive.innerText = `${val} ${val === '1' ? 'dia' : 'dias'}`;
      applyAutoArchiveRule(parseInt(val));
    });

    function applyAutoArchiveRule(archiveLimit) {
      // Find leads that exceed the limit
      const toArchive = activeFollowUpLeads.filter(l => l.status !== 'Convertido' && l.diasPassados >= archiveLimit);
      
      if (toArchive.length > 0) {
        toArchive.forEach(lead => {
          showNotification(`🗄️ Lead ${lead.empresa} arquivado automaticamente (Excedeu limite de ${archiveLimit} dias)`);
          addConsoleLog(`[CRM] Lead "${lead.empresa}" sem resposta há ${lead.diasPassados} dias. Movido automaticamente para status: ARQUIVADO.`, 'error');
        });

        // Filter active list
        activeFollowUpLeads = activeFollowUpLeads.filter(l => !(l.status !== 'Convertido' && l.diasPassados >= archiveLimit));
        
        recalculateMetrics();
        renderFollowUpUI();
      }
    }

    function addConsoleLog(text, type = 'info') {
      if (!consoleLogs || !consoleBox) return;
      consoleBox.classList.remove('hidden');
      
      const time = new Date().toLocaleTimeString('pt-BR');
      let colorClass = 'text-emerald-400';
      if (type === 'error') colorClass = 'text-red-400';
      else if (type === 'warn') colorClass = 'text-amber-400';
      else if (type === 'success') colorClass = 'text-[#00f2fe] font-bold';

      const logElement = document.createElement('div');
      logElement.className = `leading-relaxed animate-fade-in-up font-mono ${colorClass}`;
      logElement.innerHTML = `[${time}] ${text}`;
      consoleLogs.appendChild(logElement);
      
      // Auto Scroll
      consoleLogs.scrollTop = consoleLogs.scrollHeight;
    }

    // Interactive Bulk Scheduler Run
    btnRunAutomation?.addEventListener('click', () => {
      if (activeQueueLeads.length === 0) {
        showNotification("⚠️ A fila de leads ativos já está vazia!");
        return;
      }

      const dateVal = schedulerDate.value;
      const timeVal = schedulerTime.value;
      const strategyVal = selectStrategy.value;

      // Lock buttons
      btnRunAutomation.setAttribute('disabled', 'true');
      btnRunAutomation.classList.add('opacity-50', 'pointer-events-none');

      // Clear logs
      if (consoleLogs) consoleLogs.innerHTML = '';
      addConsoleLog(`🕒 Agendador programado para a data: ${dateVal} às ${timeVal}...`, 'warn');
      addConsoleLog("⏱️ Aguardando janela de disparo automático (simulando 2000ms)...", 'warn');

      setTimeout(() => {
        addConsoleLog("🚀 Janela de disparo aberta! Iniciando automacao_nxt.py em lote...", 'success');
        
        // Loop chain to simulate beautiful delayed logs
        let delay = 600;
        const leadsToProcess = [...activeQueueLeads];
        
        leadsToProcess.forEach((lead, index) => {
          // Calculate channel for each lead based on strategy
          const routing = calculateChannelRouting(lead, strategyVal);
          
          setTimeout(() => {
            addConsoleLog(`🔍 Analisando lead "${lead.empresa}" (${lead.site})...`);
          }, delay);
          delay += 600;

          setTimeout(() => {
            if (strategyVal === 'priority-whatsapp') {
              addConsoleLog(`📡 Evolution API: Verificando presença de WhatsApp no número...`);
              if (lead.hasWhatsApp) {
                addConsoleLog(`✅ WhatsApp ativo! Canal eleito: WhatsApp.`, 'info');
              } else {
                addConsoleLog(`⚠️ WhatsApp indisponível. Aplicando Smart Fallback de 1º nível...`, 'warn');
                if (lead.hasEmail) {
                  addConsoleLog(`📧 E-mail ativo! Canal eleito: E-mail.`, 'info');
                } else {
                  addConsoleLog(`⚠️ E-mail também indisponível. Aplicando Smart Fallback de 2º nível...`, 'warn');
                  addConsoleLog(`📸 Perfil de Instagram detectado! Canal eleito: Direct Instagram.`, 'info');
                }
              }
            } else if (strategyVal === 'priority-email') {
              addConsoleLog(`📡 SMTP Check: Verificando integridade da conta de E-mail...`);
              if (lead.hasEmail) {
                addConsoleLog(`✅ E-mail verificado! Canal eleito: E-mail.`, 'info');
              } else {
                addConsoleLog(`⚠️ E-mail indisponível. Aplicando Smart Fallback de 1º nível...`, 'warn');
                if (lead.hasWhatsApp) {
                  addConsoleLog(`📲 WhatsApp ativo! Canal eleito: WhatsApp.`, 'info');
                } else {
                  addConsoleLog(`⚠️ WhatsApp também indisponível. Aplicando Smart Fallback de 2º nível...`, 'warn');
                  addConsoleLog(`📸 Perfil de Instagram detectado! Canal eleito: Direct Instagram.`, 'info');
                }
              }
            } else {
              addConsoleLog(`⚡ Modo Simultâneo: Disparando cópias idênticas para todos os canais cadastrados...`);
            }
          }, delay);
          delay += 700;

          setTimeout(() => {
            addConsoleLog(`🧠 IA: Aplicando prompt RID no Gemini 2.0 Flash... [Sucesso]`);
            addConsoleLog(`📤 Enviando abordagem personalizada para "${lead.empresa}" via ${routing.channelName}.`, 'success');
          }, delay);
          delay += 800;

          // Actually move the lead in the background
          setTimeout(() => {
            // Remove from queue
            const qIndex = activeQueueLeads.findIndex(l => l.id === lead.id);
            if (qIndex !== -1) {
              activeQueueLeads.splice(qIndex, 1);
            }
            
            // Push to CRM
            activeFollowUpLeads.unshift({
              ...lead,
              status: 'Tentativa de contato',
              canal: routing.channelName,
              diasPassados: 0
            });
            
            // Visual feedback on card
            const cardEl = document.getElementById(`queue-card-${lead.id}`);
            if (cardEl) {
              cardEl.classList.add('opacity-0', 'scale-95', 'translate-x-4');
            }

            renderQueueUI();
            renderFollowUpUI();
            recalculateMetrics();
          }, delay);
          delay += 200;
        });

        // Wrap up execution
        setTimeout(() => {
          addConsoleLog("💾 Notion API: Sincronizando dados de prospecção e atualizando tags de funil...", 'warn');
        }, delay);
        delay += 600;

        setTimeout(() => {
          addConsoleLog("🏆 Execução em Lote Finalizada com 100% de Confiabilidade!", 'success');
          showNotification("🚀 Disparo de Automação Concluído com Sucesso!");
          
          // Re-enable button
          btnRunAutomation.removeAttribute('disabled');
          btnRunAutomation.classList.remove('opacity-50', 'pointer-events-none');
        }, delay);

      }, 2000);
    });

    // Reset leads to initial simulation state
    btnResetLeads?.addEventListener('click', () => {
      activeQueueLeads = JSON.parse(JSON.stringify(INITIAL_QUEUE));
      activeFollowUpLeads = JSON.parse(JSON.stringify(INITIAL_FOLLOWUP));
      
      // Hide console
      if (consoleBox) consoleBox.classList.add('hidden');
      if (consoleLogs) consoleLogs.innerHTML = '';
      
      renderQueueUI();
      renderFollowUpUI();
      recalculateMetrics();
      showNotification("🔄 Simulação Reiniciada para os Padrões!");
    });

    // Tab Logic for customizer
    scriptTabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        scriptTabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const channel = btn.getAttribute('data-channel');
        currentSelectedChannel = channel;
        
        // Toggle textareas
        textareaWa.classList.add('hidden');
        textareaEmail.classList.add('hidden');
        textareaLinkedin.classList.add('hidden');
        
        if (channel === 'whatsapp') textareaWa.classList.remove('hidden');
        else if (channel === 'email') textareaEmail.classList.remove('hidden');
        else if (channel === 'linkedin') textareaLinkedin.classList.remove('hidden');
      });
    });

    // Calculate smart channel routing on the fly based on strategy
    function calculateChannelRouting(lead, strategy) {
      if (strategy === 'priority-whatsapp') {
        if (lead.hasWhatsApp) return { channelName: 'WhatsApp', badge: '📲 WhatsApp (Canal Principal)', color: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20' };
        if (lead.hasEmail) return { channelName: 'E-mail', badge: '📧 E-mail (Fallback: WA indisponível)', color: 'text-blue-400 bg-blue-400/10 border-blue-400/20' };
        return { channelName: 'Instagram', badge: '📸 Instagram (2º Fallback: WA/E-mail indisponíveis)', color: 'text-pink-400 bg-pink-400/10 border-pink-400/20' };
      } else if (strategy === 'priority-email') {
        if (lead.hasEmail) return { channelName: 'E-mail', badge: '📧 E-mail (Canal Principal)', color: 'text-blue-400 bg-blue-400/10 border-blue-400/20' };
        if (lead.hasWhatsApp) return { channelName: 'WhatsApp', badge: '📲 WhatsApp (Fallback: E-mail indisponível)', color: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20' };
        return { channelName: 'Instagram', badge: '📸 Instagram (2º Fallback: WA/E-mail indisponíveis)', color: 'text-pink-400 bg-pink-400/10 border-pink-400/20' };
      } else {
        // Simultaneous
        if (lead.hasWhatsApp && lead.hasEmail) return { channelName: 'WA & E-mail', badge: '⚡ WA + E-mail (Simultâneo)', color: 'text-[#00f2fe] bg-[#00f2fe]/10 border-[#00f2fe]/20' };
        if (lead.hasWhatsApp) return { channelName: 'WhatsApp', badge: '📲 WhatsApp (E-mail indisponível)', color: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20' };
        if (lead.hasEmail) return { channelName: 'E-mail', badge: '📧 E-mail (WA indisponível)', color: 'text-blue-400 bg-blue-400/10 border-blue-400/20' };
        return { channelName: 'Instagram', badge: '📸 Instagram (Simultâneo indisponível)', color: 'text-pink-400 bg-pink-400/10 border-pink-400/20' };
      }
    }

    // Generate calculated script based on selected channel and templates
    function getPersonalizedScript(lead, channel) {
      let baseText = '';
      if (channel === 'whatsapp') baseText = textareaWa.value;
      else if (channel === 'email') baseText = textareaEmail.value;
      else baseText = textareaLinkedin.value;

      return baseText
        .replace(/\[Empresa\]/g, lead.empresa)
        .replace(/\[Diagnóstico\]/g, lead.diagnostico);
    }

    // Modal Copy logic
    btnCopyModal?.addEventListener('click', () => {
      if (modalScriptText) {
        navigator.clipboard.writeText(modalScriptText.innerText);
        const icon = btnCopyModal.querySelector('i');
        if (icon) {
          icon.className = "fa-solid fa-check text-emerald-400";
          setTimeout(() => {
            icon.className = "fa-solid fa-copy text-xs";
          }, 1500);
        }
      }
    });

    // Close Modal
    btnCloseModal?.addEventListener('click', () => {
      if (previewModal && previewModalContent) {
        previewModal.classList.add('opacity-0', 'pointer-events-none');
        previewModalContent.classList.remove('scale-100');
        previewModalContent.classList.add('scale-95');
      }
    });

    // Save and register prospect
    btnSaveModal?.addEventListener('click', () => {
      const selectedChannel = modalSelectChannel.value;
      
      // Move lead from active queue to follow up
      const leadIndex = activeQueueLeads.findIndex(l => l.id === leadToProspectId);
      if (leadIndex !== -1) {
        const lead = activeQueueLeads[leadIndex];
        
        // Remove from queue
        activeQueueLeads.splice(leadIndex, 1);
        
        // Push to follow up
        activeFollowUpLeads.unshift({
          ...lead,
          status: 'Tentativa de contato',
          canal: selectedChannel,
          diasPassados: 0
        });

        // Trigger CSS animation of card deletion
        const cardElement = document.getElementById(`queue-card-${leadToProspectId}`);
        if (cardElement) {
          cardElement.classList.add('opacity-0', 'scale-95', 'translate-x-4');
          setTimeout(() => {
            renderQueueUI();
            renderFollowUpUI();
            recalculateMetrics();
          }, 400);
        }
      }

      // Close modal
      if (previewModal && previewModalContent) {
        previewModal.classList.add('opacity-0', 'pointer-events-none');
        previewModalContent.classList.remove('scale-100');
        previewModalContent.classList.add('scale-95');
      }
    });

    window.openProspectModal = function(leadId, channelType) {
      leadToProspectId = leadId;
      const lead = activeQueueLeads.find(l => l.id === leadId);
      if (lead) {
        if (modalLeadTitle && modalScriptText && previewModal && previewModalContent && modalSelectChannel) {
          modalLeadTitle.innerText = `Script de abordagem para ${lead.empresa}`;
          modalScriptText.innerText = getPersonalizedScript(lead, channelType);
          
          // Prefill channel selector matching the button clicked
          if (channelType === 'whatsapp') modalSelectChannel.value = 'WhatsApp';
          else if (channelType === 'email') modalSelectChannel.value = 'E-mail';
          else modalSelectChannel.value = 'LinkedIn';
          
          // Open Modal
          previewModal.classList.remove('opacity-0', 'pointer-events-none');
          previewModalContent.classList.remove('scale-95');
          previewModalContent.classList.add('scale-100');
        }
      }
    };

    window.updateFollowUpStatus = function(leadId, newStatus) {
      const lead = activeFollowUpLeads.find(l => l.id === leadId);
      if (lead) {
        lead.status = newStatus;
        
        // If converted, celebrate!
        if (newStatus === 'Convertido') {
          triggerConfettiCelebration();
          showNotification(`🚀 Contrato Fechado com ${lead.empresa}! LTV Ganho: R$ 5.000,00`);
          addConsoleLog(`🏆 CONTRATO FECHADO: Lead "${lead.empresa}" converteu! LTV de R$ 5.000,00 conciliado no Notion CRM.`, 'success');
        }

        recalculateMetrics();
        renderFollowUpUI();
      }
    };

    // Render Prospecting Queue UI
    function renderQueueUI() {
      if (!queueContainer) return;
      
      if (activeQueueLeads.length === 0) {
        queueContainer.innerHTML = `
          <div class="flex flex-col items-center justify-center text-center py-12 border border-dashed border-white/10 rounded-2xl bg-white/[0.01]">
            <div class="w-12 h-12 rounded-full bg-brandCyan/10 border border-brandCyan/20 flex items-center justify-center mb-3 text-brandCyan">
              <i class="fa-solid fa-check animate-bounce"></i>
            </div>
            <span class="text-xs font-bold text-white">Todos os Leads Foram Contactados!</span>
            <p class="text-[10px] text-[#8b949e] mt-1 font-space">Acompanhe a esteira de follow up ao lado para converter em vendas.</p>
          </div>
        `;
        return;
      }

      const currentStrategy = selectStrategy?.value || 'priority-whatsapp';

      queueContainer.innerHTML = activeQueueLeads.map(lead => {
        // Calculate smart routing tag and details on the fly
        const routing = calculateChannelRouting(lead, currentStrategy);

        return `
          <div id="queue-card-${lead.id}" class="bg-[#161b22]/40 border border-white/5 rounded-2xl p-5 flex flex-col gap-4 hover:border-brandCyan/20 transition-all duration-300 transform">
            <div class="flex justify-between items-start">
              <div>
                <h4 class="text-sm font-bold text-white">${lead.empresa}</h4>
                <a href="${lead.site}" target="_blank" class="text-[10px] text-brandCyan hover:underline font-space mt-1 inline-flex items-center gap-1">
                  🌐 ${lead.site}
                </a>
              </div>
              <span class="text-[8px] font-space border px-2 py-0.5 rounded font-bold uppercase tracking-wider ${routing.color}">
                ${routing.badge}
              </span>
            </div>

            <div class="bg-[#0b0e14]/50 border border-white/5 p-3 rounded-xl">
              <span class="text-[9px] font-space text-brandCyan font-bold uppercase tracking-wider block mb-1">Diagnóstico RID Gemini</span>
              <p class="text-xs text-gray-300 leading-relaxed font-sora italic">"${lead.diagnostico}"</p>
            </div>

            <div class="grid grid-cols-3 gap-2">
              <button onclick="window.openProspectModal('${lead.id}', 'whatsapp')" class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 font-space font-bold text-[10px] tracking-wider uppercase py-2.5 rounded-lg hover:bg-emerald-500/20 active:scale-95 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                <i class="fa-brands fa-whatsapp text-xs"></i> WhatsApp
              </button>
              <button onclick="window.openProspectModal('${lead.id}', 'email')" class="bg-blue-500/10 border border-blue-500/20 text-blue-400 font-space font-bold text-[10px] tracking-wider uppercase py-2.5 rounded-lg hover:bg-blue-500/20 active:scale-95 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                <i class="fa-regular fa-envelope text-xs"></i> E-mail
              </button>
              <button onclick="window.openProspectModal('${lead.id}', 'linkedin')" class="bg-sky-500/10 border border-sky-500/20 text-sky-400 font-space font-bold text-[10px] tracking-wider uppercase py-2.5 rounded-lg hover:bg-sky-500/20 active:scale-95 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                <i class="fa-brands fa-linkedin text-xs"></i> LinkedIn
              </button>
            </div>
          </div>
        `;
      }).join('');
    }

    // Render CRM Follow-Up Board
    function renderFollowUpUI() {
      if (!followUpContainer) return;

      const sliderFollowUpVal = parseInt(sliderFollowUp?.value || '3');
      const sliderArchiveVal = parseInt(sliderArchive?.value || '7');

      followUpContainer.innerHTML = activeFollowUpLeads.map(lead => {
        let borderLeftColor = '#3498db';
        if (lead.status === 'Follow up') borderLeftColor = '#f1c40f';
        else if (lead.status === 'Convertido') borderLeftColor = '#2ecc71';
        else if (lead.status === 'Reunião agendada') borderLeftColor = '#9b59b6';

        let urgencyLabel = '🟢 Recente';
        let urgencyColor = 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20';
        if (lead.diasPassados >= 10) {
          urgencyLabel = '🔴 Crítico';
          urgencyColor = 'text-red-400 bg-red-400/10 border-red-400/20';
        } else if (lead.diasPassados >= 5) {
          urgencyLabel = '🟡 Pendente';
          urgencyColor = 'text-amber-500 bg-amber-500/10 border-amber-500/20';
        }

        if (lead.status === 'Convertido') {
          urgencyLabel = '🏆 Sucesso';
          urgencyColor = 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20';
        }

        const options = ['Tentativa de contato', 'Follow up', 'Reunião agendada', 'Convertido'];
        const selectOptionsHtml = options.map(opt => `
          <option value="${opt}" ${lead.status === opt ? 'selected' : ''}>${opt}</option>
        `).join('');

        // Calculate dynamic follow-up remaining days message
        let followUpMsg = '';
        if (lead.status !== 'Convertido') {
          if (lead.diasPassados >= sliderFollowUpVal) {
            followUpMsg = `<span class="text-red-400 font-bold"><i class="fa-solid fa-bell animate-bounce"></i> Follow-Up IMEDIATO Pendente!</span>`;
          } else {
            const rem = sliderFollowUpVal - lead.diasPassados;
            followUpMsg = `<span class="text-gray-400">Próximo follow-up em <strong class="text-brandCyan">${rem} ${rem === 1 ? 'dia' : 'dias'}</strong></span>`;
          }
        } else {
          followUpMsg = `<span class="text-emerald-400 font-bold"><i class="fa-solid fa-circle-check"></i> Funil Concluído</span>`;
        }

        return `
          <div class="bg-[#161b22]/40 rounded-2xl p-4 flex flex-col gap-3 transition-all duration-300 border-l-4" style="border-left-color: ${borderLeftColor}; border-top: 1px solid rgba(255,255,255,0.03); border-right: 1px solid rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.03);">
            <div class="flex justify-between items-start">
              <div>
                <h5 class="text-xs font-bold text-white">${lead.empresa}</h5>
                <span class="text-[9px] text-[#8b949e] font-space block mt-1">
                  📡 Canal: <strong class="text-white">${lead.canal}</strong> • ${lead.diasPassados} dia(s) sem retorno
                </span>
              </div>
              <span class="text-[8px] font-space border px-2 py-0.5 rounded-full font-bold uppercase tracking-wider ${urgencyColor}">
                ${urgencyLabel}
              </span>
            </div>

            <div class="bg-[#0b0e14]/30 px-3 py-2 rounded-xl text-[9px] font-space flex justify-between items-center border border-white/[0.02]">
              ${followUpMsg}
              <span class="text-gray-500">Limite: ${sliderArchiveVal}d</span>
            </div>

            <div class="flex gap-2 items-center">
              <span class="text-[9px] text-[#8b949e] font-space uppercase tracking-wider font-semibold">Status CRM:</span>
              <select onchange="window.updateFollowUpStatus('${lead.id}', this.value)" class="flex-1 bg-[#0b0e14] border border-white/5 rounded-lg px-2 py-1 text-[10px] text-white outline-none focus:border-brandCyan/50 font-sora cursor-pointer">
                ${selectOptionsHtml}
              </select>
            </div>
          </div>
        `;
      }).join('');
    }

    // Metric calculation
    function recalculateMetrics() {
      const totalLeads = activeQueueLeads.length + activeFollowUpLeads.length;
      const contactedLeads = activeFollowUpLeads.length;
      
      const respondedCount = activeFollowUpLeads.filter(l => l.status !== 'Tentativa de contato').length;
      const responseRate = contactedLeads > 0 ? (respondedCount / contactedLeads * 100).toFixed(1) : '0.0';
      
      const meetingsCount = activeFollowUpLeads.filter(l => l.status === 'Reunião agendada').length;
      
      const convertedCount = activeFollowUpLeads.filter(l => l.status === 'Convertido').length;
      const totalLtv = convertedCount * EXCHANGE_LTV_RATE;

      // Update UI
      const elTotal = document.getElementById('dash-total');
      const elContacted = document.getElementById('dash-contacted');
      const elResponse = document.getElementById('dash-response');
      const elMeetings = document.getElementById('dash-meetings');
      const elLtv = document.getElementById('dash-ltv');

      if (elTotal) elTotal.innerText = totalLeads.toString();
      if (elContacted) elContacted.innerText = contactedLeads.toString();
      if (elResponse) elResponse.innerText = `${responseRate}%`;
      if (elMeetings) elMeetings.innerText = meetingsCount.toString();
      
      if (elLtv) {
        const formatLtv = totalLtv.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        elLtv.innerText = formatLtv;
      }
    }

    // Confetti Engine
    const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
    const ctx = canvas ? canvas.getContext('2d') : null;
    let confettiArray = [];
    let isConfettiActive = false;

    function triggerConfettiCelebration() {
      if (!canvas || !ctx) return;
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      
      confettiArray = [];
      for (let i = 0; i < 80; i++) {
        confettiArray.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height - canvas.height,
          r: Math.random() * 6 + 4,
          d: Math.random() * canvas.height,
          color: `hsl(${Math.random() * 360}, 80%, 60%)`,
          tilt: Math.random() * 10 - 5,
          tiltAngleIncremental: Math.random() * 0.07 + 0.02,
          tiltAngle: 0
        });
      }
      
      if (!isConfettiActive) {
        isConfettiActive = true;
        drawConfetti();
      }
    }

    function drawConfetti() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      let remaining = false;
      confettiArray.forEach(p => {
        p.tiltAngle += p.tiltAngleIncremental;
        p.y += (Math.cos(p.d) + 3 + p.r / 2) / 2;
        p.x += Math.sin(p.tiltAngle);
        p.tilt = Math.sin(p.tiltAngle - p.r/2) * 15;
        
        ctx.beginPath();
        ctx.lineWidth = p.r;
        ctx.strokeStyle = p.color;
        ctx.moveTo(p.x + p.tilt + p.r/2, p.y);
        ctx.lineTo(p.x + p.tilt, p.y + p.tilt + p.r/2);
        ctx.stroke();

        if (p.y < canvas.height) {
          remaining = true;
        }
      });

      if (remaining) {
        requestAnimationFrame(drawConfetti);
      } else {
        isConfettiActive = false;
      }
    }

    // Success Notification Toast
    function showNotification(text) {
      const toast = document.createElement('div');
      toast.className = "fixed bottom-8 right-8 z-50 bg-[#161b22] border-2 border-emerald-500/40 text-emerald-400 px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-3 animate-fade-in-up font-bold text-sm leading-relaxed";
      toast.innerHTML = `<i class="fa-solid fa-trophy text-lg text-amber-500 animate-bounce"></i> ${text}`;
      document.body.appendChild(toast);
      
      try {
        const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.frequency.setValueAtTime(880, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.35);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.35);
      } catch (e) {}

      setTimeout(() => {
        toast.classList.add('opacity-0', 'scale-95');
        setTimeout(() => toast.remove(), 400);
      }, 4000);
    }

    // Initial Renders
    renderQueueUI();
    renderFollowUpUI();
    recalculateMetrics();
  }

  document.addEventListener('astro:page-load', initNxtOsSimulation);
</script>

