---
// src/components/NxtOsSandbox.astro
---

<div class="w-full flex flex-col font-sora mt-4 opacity-0 animate-fade-in-up [animation-delay:200ms]">
  
  <!-- Painel de Métricas e KPIs (Resumo) - Sem Caixas Pesadas, Ultra Clean -->
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-8 mb-12 border-b border-white/[0.03] pb-8">
    <div>
      <span class="text-[10px] text-textSecondary font-semibold uppercase tracking-wider font-space">Total de Leads</span>
      <div class="text-3xl font-bold text-textPrimary mt-1" id="dash-total">6</div>
    </div>
    <div>
      <span class="text-[10px] text-textSecondary font-semibold uppercase tracking-wider font-space">Contatados</span>
      <div class="text-3xl font-bold text-textPrimary mt-1" id="dash-contacted">3</div>
    </div>
    <div>
      <span class="text-[10px] text-textSecondary font-semibold uppercase tracking-wider font-space">Taxa de Resposta</span>
      <div class="text-3xl font-bold text-textPrimary mt-1" id="dash-response">50.0%</div>
    </div>
    <div>
      <span class="text-[10px] text-textSecondary font-semibold uppercase tracking-wider font-space">Reuniões</span>
      <div class="text-3xl font-bold text-textPrimary mt-1" id="dash-meetings">1</div>
    </div>
    <div class="col-span-2 lg:col-span-1">
      <span class="text-[10px] text-textSecondary font-semibold uppercase tracking-wider font-space">Vendas Convertidas</span>
      <div class="text-3xl font-bold text-textPrimary mt-1" id="dash-ltv">R$ 5.000,00</div>
    </div>
  </div>

  <!-- Layout de Duas Colunas -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    
    <!-- Coluna da Esquerda: Fila de Prospecção B2B (O Problema & A Ação) -->
    <div class="lg:col-span-7 flex flex-col gap-6 bg-surface border border-brandCyan/5 p-8 rounded-3xl">
      <div class="flex items-center justify-between border-b border-brandCyan/5 pb-4">
        <div>
          <h3 class="text-base font-bold text-textPrimary">🎯 Fila de Prospecção B2B</h3>
          <p class="text-xs text-textSecondary mt-0.5">Abordagens que geram oportunidades automáticas.</p>
        </div>
      </div>

      <!-- Fila de Leads Ativa (Aguardando Envio) -->
      <div class="flex flex-col gap-4" id="leads-queue-container">
        <!-- Renders leads here dynamically -->
      </div>

      <!-- Ação Principal (O Único Clique) -->
      <div class="flex gap-3 items-stretch mt-2">
        <button id="btn-run-automation" class="flex-1 bg-[#00f2fe] text-[#0b0e14] font-space font-extrabold text-xs tracking-widest uppercase py-4.5 px-6 rounded-xl hover:bg-white hover:text-[#0b0e14] transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer shadow-lg shadow-[#00f2fe]/10 active:scale-98">
          <i class="fa-solid fa-play text-[9px]"></i> Disparar Abordagens Automáticas
        </button>
        
        <button id="btn-reset-leads" class="bg-darkBg border border-brandCyan/10 text-textSecondary hover:text-textPrimary px-5 rounded-xl hover:bg-darkBg/80 transition-all flex items-center justify-center cursor-pointer" title="Reiniciar Simulação">
          <i class="fa-solid fa-arrows-rotate text-xs"></i>
        </button>
      </div>

      <!-- Monitor de Atividades (Antes Console NXT OS) - Oculto até o Clique -->
      <div id="automation-console-box" class="bg-darkBg/60 border border-brandCyan/5 rounded-2xl p-4 font-mono text-[10px] text-textPrimary leading-relaxed hidden">
        <div class="flex items-center justify-between border-b border-white/5 pb-2 mb-2">
          <span class="text-textSecondary font-space uppercase tracking-wider font-bold text-[9px]">🖥️ Monitor de Atividades</span>
          <span class="w-1.5 h-1.5 rounded-full bg-[#00f2fe] animate-pulse"></span>
        </div>
        <div id="automation-console-logs" class="flex flex-col gap-1 pr-1 max-h-[110px] overflow-y-auto scrollbar-thin">
          <!-- Logs will stream here dynamically -->
        </div>
      </div>

      <!-- Configurações Avançadas e Customização (Colapsado por Padrão) -->
      <details class="group border-t border-white/[0.03] pt-4 mt-2">
        <summary class="flex justify-between items-center text-xs text-textSecondary font-medium cursor-pointer hover:text-textPrimary transition-all list-none select-none">
          <span class="flex items-center gap-2">
            <i class="fa-solid fa-sliders text-[10px]"></i> Ajustar Estratégias & Templates
          </span>
          <i class="fa-solid fa-chevron-down text-[9px] group-open:rotate-180 transition-transform"></i>
        </summary>
        
        <div class="mt-6 flex flex-col gap-6 animate-fade-in-up duration-300">
          
          <!-- Estratégias de Disparo -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <label class="text-xs text-textSecondary font-medium">Estratégia de Contato</label>
              <select id="automation-strategy" class="bg-darkBg border border-white/5 rounded-xl px-3 py-2.5 text-xs text-textPrimary outline-none focus:border-brandCyan/40 font-sora cursor-pointer w-full">
                <option value="priority-whatsapp" selected>Prioridade WhatsApp (Smart Fallback)</option>
                <option value="priority-email">Prioridade E-mail (Smart Fallback)</option>
                <option value="simultaneous">WhatsApp & E-mail Simultâneo</option>
              </select>
            </div>

            <div class="flex flex-col gap-2">
              <label class="text-xs text-textSecondary font-medium">Agendar Envios Para</label>
              <div class="flex items-center gap-2">
                <input type="time" id="scheduler-start" class="bg-darkBg border border-white/5 rounded-xl px-3 py-2 text-xs text-textPrimary outline-none focus:border-brandCyan/40 font-sora cursor-pointer w-full text-center" value="08:00" />
                <span class="text-xs text-textSecondary font-bold">—</span>
                <input type="time" id="scheduler-end" class="bg-darkBg border border-white/5 rounded-xl px-3 py-2 text-xs text-textPrimary outline-none focus:border-brandCyan/40 font-sora cursor-pointer w-full text-center" value="17:00" />
              </div>
            </div>
          </div>

          <!-- Sliders de dias para CRM -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-white/[0.03] pt-5">
            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-center text-xs text-textSecondary">
                <span>Intervalo Follow Up</span>
                <span id="label-val-followup" class="text-textPrimary font-bold">3 dias</span>
              </div>
              <input type="range" id="slider-followup" min="1" max="10" value="3" class="w-full h-1 bg-darkBg rounded-lg appearance-none cursor-pointer accent-[#1c69b7]" />
            </div>

            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-center text-xs text-textSecondary">
                <span>Arquivar sem resposta após</span>
                <span id="label-val-archive" class="text-textSecondary font-bold">7 dias</span>
              </div>
              <input type="range" id="slider-archive" min="3" max="15" value="7" class="w-full h-1 bg-darkBg rounded-lg appearance-none cursor-pointer accent-[#8b949e]" />
            </div>
          </div>

          <!-- Customizador de Scripts -->
          <div class="flex flex-col gap-3 border-t border-white/[0.03] pt-5">
            <span class="text-xs font-semibold text-textPrimary">Customizar Script Padrão</span>
            
            <div class="flex gap-1.5">
              <button class="script-tab-btn active text-[10px] font-semibold px-3 py-1.5 rounded-lg transition-all" data-channel="whatsapp">
                WhatsApp
              </button>
              <button class="script-tab-btn text-[10px] font-semibold px-3 py-1.5 rounded-lg transition-all" data-channel="email">
                E-mail
              </button>
              <button class="script-tab-btn text-[10px] font-semibold px-3 py-1.5 rounded-lg transition-all" data-channel="linkedin">
                LinkedIn
              </button>
            </div>

            <!-- Inputs de Script -->
            <div class="space-y-3">
              <textarea id="script-input-whatsapp" class="w-full bg-darkBg border border-white/5 rounded-xl p-3 text-xs text-textPrimary focus:border-brandCyan/40 outline-none leading-relaxed custom-textarea font-sora" rows="5">Olá! Estava a analisar o posicionamento digital da [Empresa] e detetei uma falha oculta que prejudica diretamente a conversão de novos clientes: [Diagnóstico].

Como arquiteto de sistemas, montei um ajuste rápido que elimina essa fricção e blinda o faturamento de vocês. Teria 3 minutos para ver como resolver isso de forma simples nesta semana?</textarea>
              <textarea id="script-input-email" class="w-full bg-darkBg border border-white/5 rounded-xl p-3 text-xs text-textPrimary focus:border-brandCyan/40 outline-none leading-relaxed hidden custom-textarea font-sora" rows="8">Assunto: Otimização pendente no ecossistema digital da [Empresa]

Olá, tudo bem?

Ao estudar a infraestrutura digital da [Empresa], identifiquei uma oportunidade de melhoria que impacta diretamente a retenção dos vossos utilizadores e a entrada de novas vendas: [Diagnóstico].

Desenvolvi uma solução em lote focada exatamente em eliminar esse tipo de gargalo operacional, garantindo estabilidade e eficiência para o negócio.

Se fizer sentido para o momento atual da [Empresa], posso enviar um breve resumo de como aplicar essa correção. Qual o melhor dia para conversarmos esta semana?

Atenciosamente,
Nathan Borges</textarea>
              <textarea id="script-input-linkedin" class="w-full bg-darkBg border border-white/5 rounded-xl p-3 text-xs text-textPrimary focus:border-brandCyan/40 outline-none leading-relaxed hidden custom-textarea font-sora" rows="5">Olá! Acompanho o crescimento da [Empresa] no mercado e decidi fazer uma análise da usabilidade técnica do vosso produto. 

Notei um ponto de atrito na jornada que gera uma sobrecarga cognitiva desnecessária no utilizador: [Diagnóstico]. 

Corrigir essa brecha costuma destravar os resultados de faturamento e melhorar a experiência de forma imediata. Se tiver interesse em ver como redesenhamos esse fluxo sem impactar a vossa operação atual, fico à disposição para enviar os detalhes. Um abraço!</textarea>
            </div>
          </div>
          
        </div>
      </details>

    </div>

    <!-- Coluna da Direita: Central CRM (A Solução) -->
    <div class="lg:col-span-5 flex flex-col gap-6 bg-surface border border-brandCyan/5 p-8 rounded-3xl">
      <div class="flex items-center justify-between border-b border-brandCyan/5 pb-4">
        <div>
          <h3 class="text-base font-bold text-textPrimary">🔁 Esteira de Follow Up</h3>
          <p class="text-xs text-textSecondary mt-0.5">Sincronização ativa via Notion API.</p>
        </div>
      </div>

      <!-- Lista de Follow-Up -->
      <div class="flex-1 flex flex-col gap-4 overflow-y-auto max-h-[850px] pr-1 scrollbar-thin" id="follow-up-container">
        <!-- Renders follow up cards here dynamically -->
      </div>
      
      <div class="text-[9px] text-textSecondary pt-3 border-t border-white/[0.03] flex justify-between font-space font-semibold uppercase tracking-wider">
        <span>notion_crm_sync</span>
        <span>gemini_flash_2.0</span>
      </div>
    </div>

  </div>

  <!-- Popup Modal de Visualização de Script -->
  <div id="script-preview-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-darkBg/90 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500">
    <div class="bg-surface border border-white/5 rounded-3xl p-6 max-w-lg w-full shadow-2xl transform scale-95 transition-all duration-500 flex flex-col gap-5" id="script-preview-modal-content">
      <div class="flex items-start justify-between">
        <div>
          <span class="font-space text-[10px] text-textSecondary uppercase tracking-widest font-semibold" id="modal-top-label">ABORDAGEM PRONTAMENTE GERADA</span>
          <h4 class="text-lg font-bold text-textPrimary mt-1 tracking-tight" id="modal-lead-title">Script para Somos6digital</h4>
        </div>
        <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-textPrimary text-sm">
          <i class="fa-solid fa-wand-magic-sparkles text-[10px]"></i>
        </div>
      </div>

      <!-- Bloco de Código / Mensagem Final -->
      <div class="bg-darkBg border border-white/5 p-4 rounded-2xl relative">
        <pre class="text-xs text-gray-300 leading-relaxed font-sans whitespace-pre-wrap select-all pr-12 font-sora" id="modal-script-text"></pre>
        <button id="btn-copy-modal" class="absolute top-4 right-4 w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white transition-all active:scale-95 cursor-pointer">
          <i class="fa-solid fa-copy text-xs"></i>
        </button>
      </div>

      <!-- Popover de Registro de Canal -->
      <div class="bg-darkBg border border-white/5 p-4 rounded-2xl flex flex-col gap-3">
        <div>
          <span class="text-xs font-bold text-textPrimary font-space">Confirmar Envio e Registrar Canal</span>
          <p class="text-[10px] text-textSecondary mt-1">O lead é automaticamente atualizado no Notion CRM e movido para a esteira de acompanhamento.</p>
        </div>
        
        <div class="flex gap-2">
          <select id="modal-select-channel" class="flex-1 bg-darkBg border border-white/5 rounded-xl px-3 py-2.5 text-xs text-textPrimary outline-none focus:border-brandCyan/40 font-sora cursor-pointer">
            <option value="WhatsApp">WhatsApp</option>
            <option value="E-mail">E-mail</option>
            <option value="LinkedIn">LinkedIn</option>
          </select>
          <button id="btn-save-modal" class="bg-[#00f2fe] text-[#0b0e14] font-space font-extrabold text-xs tracking-widest uppercase py-3 px-6 rounded-xl hover:bg-white hover:text-[#0b0e14] transition-all duration-300 cursor-pointer">
            Registrar e Mover CRM
          </button>
        </div>
      </div>

      <button id="btn-close-modal" class="w-full bg-white/5 text-gray-400 hover:text-white font-space font-semibold text-xs tracking-wider uppercase py-3.5 px-4 rounded-xl transition-all duration-300 border border-white/5 cursor-pointer">
        Cancelar e Voltar
      </button>
    </div>
  </div>

  <!-- Popup Modal de Conclusão da Simulação (CRM Sincronizado) -->
  <div id="crm-completion-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-darkBg/90 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500">
    <div class="bg-surface border border-white/5 rounded-3xl p-8 max-w-2xl w-full shadow-2xl transform scale-95 transition-all duration-500 flex flex-col gap-6" id="crm-completion-modal-content">
      
      <!-- Cabeçalho -->
      <div class="flex items-start justify-between border-b border-white/5 pb-4">
        <div>
          <span class="font-space text-[10px] text-textSecondary uppercase tracking-widest font-semibold">Engenharia Comercial</span>
          <h4 class="text-xl font-bold text-textPrimary mt-1 tracking-tight">Abordagens Despachadas e CRM Sincronizado!</h4>
        </div>
        <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-textPrimary text-sm">
          <i class="fa-solid fa-circle-check text-[11px] text-[#00f2fe] animate-pulse"></i>
        </div>
      </div>

      <!-- Texto Principal -->
      <div class="bg-darkBg/40 border-l-2 border-[#00f2fe] p-4 rounded-r-xl">
        <p class="text-xs text-textSecondary leading-relaxed italic">
          Você acaba de simular o ciclo completo de prospecção inteligente. O sistema utiliza Inteligência Artificial para analisar o site de cada potencial cliente, gera uma abordagem 100% personalizada com base nas brechas encontradas e agenda os próximos pontos de contato sem que você precise preencher nenhuma linha manualmente.
        </p>
      </div>

      <!-- Bloco Comparativo de Impacto (ROI) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Card 1: Processo Manual Antigo -->
        <div class="bg-darkBg/30 border border-white/5 rounded-2xl p-5 flex flex-col justify-between gap-3">
          <div>
            <span class="text-[9px] font-space text-textSecondary font-bold uppercase tracking-wider">Processo Manual Antigo</span>
            <h5 class="text-2xl font-bold text-textSecondary mt-1">12 horas</h5>
          </div>
          <p class="text-[11px] text-textSecondary leading-relaxed">
            Tempo gasto para redigir mensagens uma a uma, com falhas constantes em datas de retorno e status perdidos em planilhas.
          </p>
        </div>

        <!-- Card 2: Ecossistema Moskato -->
        <div class="bg-darkBg/50 border border-white/10 rounded-2xl p-5 flex flex-col justify-between gap-3">
          <div>
            <span class="text-[9px] font-space text-textPrimary font-bold uppercase tracking-wider">Ecossistema Moskato</span>
            <h5 class="text-2xl font-bold text-textPrimary mt-1">Em lote</h5>
          </div>
          <p class="text-[11px] text-textSecondary leading-relaxed">
            Envio em massa totalmente personalizado via API. O algoritmo gerencia os prazos e move a esteira sozinho.
          </p>
        </div>
      </div>

      <!-- Texto de Encerramento -->
      <p class="text-[11px] text-textSecondary leading-relaxed">
        Ao centralizar a operação, o sistema elimina os três maiores gargalos de um time de vendas: esquecer de cobrar o cliente (follow-up), errar a data de retorno e atualizar o status manualmente. O pipeline roda de forma autônoma nos bastidores, garantindo que nenhuma negociação esfrie por falha humana.
      </p>

      <!-- Botão de Fechar -->
      <button id="btn-close-completion" class="w-full bg-[#00f2fe] text-[#0b0e14] font-space font-extrabold text-xs tracking-widest uppercase py-4 px-4 rounded-xl hover:bg-white hover:text-[#0b0e14] transition-all duration-300 cursor-pointer text-center">
        Fechar e Ver Esteira de Vendas
      </button>
    </div>
  </div>

  <!-- Elemento de Confetes Canvas de Comemoração -->
  <canvas id="confetti-canvas" class="fixed inset-0 z-40 pointer-events-none w-full h-full"></canvas>

</div>

<script>
  const INITIAL_QUEUE = [
    {
      id: '1',
      empresa: 'Somos6digital',
      site: 'https://somos6digital.com.br',
      telefone: '5511999991111',
      email: 'contato@somos6digital.com.br',
      linkedin: 'https://linkedin.com/company/somos6digital',
      instagram: 'https://instagram.com/somos6digital',
      diagnostico: 'Ausência de Pixel do Meta no checkout, tempo de carregamento mobile de 4.8s (LCP crítico) e falta de formulário de captura rápida na home.',
      status: 'Aguardando Disparo',
      hasWhatsApp: true,
      hasEmail: true
    },
    {
      id: '2',
      empresa: 'Actwork',
      site: 'https://actwork.com.br',
      telefone: '',
      email: 'vendas@actwork.com.br',
      linkedin: 'https://linkedin.com/company/actwork',
      instagram: 'https://instagram.com/actwork',
      diagnostico: 'Formulário de contato principal quebrado (retorna erro 500 no console), sem pixel de rastreamento de anúncios e ausência de SSL ativo no subdomínio de blog.',
      status: 'Aguardando Disparo',
      hasWhatsApp: false,
      hasEmail: true
    },
    {
      id: '3',
      empresa: 'Bazooka Design',
      site: 'https://bazooka.pt',
      telefone: '',
      email: '',
      linkedin: 'https://linkedin.com/company/bazooka',
      instagram: 'https://instagram.com/bazookadesign',
      diagnostico: 'Perfil do Instagram sem link direto para o WhatsApp, velocidade de página baixa por imagens sem otimização (WebP) e falta de cabeçalho de conversão evidente.',
      status: 'Aguardando Disparo',
      hasWhatsApp: false,
      hasEmail: false
    }
  ];

  const INITIAL_FOLLOWUP = [
    {
      id: '4',
      empresa: 'Ramper B2B',
      site: 'https://ramper.com.br',
      telefone: '5511999056763',
      email: 'leads@ramper.com.br',
      linkedin: 'https://linkedin.com/company/ramper',
      instagram: 'https://instagram.com/ramper',
      diagnostico: 'Contatos duplicados na base do comercial, números desformatados e falta de follow up de leads frios.',
      status: 'Tentativa de contato',
      canal: 'WhatsApp',
      diasPassados: 4
    },
    {
      id: '5',
      empresa: 'Reev CRM',
      site: 'https://reev.co',
      telefone: '553133334444',
      email: 'contato@reev.co',
      linkedin: 'https://linkedin.com/company/reev',
      instagram: 'https://instagram.com/reev',
      diagnostico: 'Lentidão crítica de carregamento mobile e formulário quebrado de captura de leads no blog principal.',
      status: 'Follow up',
      canal: 'LinkedIn',
      diasPassados: 11
    },
    {
      id: '6',
      empresa: 'Somos6digital SP',
      site: 'https://somos6digital.com.br',
      telefone: '5511999991112',
      email: 'comercial@somos6digital.com.br',
      linkedin: '',
      instagram: '',
      diagnostico: 'Duplicado no funil físico, sem automação de follow up e perda crítica de LTV mensal.',
      status: 'Convertido',
      canal: 'E-mail',
      diasPassados: 15
    }
  ];

  let activeQueueLeads = JSON.parse(JSON.stringify(INITIAL_QUEUE));
  let activeFollowUpLeads = JSON.parse(JSON.stringify(INITIAL_FOLLOWUP));

  let currentSelectedChannel = 'whatsapp';
  let leadToProspectId = '';

  const EXCHANGE_LTV_RATE = 5000.00;

  function initNxtOsSimulation() {
    const queueContainer = document.getElementById('leads-queue-container');
    const followUpContainer = document.getElementById('follow-up-container');
    
    // Sliders
    const sliderFollowUp = document.getElementById('slider-followup') as HTMLInputElement;
    const sliderArchive = document.getElementById('slider-archive') as HTMLInputElement;
    const labelFollowUp = document.getElementById('label-val-followup');
    const labelArchive = document.getElementById('label-val-archive');
    const selectStrategy = document.getElementById('automation-strategy') as HTMLSelectElement;

    // Advanced Automation Elements
    const btnRunAutomation = document.getElementById('btn-run-automation');
    const btnResetLeads = document.getElementById('btn-reset-leads');
    const consoleBox = document.getElementById('automation-console-box');
    const consoleLogs = document.getElementById('automation-console-logs');

    // Scheduler inputs
    const schedulerStart = document.getElementById('scheduler-start') as HTMLInputElement;
    const schedulerEnd = document.getElementById('scheduler-end') as HTMLInputElement;

    // Script Customization Tabs
    const scriptTabBtns = document.querySelectorAll('.script-tab-btn');
    const textareaWa = document.getElementById('script-input-whatsapp') as HTMLTextAreaElement;
    const textareaEmail = document.getElementById('script-input-email') as HTMLTextAreaElement;
    const textareaLinkedin = document.getElementById('script-input-linkedin') as HTMLTextAreaElement;
    
    // Script Preview Modal Elements
    const previewModal = document.getElementById('script-preview-modal');
    const previewModalContent = document.getElementById('script-preview-modal-content');
    const modalLeadTitle = document.getElementById('modal-lead-title');
    const modalScriptText = document.getElementById('modal-script-text');
    const modalSelectChannel = document.getElementById('modal-select-channel') as HTMLSelectElement;
    
    const btnCloseModal = document.getElementById('btn-close-modal');
    const btnCopyModal = document.getElementById('btn-copy-modal');
    const btnSaveModal = document.getElementById('btn-save-modal');

    // CRM Completion Modal Elements
    const completionModal = document.getElementById('crm-completion-modal');
    const completionModalContent = document.getElementById('crm-completion-modal-content');
    const btnCloseCompletion = document.getElementById('btn-close-completion');

    // Re-render leads when strategy changes
    selectStrategy?.addEventListener('change', () => {
      renderQueueUI();
    });

    // Close CRM Completion Modal
    btnCloseCompletion?.addEventListener('click', () => {
      if (completionModal && completionModalContent) {
        completionModal.classList.add('opacity-0', 'pointer-events-none');
        completionModalContent.classList.remove('scale-100');
        completionModalContent.classList.add('scale-95');
      }
    });

    // Slider Listeners
    sliderFollowUp?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      if (labelFollowUp) labelFollowUp.innerText = `${val} ${val === '1' ? 'dia' : 'dias'}`;
      renderFollowUpUI();
    });

    sliderArchive?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      if (labelArchive) labelArchive.innerText = `${val} ${val === '1' ? 'dia' : 'dias'}`;
      applyAutoArchiveRule(parseInt(val));
    });

    function applyAutoArchiveRule(archiveLimit) {
      const toArchive = activeFollowUpLeads.filter(l => l.status !== 'Convertido' && l.diasPassados >= archiveLimit);
      
      if (toArchive.length > 0) {
        toArchive.forEach(lead => {
          showNotification(`🗄️ Lead ${lead.empresa} arquivado automaticamente`);
          addConsoleLog(`[CRM] Lead "${lead.empresa}" sem resposta há ${lead.diasPassados} dias. Movido automaticamente para status: ARQUIVADO.`, 'error');
        });

        activeFollowUpLeads = activeFollowUpLeads.filter(l => !(l.status !== 'Convertido' && l.diasPassados >= archiveLimit));
        
        recalculateMetrics();
        renderFollowUpUI();
      }
    }

    function addConsoleLog(text, type = 'info') {
      if (!consoleLogs || !consoleBox) return;
      consoleBox.classList.remove('hidden');
      
      const time = new Date().toLocaleTimeString('pt-BR');
      let colorClass = 'text-textPrimary';
      if (type === 'error') colorClass = 'text-white/40';
      else if (type === 'warn') colorClass = 'text-textSecondary';
      else if (type === 'success') colorClass = 'text-[#00f2fe] font-bold';

      const logElement = document.createElement('div');
      logElement.className = `leading-relaxed animate-fade-in-up font-mono ${colorClass}`;
      logElement.innerHTML = `[${time}] ${text}`;
      consoleLogs.appendChild(logElement);
      
      consoleLogs.scrollTop = consoleLogs.scrollHeight;
    }

    // Interactive Bulk Scheduler Run
    btnRunAutomation?.addEventListener('click', () => {
      if (activeQueueLeads.length === 0) {
        showNotification("⚠️ A fila de leads ativos já está vazia!");
        return;
      }

      const startVal = schedulerStart.value;
      const endVal = schedulerEnd.value;
      const strategyVal = selectStrategy.value;

      btnRunAutomation.setAttribute('disabled', 'true');
      btnRunAutomation.classList.add('opacity-50', 'pointer-events-none');

      if (consoleLogs) consoleLogs.innerHTML = '';
      addConsoleLog(`🕒 Configurando robô de disparos restrito à janela: das ${startVal} às ${endVal}...`, 'warn');
      addConsoleLog(`⏱️ Validando fuso horário e conformidade comercial (Evitando SPAM)...`, 'warn');

      setTimeout(() => {
        addConsoleLog(`✅ Hora comercial validada dentro da janela programada (${startVal} - ${endVal}). Iniciando disparos...`, 'success');
        
        let delay = 600;
        const leadsToProcess = [...activeQueueLeads];
        
        leadsToProcess.forEach((lead, index) => {
          const routing = calculateChannelRouting(lead, strategyVal);
          
          setTimeout(() => {
            addConsoleLog(`🔍 Analisando lead "${lead.empresa}" (${lead.site})...`);
          }, delay);
          delay += 600;

          setTimeout(() => {
            if (strategyVal === 'priority-whatsapp') {
              addConsoleLog(`📡 Evolution API: Verificando presença de WhatsApp no número...`);
              if (lead.hasWhatsApp) {
                addConsoleLog(`✅ WhatsApp ativo! Canal eleito: WhatsApp.`, 'info');
              } else {
                addConsoleLog(`⚠️ WhatsApp indisponível. Aplicando Fallback de 1º nível...`, 'warn');
                if (lead.hasEmail) {
                  addConsoleLog(`📧 E-mail ativo! Canal eleito: E-mail.`, 'info');
                } else {
                  addConsoleLog(`⚠️ E-mail também indisponível. Aplicando Fallback de 2º nível...`, 'warn');
                  addConsoleLog(`📸 Perfil de Instagram detectado! Canal eleito: Direct Instagram.`, 'info');
                }
              }
            } else if (strategyVal === 'priority-email') {
              addConsoleLog(`📡 SMTP Check: Verificando integridade da conta de E-mail...`);
              if (lead.hasEmail) {
                addConsoleLog(`✅ E-mail verificado! Canal eleito: E-mail.`, 'info');
              } else {
                addConsoleLog(`⚠️ E-mail indisponível. Aplicando Fallback de 1º nível...`, 'warn');
                if (lead.hasWhatsApp) {
                  addConsoleLog(`📲 WhatsApp ativo! Canal eleito: WhatsApp.`, 'info');
                } else {
                  addConsoleLog(`⚠️ WhatsApp também indisponível. Aplicando Fallback de 2º nível...`, 'warn');
                  addConsoleLog(`📸 Perfil de Instagram detectado! Canal eleito: Direct Instagram.`, 'info');
                }
              }
            } else {
              addConsoleLog(`⚡ Modo Simultâneo: Disparando cópias idênticas para todos os canais cadastrados...`);
            }
          }, delay);
          delay += 700;

          setTimeout(() => {
            addConsoleLog(`🧠 IA: Aplicando prompt no Gemini 2.0 Flash... [Sucesso]`);
            addConsoleLog(`📤 Enviando abordagem personalizada para "${lead.empresa}" via ${routing.channelName}.`, 'success');
          }, delay);
          delay += 800;

          setTimeout(() => {
            const qIndex = activeQueueLeads.findIndex(l => l.id === lead.id);
            if (qIndex !== -1) {
              activeQueueLeads.splice(qIndex, 1);
            }
            
            activeFollowUpLeads.unshift({
              ...lead,
              status: 'Tentativa de contato',
              canal: routing.channelName,
              diasPassados: 0
            });
            
            const cardEl = document.getElementById(`queue-card-${lead.id}`);
            if (cardEl) {
              cardEl.classList.add('opacity-0', 'scale-95', 'translate-x-4');
            }

            renderQueueUI();
            renderFollowUpUI();
            recalculateMetrics();
          }, delay);
          delay += 200;
        });

        setTimeout(() => {
          addConsoleLog("💾 Notion API: Sincronizando dados de prospecção e atualizando tags de funil...", 'warn');
        }, delay);
        delay += 600;

        setTimeout(() => {
          addConsoleLog("🏆 Execução em Lote Finalizada com 100% de Confiabilidade!", 'success');
          showNotification("🚀 Disparo de Abordagens Concluído!");
          
          btnRunAutomation.removeAttribute('disabled');
          btnRunAutomation.classList.remove('opacity-50', 'pointer-events-none');

          // Trigger the completion modal
          if (completionModal && completionModalContent) {
            setTimeout(() => {
              completionModal.classList.remove('opacity-0', 'pointer-events-none');
              completionModalContent.classList.remove('scale-95');
              completionModalContent.classList.add('scale-100');
              triggerConfettiCelebration(); // Explode confetti on success!
            }, 600);
          }
        }, delay);

      }, 2000);
    });

    btnResetLeads?.addEventListener('click', () => {
      activeQueueLeads = JSON.parse(JSON.stringify(INITIAL_QUEUE));
      activeFollowUpLeads = JSON.parse(JSON.stringify(INITIAL_FOLLOWUP));
      
      if (consoleBox) consoleBox.classList.add('hidden');
      if (consoleLogs) consoleLogs.innerHTML = '';
      
      renderQueueUI();
      renderFollowUpUI();
      recalculateMetrics();
      showNotification("🔄 Simulação Reiniciada!");
    });

    // Tab Logic for customizer
    scriptTabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        scriptTabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const channel = btn.getAttribute('data-channel');
        currentSelectedChannel = channel;
        
        textareaWa.classList.add('hidden');
        textareaEmail.classList.add('hidden');
        textareaLinkedin.classList.add('hidden');
        
        if (channel === 'whatsapp') textareaWa.classList.remove('hidden');
        else if (channel === 'email') textareaEmail.classList.remove('hidden');
        else if (channel === 'linkedin') textareaLinkedin.classList.remove('hidden');
      });
    });

    // Calculate contact strategies
    function calculateChannelRouting(lead, strategy) {
      if (strategy === 'priority-whatsapp') {
        if (lead.hasWhatsApp) return { channelName: 'WhatsApp', badge: 'WhatsApp', color: 'text-textPrimary bg-white/5 border border-white/10' };
        if (lead.hasEmail) return { channelName: 'E-mail', badge: 'E-mail (Fallback)', color: 'text-textPrimary bg-white/5 border border-white/10' };
        return { channelName: 'Instagram', badge: 'Instagram (Fallback)', color: 'text-textSecondary bg-transparent border border-white/5' };
      } else if (strategy === 'priority-email') {
        if (lead.hasEmail) return { channelName: 'E-mail', badge: 'E-mail', color: 'text-textPrimary bg-white/5 border border-white/10' };
        if (lead.hasWhatsApp) return { channelName: 'WhatsApp', badge: 'WhatsApp (Fallback)', color: 'text-textPrimary bg-white/5 border border-white/10' };
        return { channelName: 'Instagram', badge: 'Instagram (Fallback)', color: 'text-textSecondary bg-transparent border border-white/5' };
      } else {
        if (lead.hasWhatsApp && lead.hasEmail) return { channelName: 'WA & E-mail', badge: 'WA + E-mail', color: 'text-textPrimary bg-white/10 border border-white/20' };
        if (lead.hasWhatsApp) return { channelName: 'WhatsApp', badge: 'WhatsApp', color: 'text-textPrimary bg-white/5 border border-white/10' };
        if (lead.hasEmail) return { channelName: 'E-mail', badge: 'E-mail', color: 'text-textPrimary bg-white/5 border border-white/10' };
        return { channelName: 'Instagram', badge: 'Instagram', color: 'text-textSecondary bg-transparent border border-white/5' };
      }
    }

    // Generate calculated script based on selected channel and templates
    function getPersonalizedScript(lead, channel) {
      let baseText = '';
      if (channel === 'whatsapp') baseText = textareaWa.value;
      else if (channel === 'email') baseText = textareaEmail.value;
      else baseText = textareaLinkedin.value;

      return baseText
        .replace(/\[Empresa\]/g, lead.empresa)
        .replace(/\[Diagnóstico\]/g, lead.diagnostico);
    }

    // Modal Copy logic
    btnCopyModal?.addEventListener('click', () => {
      if (modalScriptText) {
        navigator.clipboard.writeText(modalScriptText.innerText);
        const icon = btnCopyModal.querySelector('i');
        if (icon) {
          icon.className = "fa-solid fa-check text-[#00f2fe]";
          setTimeout(() => {
            icon.className = "fa-solid fa-copy text-xs";
          }, 1500);
        }
      }
    });

    // Close Modal
    btnCloseModal?.addEventListener('click', () => {
      if (previewModal && previewModalContent) {
        previewModal.classList.add('opacity-0', 'pointer-events-none');
        previewModalContent.classList.remove('scale-100');
        previewModalContent.classList.add('scale-95');
      }
    });

    // Save and register prospect
    btnSaveModal?.addEventListener('click', () => {
      const selectedChannel = modalSelectChannel.value;
      
      const leadIndex = activeQueueLeads.findIndex(l => l.id === leadToProspectId);
      if (leadIndex !== -1) {
        const lead = activeQueueLeads[leadIndex];
        
        activeQueueLeads.splice(leadIndex, 1);
        
        activeFollowUpLeads.unshift({
          ...lead,
          status: 'Tentativa de contato',
          canal: selectedChannel,
          diasPassados: 0
        });

        const cardElement = document.getElementById(`queue-card-${leadToProspectId}`);
        if (cardElement) {
          cardElement.classList.add('opacity-0', 'scale-95', 'translate-x-4');
          setTimeout(() => {
            renderQueueUI();
            renderFollowUpUI();
            recalculateMetrics();
          }, 400);
        }
      }

      if (previewModal && previewModalContent) {
        previewModal.classList.add('opacity-0', 'pointer-events-none');
        previewModalContent.classList.remove('scale-100');
        previewModalContent.classList.add('scale-95');
      }
    });

    window.openProspectModal = function(leadId, channelType) {
      leadToProspectId = leadId;
      const lead = activeQueueLeads.find(l => l.id === leadId);
      if (lead) {
        if (modalLeadTitle && modalScriptText && previewModal && previewModalContent && modalSelectChannel) {
          modalLeadTitle.innerText = `Script de abordagem para ${lead.empresa}`;
          modalScriptText.innerText = getPersonalizedScript(lead, channelType);
          
          if (channelType === 'whatsapp') modalSelectChannel.value = 'WhatsApp';
          else if (channelType === 'email') modalSelectChannel.value = 'E-mail';
          else modalSelectChannel.value = 'LinkedIn';
          
          previewModal.classList.remove('opacity-0', 'pointer-events-none');
          previewModalContent.classList.remove('scale-95');
          previewModalContent.classList.add('scale-100');
        }
      }
    };

    window.updateFollowUpStatus = function(leadId, newStatus) {
      const lead = activeFollowUpLeads.find(l => l.id === leadId);
      if (lead) {
        lead.status = newStatus;
        
        if (newStatus === 'Convertido') {
          triggerConfettiCelebration();
          showNotification(`🚀 Contrato Fechado com ${lead.empresa}!`);
          addConsoleLog(`🏆 CONTRATO FECHADO: Lead "${lead.empresa}" converteu! LTV conciliado no Notion CRM.`, 'success');
        }

        recalculateMetrics();
        renderFollowUpUI();
      }
    };

