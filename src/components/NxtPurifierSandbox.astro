---
// Componente Interativo: Sandbox de Purificação e Automação de Dados
---

<div class="md:col-span-3 grid grid-cols-1 md:grid-cols-[1fr_0.8fr] gap-6 bg-[#161b22] rounded-[32px] border border-white/5 p-6 md:p-8 font-sora mt-2 shadow-2xl">
  
  <!-- Coluna Esquerda: Painel Operacional -->
  <div class="flex flex-col gap-6">
    <div class="flex items-center justify-between">
      <h3 class="text-textPrimary font-bold text-lg md:text-xl">Pipeline de Dados B2B</h3>
      <span id="pipeline-status" class="px-3 py-1 bg-surface border border-white/10 rounded-full text-[10px] uppercase tracking-widest text-textSecondary transition-colors duration-300">Aguardando...</span>
    </div>

    <!-- Base Simulada (Dados Sujos) -->
    <div class="flex flex-col gap-3 font-space text-sm">
      <div id="lead-1" class="p-4 bg-darkBg rounded-xl border border-red-500/20 text-textSecondary transition-all duration-500 flex justify-between items-center">
        <div class="flex flex-col">
          <span class="text-red-400 font-bold name transition-colors">Nath_Borges_ </span>
          <span class="phone transition-all">+355 (0) 69 12-34</span>
        </div>
        <span class="badge px-2 py-1 bg-red-500/10 text-red-400 rounded text-[10px] uppercase transition-colors">Duplicada</span>
      </div>
      
      <div id="lead-2" class="p-4 bg-darkBg rounded-xl border border-yellow-500/20 text-textSecondary transition-all duration-500 flex justify-between items-center">
        <div class="flex flex-col">
          <span class="text-yellow-400 font-bold name transition-colors">Vasil_Moskato</span>
          <span class="phone transition-all">068-123-456</span>
        </div>
        <span class="badge px-2 py-1 bg-yellow-500/10 text-yellow-400 rounded text-[10px] uppercase transition-colors">Pendente</span>
      </div>
    </div>

    <!-- Impact Result (Hidden initially) -->
    <div id="impact-result" class="hidden mt-auto p-4 bg-[#00f2fe]/10 border border-[#00f2fe]/20 rounded-xl transition-all duration-500">
      <p class="text-[#00f2fe] font-sora font-bold text-sm md:text-base leading-tight">Carga Cognitiva Reduzida.<br/>Tempo de Operação salvo: 9 horas.</p>
    </div>

    <!-- Controls -->
    <div class="mt-auto flex flex-col gap-3 pt-4">
      <button id="btn-clean" class="w-full py-4 bg-[#00f2fe] text-[#0b0e14] font-bold font-sora rounded-xl hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-[0_0_15px_rgba(0,242,254,0.3)]">
        <span>🧼 Executar Higienização (Pandas + Regex)</span>
      </button>
      <button id="btn-sync" disabled class="w-full py-4 bg-surface border border-white/5 text-textSecondary font-bold font-sora rounded-xl opacity-50 transition-all flex items-center justify-center gap-2">
        <span>🚀 Sincronizar com Notion & IA</span>
      </button>
    </div>
  </div>

  <!-- Coluna Direita: Terminal Técnico -->
  <div class="bg-[#0b0e14] rounded-[24px] p-6 font-space text-xs md:text-sm overflow-hidden flex flex-col border border-white/5 h-[350px] md:h-auto shadow-inner relative">
    
    <!-- Topbar Terminal -->
    <div class="flex items-center gap-2 mb-6 border-b border-white/5 pb-4">
      <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
      <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
      <span class="ml-2 text-textSecondary opacity-50 text-[10px] uppercase tracking-widest">bash - nxt_pipeline.py</span>
    </div>

    <!-- Output Terminal -->
    <div id="terminal-output" class="flex flex-col gap-3 overflow-y-auto text-textSecondary scrollbar-thin pr-2">
      <div class="text-[#00f2fe] opacity-80">[SYSTEM]: Aguardando upload da base de dados B2B...</div>
    </div>
    
    <!-- Blinking Cursor -->
    <div class="mt-2 text-[#00f2fe] animate-pulse">_</div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btnClean = document.getElementById('btn-clean');
    const btnSync = document.getElementById('btn-sync');
    const terminal = document.getElementById('terminal-output');
    const lead1 = document.getElementById('lead-1');
    const lead2 = document.getElementById('lead-2');
    const impactResult = document.getElementById('impact-result');
    const pipelineStatus = document.getElementById('pipeline-status');

    if(!btnClean || !btnSync) return;

    // Utilitário para adicionar logs no terminal
    const logToTerminal = (text, type = 'normal') => {
      const div = document.createElement('div');
      div.className = 'opacity-0 translate-y-2 transition-all duration-300';
      
      if(type === 'success') div.classList.add('text-green-400', 'font-bold');
      else if(type === 'system') div.classList.add('text-[#00f2fe]');
      
      div.textContent = text;
      terminal.appendChild(div);
      
      // Animate in
      requestAnimationFrame(() => {
        div.classList.remove('opacity-0', 'translate-y-2');
      });
      
      // Auto-scroll
      terminal.scrollTop = terminal.scrollHeight;
    };

    const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

    // Ação 1: Higienização
    btnClean.addEventListener('click', async () => {
      // Desativa botão 1
      btnClean.disabled = true;
      btnClean.classList.replace('bg-[#00f2fe]', 'bg-surface');
      btnClean.classList.add('opacity-50', 'text-textSecondary');
      btnClean.classList.remove('text-[#0b0e14]', 'shadow-[0_0_15px_rgba(0,242,254,0.3)]');
      
      logToTerminal('>>> Lendo dataframe (.csv) via Pandas...');
      await sleep(600);
      logToTerminal(">>> Invocando módulo 'executar_guilhotina(df)'...");
      await sleep(500);
      logToTerminal('>>> Aplicando Regex: filtrando caracteres não numéricos...');
      
      // UI Update Lead 1 (Limpo)
      await sleep(300);
      lead1.classList.replace('border-red-500/20', 'border-green-500/30');
      lead1.classList.replace('bg-darkBg', 'bg-green-500/5');
      lead1.querySelector('.name').textContent = 'Nath Borges';
      lead1.querySelector('.name').classList.replace('text-red-400', 'text-green-400');
      lead1.querySelector('.phone').textContent = '+355 69 1234';
      const badge1 = lead1.querySelector('.badge');
      badge1.textContent = 'Limpo';
      badge1.classList.replace('bg-red-500/10', 'bg-green-500/10');
      badge1.classList.replace('text-red-400', 'text-green-400');

      await sleep(400);
      logToTerminal('>>> Critério Smart Erase: 1 entrada duplicada eliminada.');
      
      // UI Update Lead 2 (Limpo)
      await sleep(300);
      lead2.classList.replace('border-yellow-500/20', 'border-green-500/30');
      lead2.classList.replace('bg-darkBg', 'bg-green-500/5');
      lead2.querySelector('.name').textContent = 'Vasil Moskato';
      lead2.querySelector('.name').classList.replace('text-yellow-400', 'text-green-400');
      lead2.querySelector('.phone').textContent = '+355 68 123456';
      const badge2 = lead2.querySelector('.badge');
      badge2.textContent = 'Limpo';
      badge2.classList.replace('bg-yellow-500/10', 'bg-green-500/10');
      badge2.classList.replace('text-yellow-400', 'text-green-400');

      await sleep(500);
      logToTerminal('✓ Sucesso: Base purificada e exportada temporariamente em utf-8-sig.', 'success');
      
      pipelineStatus.textContent = 'Dados Limpos';
      pipelineStatus.classList.replace('text-textSecondary', 'text-green-400');
      pipelineStatus.classList.replace('border-white/10', 'border-green-400/30');
      
      // Ativa botão 2
      btnSync.disabled = false;
      btnSync.classList.remove('opacity-50', 'bg-surface', 'border-white/5', 'text-textSecondary');
      btnSync.classList.add('bg-[#00f2fe]', 'text-[#0b0e14]', 'shadow-[0_0_15px_rgba(0,242,254,0.3)]', 'active:scale-[0.98]', 'cursor-pointer');
    });

    // Ação 2: Sincronização Notion + IA
    btnSync.addEventListener('click', async () => {
      btnSync.disabled = true;
      btnSync.classList.replace('bg-[#00f2fe]', 'bg-surface');
      btnSync.classList.add('opacity-50', 'text-textSecondary');
      btnSync.classList.remove('text-[#0b0e14]', 'shadow-[0_0_15px_rgba(0,242,254,0.3)]', 'active:scale-[0.98]', 'cursor-pointer');

      logToTerminal('>>> Inicializando cliente genai.Client()...');
      await sleep(500);
      logToTerminal(">>> Executando modelo 'gemini-2.0-flash' para enriquecimento semântico...");
      
      const badges = document.querySelectorAll('.badge');
      badges.forEach(b => {
        b.textContent = 'Processando...';
        b.classList.replace('bg-green-500/10', 'bg-[#00f2fe]/10');
        b.classList.replace('text-green-400', 'text-[#00f2fe]');
      });

      await sleep(700);
      logToTerminal(">>> Gerando chaves únicas através de 'gerar_rid()'.");
      await sleep(600);
      logToTerminal(">>> Despachando payload JSON para a API do Notion (DATABASE_ID autenticado)...");
      
      await sleep(400);
      badges.forEach(b => {
        b.textContent = 'Sincronizado';
        b.classList.replace('bg-[#00f2fe]/10', 'bg-blue-500/20');
        b.classList.replace('text-[#00f2fe]', 'text-blue-400');
      });

      await sleep(500);
      logToTerminal(">>> Gravando callbacks de sucesso em 'automacao.log'.");
      await sleep(400);
      logToTerminal('✓ Concluído: Pipeline finalizado com INP estável (< 200ms).', 'success');

      pipelineStatus.textContent = 'Operação Finalizada';
      pipelineStatus.classList.replace('text-green-400', 'text-[#00f2fe]');
      pipelineStatus.classList.replace('border-green-400/30', 'border-[#00f2fe]/30');
      pipelineStatus.classList.add('bg-[#00f2fe]/10');

      impactResult.classList.remove('hidden');
      // Pequeno delay para a animação de fade in fluir
      setTimeout(() => {
        impactResult.classList.add('animate-fade-in-up');
      }, 50);
    });
  });
</script>

<style>
  /* Personalização fina para o Scrollbar do Terminal */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }
</style>
