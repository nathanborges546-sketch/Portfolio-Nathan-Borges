---
// Componente Interativo: Tabela Notion + Pipeline Sandbox B2B
---

<div class="w-full flex flex-col font-sora mt-4 opacity-0 animate-fade-in-up [animation-delay:200ms]">
  
  <!-- Wrapper da Tabela Estilo Notion -->
  <div class="w-full bg-[#161b22] border border-white/10 rounded-2xl overflow-hidden mb-6 shadow-2xl">
    
    <!-- Top Bar -->
    <div class="px-6 py-4 border-b border-white/5 flex items-center justify-between bg-white/[0.02]">
      <div class="flex items-center gap-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-textSecondary">
          <path d="M3 3v18h18V3H3zm16 16H5V5h14v14zM7 7h10v2H7V7zm0 4h10v2H7v-2zm0 4h7v2H7v-2z"/>
        </svg>
        <span class="font-sora font-semibold text-textPrimary tracking-wide">Leads_B2B_Brutos.csv</span>
      </div>
      <span class="text-[10px] font-space text-textSecondary uppercase tracking-widest bg-darkBg px-3 py-1 rounded-full border border-white/5">6 Entradas Mapeadas</span>
    </div>
    
    <div class="overflow-x-auto scrollbar-thin">
      <table class="w-full text-left border-collapse min-w-[900px]">
        <thead class="bg-[#0b0e14] border-b border-white/5 font-space text-[10px] uppercase tracking-widest text-textSecondary">
          <tr>
            <th class="px-6 py-4 font-normal">Empresa</th>
            <th class="px-6 py-4 font-normal">Telefone</th>
            <th class="px-6 py-4 font-normal">E-mail</th>
            <th class="px-6 py-4 font-normal">Decisor</th>
            <th class="px-6 py-4 font-normal">Status/Erro</th>
            <th class="px-6 py-4 font-normal text-right">Tempo Salvo</th>
          </tr>
        </thead>
        <tbody id="notion-tbody" class="text-sm font-sora text-textPrimary divide-y divide-white/5">
          
          <!-- Row 1: Erro no diagnóstico (Vazio) -->
          <tr class="db-row transition-all duration-700 bg-red-500/5 hover:bg-white/5 group row-null" id="row-1">
            <td class="px-6 py-4 whitespace-nowrap field-empresa font-bold">Somos6digital</td>
            <td class="px-6 py-4 whitespace-nowrap text-red-400 field-telefone font-space text-xs">-- VAZIO --</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">contato@somos6digital.com</td>
            <td class="px-6 py-4 whitespace-nowrap text-red-400 field-decisor font-space text-xs">-- VAZIO --</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="badge-status px-2 py-1 bg-red-500/10 text-red-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500">Erro (NaN)</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <span class="time-saved opacity-0 text-[#00f2fe] font-space text-xs font-bold transition-all duration-500 translate-y-2 inline-block">+ 3 min</span>
            </td>
          </tr>

          <!-- Row 2: Sujo Regex -->
          <tr class="db-row transition-all duration-700 hover:bg-white/5 group row-regex" id="row-2">
            <td class="px-6 py-4 whitespace-nowrap field-empresa font-bold">Ramper</td>
            <td class="px-6 py-4 whitespace-nowrap text-yellow-400 field-telefone font-space text-xs transition-colors duration-500">11999056763</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">ricardo@ramper.com.br</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">Ricardo Corrêa</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="badge-status px-2 py-1 bg-yellow-500/10 text-yellow-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500">Formato Inválido</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <span class="time-saved opacity-0 text-[#00f2fe] font-space text-xs font-bold transition-all duration-500 translate-y-2 inline-block">+ 2 min</span>
            </td>
          </tr>

          <!-- Row 3: Sujo Regex -->
          <tr class="db-row transition-all duration-700 hover:bg-white/5 group row-regex" id="row-3">
            <td class="px-6 py-4 whitespace-nowrap field-empresa font-bold">Actwork: Agência...</td>
            <td class="px-6 py-4 whitespace-nowrap text-yellow-400 field-telefone font-space text-xs transition-colors duration-500">551120903030</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">vinicius@actwork.com.br</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">Vinicius Marques</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="badge-status px-2 py-1 bg-yellow-500/10 text-yellow-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500">Formato Inválido</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <span class="time-saved opacity-0 text-[#00f2fe] font-space text-xs font-bold transition-all duration-500 translate-y-2 inline-block">+ 2 min</span>
            </td>
          </tr>

          <!-- Row 4: Duplicado (Ramper) -->
          <tr class="db-row transition-all duration-1000 bg-red-500/5 hover:bg-white/5 group row-dup" id="row-4">
            <td class="px-6 py-4 whitespace-nowrap field-empresa font-bold text-red-400">Ramper</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary font-space text-xs">11999056763</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">ricardo@ramper.com.br</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">Ricardo Corrêa</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="badge-status px-2 py-1 bg-red-500/10 text-red-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500">Duplicado</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <span class="time-saved opacity-0 text-[#00f2fe] font-space text-xs font-bold transition-all duration-500 translate-y-2 inline-block">+ 1 min</span>
            </td>
          </tr>

          <!-- Row 5: Misto -->
          <tr class="db-row transition-all duration-700 hover:bg-white/5 group row-regex row-null" id="row-5">
            <td class="px-6 py-4 whitespace-nowrap field-empresa font-bold">Bazooka</td>
            <td class="px-6 py-4 whitespace-nowrap text-yellow-400 field-telefone font-space text-xs transition-colors duration-500">351918318424</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">geral@boaventura...</td>
            <td class="px-6 py-4 whitespace-nowrap text-red-400 field-decisor font-space text-xs">-- VAZIO --</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="badge-status px-2 py-1 bg-orange-500/10 text-orange-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500">Atenção</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <span class="time-saved opacity-0 text-[#00f2fe] font-space text-xs font-bold transition-all duration-500 translate-y-2 inline-block">+ 4 min</span>
            </td>
          </tr>

          <!-- Row 6: Duplicado (Somos6digital) -->
          <tr class="db-row transition-all duration-1000 bg-red-500/5 hover:bg-white/5 group row-dup" id="row-6">
            <td class="px-6 py-4 whitespace-nowrap field-empresa font-bold text-red-400">Somos6digital</td>
            <td class="px-6 py-4 whitespace-nowrap text-red-400 font-space text-xs">-- VAZIO --</td>
            <td class="px-6 py-4 whitespace-nowrap text-textSecondary">contato@somos...</td>
            <td class="px-6 py-4 whitespace-nowrap text-red-400 font-space text-xs">-- VAZIO --</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="badge-status px-2 py-1 bg-red-500/10 text-red-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500">Duplicado</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <span class="time-saved opacity-0 text-[#00f2fe] font-space text-xs font-bold transition-all duration-500 translate-y-2 inline-block">+ 1 min</span>
            </td>
          </tr>

        </tbody>
      </table>
    </div>
  </div>

  <!-- Controles e Terminal -->
  <div class="grid grid-cols-1 lg:grid-cols-[0.8fr_1.2fr] gap-6">
    
    <!-- Painel de Ações -->
    <div class="flex flex-col gap-6 bg-[#161b22] p-6 md:p-8 rounded-2xl border border-white/5 shadow-2xl relative overflow-hidden">
      <!-- Decorator -->
      <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-[#00f2fe]/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="flex items-center justify-between mb-2">
        <h3 class="font-bold text-lg text-textPrimary tracking-tight">Console de Operação</h3>
        <span id="global-time" class="text-[#00f2fe] font-space font-bold opacity-0 transition-opacity duration-700 bg-[#00f2fe]/10 px-3 py-1 rounded-full text-xs">0 min salvos</span>
      </div>
      
      <p class="text-textSecondary text-sm mb-auto">Acione o script abaixo para iniciar a limpeza semântica via Pandas na base superior.</p>
      
      <div class="flex flex-col gap-3 mt-8">
        <button id="btn-clean" class="w-full py-4 bg-[#00f2fe] text-[#0b0e14] font-bold font-sora rounded-xl hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-[0_0_15px_rgba(0,242,254,0.2)]">
          <span>🧼 Iniciar Purificação (Pandas)</span>
        </button>
        <button id="btn-sync" disabled class="w-full py-4 bg-surface border border-white/5 text-textSecondary font-bold font-sora rounded-xl opacity-50 transition-all flex items-center justify-center gap-2">
          <span>🚀 Sincronizar Notion Database</span>
        </button>
      </div>
    </div>

    <!-- Terminal Técnico -->
    <div class="bg-[#0b0e14] rounded-2xl p-6 font-space text-xs md:text-sm overflow-hidden flex flex-col border border-white/5 h-[350px] shadow-inner relative">
      <div class="flex items-center gap-2 mb-6 border-b border-white/5 pb-4">
        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
        <span class="ml-2 text-textSecondary opacity-50 text-[10px] uppercase tracking-widest">bash - nxt_pipeline.py</span>
      </div>
      <div id="terminal-output" class="flex flex-col gap-3 overflow-y-auto text-textSecondary scrollbar-thin pr-2">
        <div class="text-[#00f2fe] opacity-80">[SYSTEM]: Aguardando injeção de scripts...</div>
      </div>
      <div class="mt-2 text-[#00f2fe] animate-pulse">_</div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btnClean = document.getElementById('btn-clean');
    const btnSync = document.getElementById('btn-sync');
    const terminal = document.getElementById('terminal-output');
    const globalTimeCounter = document.getElementById('global-time');
    
    if(!btnClean || !btnSync) return;

    let totalMinutesSaved = 0;

    const logToTerminal = (text, type = 'normal') => {
      const div = document.createElement('div');
      div.className = 'opacity-0 translate-y-2 transition-all duration-500';
      
      if(type === 'success') div.classList.add('text-green-400', 'font-bold');
      else if(type === 'system') div.classList.add('text-[#00f2fe]');
      else if(type === 'error') div.classList.add('text-red-400');
      
      div.textContent = text;
      terminal.appendChild(div);
      
      requestAnimationFrame(() => {
        div.classList.remove('opacity-0', 'translate-y-2');
      });
      terminal.scrollTop = terminal.scrollHeight;
    };

    const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

    const updateGlobalTime = (minutes) => {
      totalMinutesSaved += minutes;
      globalTimeCounter.textContent = `${totalMinutesSaved} min salvos`;
      globalTimeCounter.classList.remove('opacity-0');
    };

    const showTimeSaved = (rowElement, minutes) => {
      const timeSavedEl = rowElement.querySelector('.time-saved');
      if (timeSavedEl) {
        timeSavedEl.textContent = `+ ${minutes}m`;
        timeSavedEl.classList.remove('opacity-0', 'translate-y-2');
      }
      updateGlobalTime(minutes);
    };

    const updateBadge = (row, text, colorClass) => {
      const badge = row.querySelector('.badge-status');
      badge.textContent = text;
      badge.className = `badge-status px-2 py-1 rounded text-[10px] uppercase tracking-wider transition-colors duration-500 ${colorClass}`;
    };

    // Ação 1: Higienização
    btnClean.addEventListener('click', async () => {
      btnClean.disabled = true;
      btnClean.classList.replace('bg-[#00f2fe]', 'bg-surface');
      btnClean.classList.add('opacity-50', 'text-textSecondary');
      btnClean.classList.remove('text-[#0b0e14]', 'shadow-[0_0_15px_rgba(0,242,254,0.2)]');
      
      logToTerminal('>>> Analisando DataFrame via Pandas (6 entradas brutas)...');
      await sleep(1500);
      
      // Step 1: Regex
      logToTerminal('>>> Aplicando módulo Regex em telefones (E.164)...', 'system');
      await sleep(1500);
      
      const regexRows = document.querySelectorAll('.row-regex');
      regexRows.forEach((row, index) => {
        const tel = row.querySelector('.field-telefone');
        tel.classList.remove('text-yellow-400');
        tel.classList.add('text-green-400');
        
        // Hardcoded formatting for visual simulation
        if(row.id === 'row-2') tel.textContent = '+55 (11) 99905-6763';
        if(row.id === 'row-3') tel.textContent = '+55 (11) 2090-3030';
        if(row.id === 'row-5') tel.textContent = '+35 (19) 1831-8424';

        if(row.id !== 'row-5') updateBadge(row, 'Regex Ok', 'bg-green-500/10 text-green-400');
        showTimeSaved(row, 2);
      });

      await sleep(1500);
      
      // Step 2: Tratamento de Nulos
      logToTerminal('>>> Aplicando preenchimento Null (Tratamento Semântico)...', 'system');
      await sleep(1500);

      const nullRows = document.querySelectorAll('.row-null');
      nullRows.forEach(row => {
        row.classList.remove('bg-red-500/5');
        
        const tels = row.querySelectorAll('.field-telefone');
        const decisors = row.querySelectorAll('.field-decisor');
        
        tels.forEach(el => {
          if (el.textContent.includes('VAZIO')) {
            el.textContent = 'Não Informado';
            el.classList.replace('text-red-400', 'text-textSecondary');
            el.classList.replace('font-space', 'font-sora');
            el.classList.add('italic', 'opacity-50');
          }
        });
        
        decisors.forEach(el => {
          if (el.textContent.includes('VAZIO')) {
            el.textContent = 'Desconhecido';
            el.classList.replace('text-red-400', 'text-textSecondary');
            el.classList.replace('font-space', 'font-sora');
            el.classList.add('italic', 'opacity-50');
          }
        });

        if(row.id !== 'row-6') {
          updateBadge(row, 'Null Fix', 'bg-green-500/10 text-green-400');
          showTimeSaved(row, 3);
        }
      });

      await sleep(2000);

      // Step 3: Smart Erase (Duplicatas)
      logToTerminal('>>> Executando módulo Smart Erase (Buscando Duplicatas)...', 'system');
      await sleep(1500);
      
      const dupRows = document.querySelectorAll('.row-dup');
      dupRows.forEach(row => {
        row.classList.replace('bg-red-500/5', 'bg-red-500/20'); // Highlight before delete
      });
      logToTerminal('>>> Anomalia: 2 entradas redundantes detectadas.', 'error');

      await sleep(1500);

      dupRows.forEach(row => {
        // Encolher visualmente
        row.style.opacity = '0';
        row.style.transform = 'scaleY(0)';
        row.style.height = '0px';
        row.style.borderWidth = '0px';
        // Remove padding das td
        row.querySelectorAll('td').forEach(td => {
          td.style.paddingTop = '0';
          td.style.paddingBottom = '0';
        });
        
        setTimeout(() => row.remove(), 1000);
        showTimeSaved(row, 1);
      });

      logToTerminal('>>> Smart Erase: Linhas eliminadas com sucesso.', 'success');
      
      await sleep(1500);

      // Finalização
      document.querySelectorAll('.badge-status').forEach(b => {
        b.textContent = 'Limpo';
        b.className = 'badge-status px-2 py-1 bg-green-500/10 text-green-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500';
      });

      logToTerminal('✓ Base purificada em 1.2s. Exportação pronta.', 'success');
      
      // Habilita Sync
      btnSync.disabled = false;
      btnSync.classList.remove('opacity-50', 'bg-surface', 'border', 'border-white/5', 'text-textSecondary');
      btnSync.classList.add('bg-[#00f2fe]', 'text-[#0b0e14]', 'active:scale-[0.98]', 'cursor-pointer', 'shadow-[0_0_15px_rgba(0,242,254,0.2)]');
    });

    // Ação 2: Sync Notion
    btnSync.addEventListener('click', async () => {
      btnSync.disabled = true;
      btnSync.classList.replace('bg-[#00f2fe]', 'bg-surface');
      btnSync.classList.add('opacity-50', 'text-textSecondary', 'border', 'border-white/5');
      btnSync.classList.remove('text-[#0b0e14]', 'shadow-[0_0_15px_rgba(0,242,254,0.2)]', 'cursor-pointer');

      logToTerminal('>>> Instanciando client Notion API (v2)...');
      await sleep(1500);
      logToTerminal('>>> Preparando batch de 4 leads purificados...');
      
      const badges = document.querySelectorAll('.badge-status');
      badges.forEach(b => {
        b.textContent = 'Processando...';
        b.className = 'badge-status px-2 py-1 bg-[#00f2fe]/10 text-[#00f2fe] rounded text-[10px] uppercase tracking-wider transition-colors duration-500';
      });

      await sleep(2000);
      logToTerminal(">>> Gerando Embeddings via Gemini 2.0 para estruturação semântica...", 'system');
      await sleep(2500);
      logToTerminal(">>> Commit finalizado no Notion (Database ID: auth_success).");
      
      await sleep(1000);
      badges.forEach(b => {
        b.textContent = 'Sincronizado';
        b.className = 'badge-status px-2 py-1 bg-blue-500/20 text-blue-400 rounded text-[10px] uppercase tracking-wider transition-colors duration-500';
      });

      logToTerminal('✓ Operação concluída. INP estável (< 200ms).', 'success');
    });
  });
</script>

<style>
  /* Oculta overflow na animação de Smart Erase */
  .db-row {
    transform-origin: top;
    overflow: hidden;
  }
  
  .scrollbar-thin::-webkit-scrollbar {
    height: 6px;
    width: 6px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }
</style>
