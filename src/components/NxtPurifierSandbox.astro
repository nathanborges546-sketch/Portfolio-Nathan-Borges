---
// src/components/NxtPurifierSandbox.astro
---

<div class="w-full max-w-6xl mx-auto bg-[#161b22] rounded-3xl p-6 border border-white/5 shadow-2xl font-sora text-[#f0f6fc]">
  
  <!-- Tabela Estilo Notion -->
  <div class="mb-8 border border-white/5 rounded-2xl overflow-hidden bg-white/[0.01]">
    
    <!-- Top Bar da Tabela (Estática) -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-white/5 p-5 bg-[#0b0e14]/30">
      <div class="flex items-center gap-3">
        <span class="font-space text-[10px] bg-white/5 text-[#8b949e] px-3 py-1 rounded-full border border-white/5 tracking-wider font-semibold">CSV ENGINE</span>
        <h3 class="text-sm font-bold tracking-tight text-[#f0f6fc]">Base_Leads_Brutos.csv</h3>
      </div>
      <span id="badge-total" class="font-space text-[10px] text-[#00f2fe] bg-[#00f2fe]/10 px-3 py-1 rounded-full border border-[#00f2fe]/20 tracking-wider font-semibold">
        6 Entradas Detectadas
      </span>
    </div>

    <!-- Container com Scroll Horizontal Responsivo para Telas Menores -->
    <div class="overflow-x-auto scrollbar-thin">
      <div class="min-w-[800px] p-5">
        
        <!-- Cabeçalho das Colunas -->
        <div class="grid grid-cols-5 gap-4 text-xs font-space text-[#8b949e] uppercase tracking-wider pb-3 px-4 border-b border-white/5">
          <div>Empresa</div>
          <div>Telefone (Antes → Depois)</div>
          <div>Diagnóstico Inicial</div>
          <div>Status Final</div>
          <div class="text-right">Tempo Economizado</div>
        </div>

        <!-- Linhas de Dados -->
        <div class="space-y-2 mt-3" id="table-body">
          
          <!-- Linha 1 -->
          <div class="grid grid-cols-5 gap-4 text-sm items-center bg-[#0b0e14]/40 p-4 rounded-xl border border-white/5 transition-all duration-500" id="row-1">
            <div class="font-bold">Somos6digital</div>
            <div class="text-[#8b949e] italic transition-all duration-300 font-space text-xs" id="tel-1">-- VAZIO --</div>
            <div class="text-amber-400/80 text-xs flex items-center gap-1.5 font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> Dado Ausente
            </div>
            <div class="font-space text-xs text-[#8b949e]" id="status-1">Aguardando Comando</div>
            <div class="text-right font-space text-xs text-[#00f2fe] opacity-0 transition-all duration-500 font-bold" id="time-1">+ 3 min</div>
          </div>

          <!-- Linha 2 -->
          <div class="grid grid-cols-5 gap-4 text-sm items-center bg-[#0b0e14]/40 p-4 rounded-xl border border-white/5 transition-all duration-500" id="row-2">
            <div class="font-bold">Ramper</div>
            <div class="text-[#f0f6fc] tracking-mono transition-all duration-300 font-space text-xs" id="tel-2">11999056763</div>
            <div class="text-amber-400/80 text-xs flex items-center gap-1.5 font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> Desformatado
            </div>
            <div class="font-space text-xs text-[#8b949e]" id="status-2">Aguardando Comando</div>
            <div class="text-right font-space text-xs text-[#00f2fe] opacity-0 transition-all duration-500 font-bold" id="time-2">+ 2 min</div>
          </div>

          <!-- Linha 3 -->
          <div class="grid grid-cols-5 gap-4 text-sm items-center bg-[#0b0e14]/40 p-4 rounded-xl border border-white/5 transition-all duration-500" id="row-3">
            <div class="font-bold">Actwork</div>
            <div class="text-[#f0f6fc] tracking-mono transition-all duration-300 font-space text-xs" id="tel-3">551120903030</div>
            <div class="text-amber-400/80 text-xs flex items-center gap-1.5 font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> Desformatado
            </div>
            <div class="font-space text-xs text-[#8b949e]" id="status-3">Aguardando Comando</div>
            <div class="text-right font-space text-xs text-[#00f2fe] opacity-0 transition-all duration-500 font-bold" id="time-3">+ 2 min</div>
          </div>

          <!-- Linha 4 (Redundante) -->
          <div class="grid grid-cols-5 gap-4 text-sm items-center bg-[#0b0e14]/40 p-4 rounded-xl border border-white/5 transition-all duration-500 max-h-[200px] overflow-hidden origin-center" id="row-4">
            <div class="font-bold text-[#8b949e]/60">Ramper <span class="text-[9px] bg-red-500/10 text-red-400 px-1.5 py-0.5 rounded border border-red-500/10 uppercase tracking-widest font-space font-semibold ml-1">DUP</span></div>
            <div class="text-[#8b949e]/40 tracking-mono font-space text-xs">11999056763</div>
            <div class="text-red-400/80 text-xs flex items-center gap-1.5 font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span> Entrada Repetida
            </div>
            <div class="font-space text-xs text-red-400/60" id="status-4">Aguardando Comando</div>
            <div class="text-right font-space text-xs text-[#00f2fe] opacity-0 transition-all duration-500 font-bold" id="time-4">+ 1 min</div>
          </div>

          <!-- Linha 5 -->
          <div class="grid grid-cols-5 gap-4 text-sm items-center bg-[#0b0e14]/40 p-4 rounded-xl border border-white/5 transition-all duration-500" id="row-5">
            <div class="font-bold">Bazooka</div>
            <div class="text-[#f0f6fc] tracking-mono transition-all duration-300 font-space text-xs" id="tel-5">351918318424</div>
            <div class="text-amber-400/80 text-xs flex items-center gap-1.5 font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> Formato Int.
            </div>
            <div class="font-space text-xs text-[#8b949e]" id="status-5">Aguardando Comando</div>
            <div class="text-right font-space text-xs text-[#00f2fe] opacity-0 transition-all duration-500 font-bold" id="time-5">+ 4 min</div>
          </div>

          <!-- Linha 6 (Redundante) -->
          <div class="grid grid-cols-5 gap-4 text-sm items-center bg-[#0b0e14]/40 p-4 rounded-xl border border-white/5 transition-all duration-500 max-h-[200px] overflow-hidden origin-center" id="row-6">
            <div class="font-bold text-[#8b949e]/60">Somos6digital <span class="text-[9px] bg-red-500/10 text-red-400 px-1.5 py-0.5 rounded border border-red-500/10 uppercase tracking-widest font-space font-semibold ml-1">DUP</span></div>
            <div class="text-[#8b949e]/40 italic font-space text-xs">-- VAZIO --</div>
            <div class="text-red-400/80 text-xs flex items-center gap-1.5 font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span> Entrada Repetida
            </div>
            <div class="font-space text-xs text-red-400/60" id="status-6">Aguardando Comando</div>
            <div class="text-right font-space text-xs text-[#00f2fe] opacity-0 transition-all duration-500 font-bold" id="time-6">+ 1 min</div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Controles do Painel e Logs do Terminal -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
    
    <!-- Painel de Operações (Esquerda) -->
    <div class="lg:col-span-5 flex flex-col justify-between bg-[#0b0e14]/60 p-6 rounded-2xl border border-white/5 shadow-inner">
      <div>
        <h4 class="font-bold text-base tracking-tight text-[#f0f6fc]">Painel de Controle</h4>
        <p class="text-xs text-[#8b949e] mt-2 leading-relaxed">
          Execute as etapas lógicas do algoritmo para processar a base de dados acima de forma assíncrona.
        </p>
        
        <!-- Contador de Produtividade -->
        <div class="mt-6 bg-[#0b0e14] p-4 rounded-xl border border-white/5 text-center shadow-inner">
          <div class="font-space text-3xl font-bold text-[#00f2fe] transition-all duration-300" id="time-counter">0 min</div>
          <div class="text-[9px] font-space text-[#8b949e] uppercase tracking-widest mt-1.5 font-semibold">Tempo de Trabalho Economizado</div>
        </div>
      </div>

      <!-- Ações do Painel -->
      <div class="space-y-3 mt-6">
        <button id="btn-run-purify" class="w-full bg-[#00f2fe] text-[#0b0e14] font-space font-bold text-xs tracking-wider uppercase py-4 px-4 rounded-xl transition-all duration-300 hover:brightness-110 active:scale-[0.98] shadow-[0_0_15px_rgba(0,242,254,0.15)] cursor-pointer">
          🧼 Passo 1: Executar Limpeza Automatizada
        </button>
        <button id="btn-run-sync" class="w-full bg-white/5 text-[#8b949e] font-space font-bold text-xs tracking-wider uppercase py-4 px-4 rounded-xl cursor-not-allowed transition-all duration-300 border border-white/5" disabled>
          🚀 Passo 2: Sincronizar com Banco de Dados Central
        </button>
      </div>
    </div>

    <!-- Terminal Técnico de Logs (Direita) -->
    <div class="lg:col-span-7 bg-[#0b0e14] rounded-2xl p-5 border border-white/5 font-space flex flex-col justify-between min-h-[280px] shadow-inner relative">
      
      <!-- Topbar Terminal -->
      <div class="flex items-center justify-between border-b border-white/5 pb-3 text-[10px] text-[#8b949e] font-semibold">
        <span class="tracking-widest uppercase">Console de Execução Assíncrona</span>
        <div class="flex items-center gap-1.5 bg-white/5 px-2.5 py-1 rounded-full border border-white/5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#00f2fe] animate-pulse" id="terminal-pulse"></span>
          <span id="terminal-status" class="tracking-wider">READY</span>
        </div>
      </div>

      <!-- Saída de Logs do Terminal -->
      <div id="log-screen" class="font-mono text-[11px] text-[#8b949e] space-y-2 py-4 overflow-y-auto flex-1 max-h-[190px] scrollbar-thin pr-2 mt-2 leading-relaxed">
        <p class="text-[#00f2fe]/60 animate-pulse">[SYSTEM]: Sistema operacional iniciado. Aguardando gatilho...</p>
      </div>

      <!-- Rodapé Terminal -->
      <div class="text-[9px] text-[#8b949e]/40 pt-3 border-t border-white/5 flex justify-between font-semibold mt-2">
        <span>Instâncias: nxt_purifier.py • automacao_nxt.py</span>
        <span>v2026.5</span>
      </div>
    </div>

  </div>
</div>

<script>
  // Captura de Elementos do DOM com Segurança de Tipos
  const btnPurify = document.getElementById('btn-run-purify') as HTMLButtonElement;
  const btnSync = document.getElementById('btn-run-sync') as HTMLButtonElement;
  const logScreen = document.getElementById('log-screen');
  const timeCounter = document.getElementById('time-counter');
  const badgeTotal = document.getElementById('badge-total');
  const terminalStatus = document.getElementById('terminal-status');
  const terminalPulse = document.getElementById('terminal-pulse');

  // Função utilitária para injetar logs sequencialmente na tela
  function addLog(text: string, type: 'info' | 'success' | 'warn' | 'error' = 'info', delay: number) {
    return new Promise((resolve) => {
      setTimeout(() => {
        if (logScreen) {
          const p = document.createElement('p');
          if (type === 'success') p.className = 'text-emerald-400 font-semibold';
          else if (type === 'warn') p.className = 'text-amber-400';
          else if (type === 'error') p.className = 'text-red-400 font-bold';
          else p.className = 'text-[#8b949e]';
          
          p.innerHTML = text;
          logScreen.appendChild(p);
          logScreen.scrollTop = logScreen.scrollHeight; // Scroll automático
        }
        resolve(true);
      }, delay);
    });
  }

  // Função para simular o crescimento suave do contador numérico
  function animateCounter(targetValue: number, duration: number) {
    let start = 0;
    const stepTime = Math.abs(Math.floor(duration / targetValue));
    const timer = setInterval(() => {
      start++;
      if (timeCounter) timeCounter.innerText = `${start} min`;
      if (start >= targetValue) clearInterval(timer);
    }, stepTime);
  }

  // ==========================================
  // CLICK DO PASSO 1: HIGIENIZAÇÃO (Pandas/Regex)
  // ==========================================
  btnPurify?.addEventListener('click', async () => {
    btnPurify.disabled = true;
    btnPurify.classList.add('opacity-50', 'cursor-not-allowed');
    btnPurify.classList.remove('shadow-[0_0_15px_rgba(0,242,254,0.15)]');
    if (terminalStatus) terminalStatus.innerText = 'PROCESSING';

    // Cascata de Logs de Processamento no Terminal (nxt_purifier.py)
    await addLog('>>> Lendo DataFrame via Pandas: 6 registros carregados...', 'info', 0);
    await addLog('>>> Executando módulo \'executar_guilhotina\': isolando colunas críticas...', 'info', 800);
    await addLog('>>> Aplicando Regex (E.164): filtrando ruídos e padronizando máscaras...', 'info', 1000);
    
    // Atualização Visual Tabela: Correções de Regex nos Telefones (Linhas 2, 3 e 5)
    setTimeout(() => {
      const tel2 = document.getElementById('tel-2');
      const st2 = document.getElementById('status-2');
      if (tel2 && st2) {
        tel2.innerText = '+55 (11) 99905-6763'; tel2.classList.add('text-emerald-400');
        st2.innerText = '✓ Padronizado'; st2.className = 'font-space text-xs text-emerald-400 font-semibold';
      }
      const tel3 = document.getElementById('tel-3');
      const st3 = document.getElementById('status-3');
      if (tel3 && st3) {
        tel3.innerText = '+55 (11) 2090-3030'; tel3.classList.add('text-emerald-400');
        st3.innerText = '✓ Padronizado'; st3.className = 'font-space text-xs text-emerald-400 font-semibold';
      }
      const tel5 = document.getElementById('tel-5');
      const st5 = document.getElementById('status-5');
      if (tel5 && st5) {
        tel5.innerText = '+351 918 318 424'; tel5.classList.add('text-emerald-400');
        st5.innerText = '✓ Ajustado'; st5.className = 'font-space text-xs text-emerald-400 font-semibold';
      }
    }, 2000);

    await addLog('>>> Tratamento de nulos: strings vazias convertidas para rótulos...', 'info', 1200);
    
    // Atualização Visual Tabela: Correções de Nulos/NaN (Linha 1)
    setTimeout(() => {
      const tel1 = document.getElementById('tel-1');
      const st1 = document.getElementById('status-1');
      if (tel1 && st1) {
        tel1.innerText = 'Não informado'; tel1.classList.replace('text-[#8b949e]', 'text-[#8b949e]/60');
        st1.innerText = '✓ Tratado'; st1.className = 'font-space text-xs text-emerald-400 font-semibold';
      }
    }, 3200);

    await addLog('>>> Ativando Smart Erase: varredura de redundâncias concluída.', 'info', 1000);
    await addLog('⚠️ Alerta: Detectadas 2 entradas duplicadas na base primária.', 'warn', 800);
    await addLog('>>> Smart Erase executado: linhas redundantes expurgadas do buffer.', 'info', 1000);

    // =============================================================
    // ANIMAÇÃO DE SMART ERASE (Rows colapsando com efeito suave)
    // =============================================================
    setTimeout(() => {
      const row4 = document.getElementById('row-4');
      const row6 = document.getElementById('row-6');
      
      [row4, row6].forEach(row => {
        if (row) {
          // Colapso completo respeitando as transições Tailwind
          row.classList.add('opacity-0', 'scale-[0.95]', 'max-h-0', '!p-0', '!my-0', '!border-0', 'pointer-events-none');
        }
      });
      if (badgeTotal) {
        badgeTotal.innerText = '4 Entradas Consolidadas';
        badgeTotal.classList.replace('text-[#00f2fe]', 'text-emerald-400');
        badgeTotal.classList.replace('bg-[#00f2fe]/10', 'bg-emerald-400/10');
        badgeTotal.classList.replace('border-[#00f2fe]/20', 'border-emerald-400/20');
      }
    }, 6000);

    await addLog('✓ Sucesso: Base purificada e armazenada em memória (utf-8-sig).', 'success', 1500);

    // Exibe cronômetro economizado e libera o Passo 2
    setTimeout(() => {
      animateCounter(13, 1200); // Contador cresce suave de 0 a 13
      ['time-1', 'time-2', 'time-3', 'time-4', 'time-5', 'time-6'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.remove('opacity-0');
      });

      if (btnSync && terminalStatus) {
        terminalStatus.innerText = 'PRONTO P/ ENVIO';
        btnSync.disabled = false;
        btnSync.classList.remove('bg-white/5', 'text-[#8b949e]', 'cursor-not-allowed');
        btnSync.classList.add('bg-[#00f2fe]', 'text-[#0b0e14]', 'hover:brightness-110', 'active:scale-[0.98]', 'shadow-[0_0_15px_rgba(0,242,254,0.15)]', 'cursor-pointer');
      }
    }, 6500);
  });


  // ==========================================
  // CLICK DO PASSO 2: SINCRONIZAÇÃO (Notion/Gemini)
  // ==========================================
  btnSync?.addEventListener('click', async () => {
    btnSync.disabled = true;
    btnSync.classList.remove('bg-[#00f2fe]', 'shadow-[0_0_15px_rgba(0,242,254,0.15)]', 'cursor-pointer');
    btnSync.classList.add('bg-white/5', 'text-[#8b949e]', 'cursor-not-allowed');
    if (terminalStatus) terminalStatus.innerText = 'SENDING';

    // Logs de Integração no Terminal (automacao_nxt.py)
    await addLog('>>> Conectando à API oficial do Notion (Versão: 2022-06-28)...', 'info', 0);
    await addLog('>>> Instanciando genai.Client() para análise semântica descritiva...', 'info', 800);
    await addLog('>>> Processando batch com modelo \'gemini-2.0-flash\'...', 'info', 1000);
    await addLog('>>> Gerando identificadores exclusivos através da função \'gerar_rid()\'...', 'info', 800);
    await addLog('>>> Payload JSON estruturado enviado para DATABASE_ID com sucesso.', 'info', 800);
    
    // Status Final da Tabela de Leads vira "Sincronizado"
    setTimeout(() => {
      ['status-1', 'status-2', 'status-3', 'status-5'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
          el.innerText = '✓ Sincronizado';
          el.className = 'font-space text-xs text-[#00f2fe] font-semibold';
        }
      });
    }, 2800);

    await addLog('✓ Operação finalizada. Integração concluída com estabilidade (INP < 200ms).', 'success', 1200);

    // Estado Final de Sucesso Absoluto
    setTimeout(() => {
      if (terminalStatus && terminalPulse) {
        terminalStatus.innerText = 'SINCRONIZADO';
        terminalPulse.classList.replace('bg-[#00f2fe]', 'bg-emerald-400');
      }
      btnSync.classList.replace('bg-white/5', 'bg-emerald-500');
      btnSync.classList.replace('text-[#8b949e]', 'text-white');
      btnSync.innerText = '✓ Sincronização Concluída';
    }, 3200);
  });
</script>

<style>
  /* Scrollbar minimalista para o Terminal de Logs e Tabela */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 99px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 242, 254, 0.3);
  }
</style>
