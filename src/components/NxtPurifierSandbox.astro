  </div>

  <!-- Modal de Impacto Operacional (POPUP ROI) -->
  <div id="roi-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0b0e14]/80 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500">
    <div class="bg-[#161b22] border border-white/10 rounded-3xl p-6 max-w-lg w-full shadow-2xl transform scale-95 transition-all duration-500 flex flex-col gap-5" id="roi-modal-content">
      
      <div class="flex items-start justify-between">
