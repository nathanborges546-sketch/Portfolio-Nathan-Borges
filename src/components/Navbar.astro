<script>
  document.addEventListener('astro:page-load', () => {
    // Desktop Drawer
    const trigger = document.getElementById('project-trigger');
    const drawer = document.getElementById('project-drawer');
    const close = document.getElementById('close-drawer');

    // Mobile Menu
    const mobileTrigger = document.getElementById('mobile-menu-trigger');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileClose = document.getElementById('close-mobile-menu');
    const mobileProjectTrigger = document.getElementById('mobile-project-trigger');

    const toggleDrawer = (open) => {
      if (open) {
        drawer?.classList.remove('translate-y-[-100%]');
        drawer?.classList.add('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      } else {
        drawer?.classList.add('translate-y-[-100%]');
        drawer?.classList.remove('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = '';
      }
    };

    const toggleMobileMenu = (open) => {
      if (open) {
        mobileMenu?.classList.remove('translate-y-[-100%]');
        mobileMenu?.classList.add('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu?.classList.add('translate-y-[-100%]');
        mobileMenu?.classList.remove('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = '';
      }
    };

    // Event Listeners
    trigger?.addEventListener('click', () => toggleDrawer(true));
    close?.addEventListener('click', () => toggleDrawer(false));
    mobileTrigger?.addEventListener('click', () => toggleMobileMenu(true));
    mobileClose?.addEventListener('click', () => toggleMobileMenu(false));
    mobileProjectTrigger?.addEventListener('click', () => {
      toggleMobileMenu(false);
      setTimeout(() => toggleDrawer(true), 300);
    });

    // Accordion Logic
    const accordionHeaders = document.querySelectorAll('.accordion-header');
    accordionHeaders.forEach(header => {
      header.addEventListener('click', () => {
        const item = header.closest('.accordion-item');
        const content = item.querySelector('.accordion-content');
        const icon = item.querySelector('.accordion-icon');
        const isOpen = content.style.maxHeight && content.style.maxHeight !== '0px';

        // Close all other accordions first
        document.querySelectorAll('.accordion-item').forEach(otherItem => {
          if (otherItem !== item) {
            const otherContent = otherItem.querySelector('.accordion-content');
            const otherIcon = otherItem.querySelector('.accordion-icon');
            if (otherContent) otherContent.style.maxHeight = '0px';
            if (otherIcon) otherIcon.textContent = '+';
          }
        });

        // Toggle active accordion
        if (isOpen) {
          content.style.maxHeight = '0px';
          icon.textContent = '+';
        } else {
          // Scroll height calculation for smooth accordion expansion
          content.style.maxHeight = content.scrollHeight + 'px';
          icon.textContent = '-';
        }
      });
    });

    // Sandbox Toggle Logic
    const sandboxTriggers = document.querySelectorAll('.sandbox-trigger');
    sandboxTriggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation(); // Avoid triggering accordion close/toggle
        const item = trigger.closest('.accordion-item');
        const sandboxContent = item.querySelector('.sandbox-content');
        const accordionContent = item.querySelector('.accordion-content');
        const triggerText = trigger.querySelector('.sandbox-trigger-text');
        const isSandboxOpen = sandboxContent.style.maxHeight && sandboxContent.style.maxHeight !== '0px';

        if (isSandboxOpen) {
          sandboxContent.style.maxHeight = '0px';
          triggerText.textContent = triggerText.textContent.replace('Ocultar', 'Ativar');
          // Re-calculate the accordion wrapper height to reflect collapsed child
          setTimeout(() => {
            accordionContent.style.maxHeight = accordionContent.scrollHeight + 'px';
          }, 300);
        } else {
          sandboxContent.style.maxHeight = sandboxContent.scrollHeight + 1000 + 'px'; // Allow generous padding for sandbox
          triggerText.textContent = triggerText.textContent.replace('Ativar', 'Ocultar');
          // Re-calculate the accordion wrapper height to reflect expanded child
          setTimeout(() => {
            accordionContent.style.maxHeight = accordionContent.scrollHeight + 'px';
          }, 300);
        }
      });
    });
  });
</script>
