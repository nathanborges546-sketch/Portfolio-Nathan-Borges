---
// Navbar Estratégica: Foco em Conversão e Navegação Centralizada
import { Image } from 'astro:assets';
import logoImg from '../assets/logo nathan.png';
---
<nav class="fixed top-0 left-0 w-full z-50 px-8 py-4 flex justify-between items-center bg-darkBg/80 backdrop-blur-xl border-b border-surface/50">
  
  <!-- Lado Esquerdo: Logo (Enlarged) -->
  <div class="flex-1 flex justify-start">
    <a href="/" class="hover:opacity-80 transition-opacity">
      <Image src={logoImg} width={160} alt="Nathan Borges" class="h-16 md:h-20 w-auto invert brightness-0" />
    </a>
  </div>

  <!-- Centro: Navegação Desktop -->
  <div class="flex-1 hidden md:flex justify-center">
    <ul class="flex items-center gap-8">
      <li class="relative group">
        <button id="project-trigger" class="text-textSecondary hover:text-textPrimary transition-colors text-sm font-sora flex items-center gap-2">
          Projetos
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" class="opacity-50 group-hover:rotate-180 transition-transform">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </li>
      <li><a href="/#metodologia" class="text-textSecondary hover:text-textPrimary transition-colors text-sm font-sora">Metodologia</a></li>
      <li><a href="/blog" class="text-textSecondary hover:text-textPrimary transition-colors text-sm font-sora">Blog</a></li>
    </ul>
  </div>

  <!-- Lado Direito: CTA Desktop & Mobile Trigger -->
  <div class="flex-1 flex justify-end items-center gap-4">
    <!-- Desktop CTA -->
    <a href="https://wa.me/5564993335277" target="_blank" rel="noopener noreferrer" class="hidden md:flex font-space text-xs tracking-[0.2em] bg-brandCyan text-textPrimary px-8 py-4 rounded-full hover:brightness-110 transition-all active:scale-95 uppercase font-bold shadow-[0_0_20px_rgba(28,105,183,0.3)]">
      CONVERSAR NO WHATSAPP
    </a>

    <!-- Mobile Burger (Visible only on mobile, right aligned) -->
    <button id="mobile-menu-trigger" aria-label="Abrir menu mobile" class="flex md:hidden text-textPrimary hover:text-brandCyan transition-colors p-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

</nav>

<!-- Mobile Menu (Overlay) -->
<div id="mobile-menu" class="fixed inset-0 z-[55] bg-darkBg translate-y-[-100%] transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] pointer-events-none flex flex-col justify-center items-center md:hidden">
  <button id="close-mobile-menu" aria-label="Fechar menu mobile" class="absolute top-6 right-6 text-textPrimary hover:text-brandCyan transition-colors p-4">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <ul class="flex flex-col items-center gap-10 text-3xl font-sora font-bold">
    <li><a href="/" class="text-textPrimary hover:text-brandCyan transition-colors">Home</a></li>
    <li>
      <button id="mobile-project-trigger" class="text-textPrimary hover:text-brandCyan transition-colors flex items-center gap-3">
        Projetos
      </button>
    </li>
    <li><a href="/#metodologia" class="text-textPrimary hover:text-brandCyan transition-colors">Metodologia</a></li>
    <li><a href="/blog" class="text-textPrimary hover:text-brandCyan transition-colors">Blog</a></li>
    <li>
      <a href="https://wa.me/5564993335277" target="_blank" class="font-space text-lg bg-brandCyan text-textPrimary px-8 py-3 rounded-full">
        WHATSAPP
      </a>
    </li>
  </ul>
</div>

<!-- Gaveta de Projetos (Overlay) -->
<div id="project-drawer" class="fixed inset-0 z-[60] bg-darkBg translate-y-[-100%] transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] pointer-events-none overflow-y-auto scrollbar-thin py-12 md:py-20 flex items-center justify-center">
  <div class="max-w-7xl w-full mx-auto px-6 md:px-12 lg:px-24">
    
    <!-- Cabeçalho Gaveta -->
    <div class="flex justify-between items-center mb-12">
      <h2 class="text-textSecondary font-space text-xs tracking-[0.3em] uppercase mt-2">Eixos de Especialização</h2>
      <button id="close-drawer" aria-label="Fechar gaveta de projetos" class="text-textPrimary hover:text-brandCyan transition-colors p-4 bg-surface rounded-full border border-white/5 cursor-pointer active:scale-95">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- Layout de Duas Colunas Principal -->
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-stretch">
      
      <!-- Coluna da Esquerda: Eixo UX Design (col-span-4) -->
      <div class="lg:col-span-4 flex flex-col justify-center">
        <a href="/ux" class="group flex flex-col items-start p-8 rounded-[32px] bg-surface border border-brandCyan/5 hover:border-brandCyan/20 transition-all h-full justify-between">
          <div class="flex flex-col gap-4">
            <span class="text-blue-400 font-space text-[10px] uppercase tracking-widest">Eixo UX Design</span>
            <h3 class="text-textPrimary text-3xl font-sora font-bold group-hover:text-brandCyan transition-colors">Interfaces & Sistemas</h3>
            <p class="text-textSecondary text-sm leading-relaxed font-sora">Aplicações desenhadas para mitigar a carga cognitiva e anular a fricção do usuário.</p>
          </div>
          <span class="inline-flex items-center text-xs font-space font-bold text-brandCyan group-hover:translate-x-2 transition-transform mt-8">
            EXPLORAR EIXO UX DESIGN <span class="ml-2">→</span>
          </span>
        </a>
      </div>

      <!-- Coluna da Direita: Eixo Automação e Código (col-span-8) -->
      <div class="lg:col-span-8 flex flex-col items-start p-8 rounded-[32px] bg-surface border border-brandCyan/5">
        <div class="mb-6">
          <span class="text-blue-400 font-space text-[10px] uppercase tracking-widest mb-2 block">Eixo Automação e Código</span>
          <h3 class="text-textPrimary text-2xl font-sora font-bold">Arquitetura & Engenharia de IA</h3>
        </div>

        <!-- Sub-layout do Switcher: Botões à esquerda, Detalhes à direita -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 w-full items-start">
          
          <!-- Lado Esquerdo: Stack de Botões de Projetos (col-span-5) -->
          <div class="md:col-span-5 flex flex-col gap-3 w-full">
            <button id="btn-project-crm" class="project-drawer-btn active w-full p-4 rounded-xl text-left font-sora font-bold text-xs transition-all border border-brandCyan bg-brandCyan text-textPrimary cursor-pointer">
              CRM Inteligente
            </button>
            <button id="btn-project-software" class="project-drawer-btn w-full p-4 rounded-xl text-left font-sora font-bold text-xs transition-all border border-white/5 bg-darkBg/40 text-textSecondary hover:text-textPrimary cursor-pointer">
              Criação de Software
            </button>
            <button id="btn-project-data" class="project-drawer-btn w-full p-4 rounded-xl text-left font-sora font-bold text-xs transition-all border border-white/5 bg-darkBg/40 text-textSecondary hover:text-textPrimary cursor-pointer">
              Eficiência de Dados
            </button>
          </div>

          <!-- Lado Direito: Painel de Detalhes do Projeto (col-span-7) -->
          <div class="md:col-span-7 w-full p-5 bg-darkBg/40 border border-white/5 rounded-2xl min-h-[220px] flex items-center">
            
            <!-- Detalhes CRM Inteligente -->
            <div id="detail-project-crm" class="project-drawer-detail transition-all duration-300 opacity-100 scale-100 flex flex-col gap-3 w-full">
              <div class="flex justify-between items-start gap-2">
                <h4 class="text-sm font-sora font-bold text-brandCyan">Sistema de Prospecção Automatizada</h4>
                <div class="flex gap-1">
                  <span class="px-2 py-0.5 bg-surface border border-brandCyan/10 rounded-full text-[8px] font-space text-blue-400">Python</span>
                  <span class="px-2 py-0.5 bg-surface border border-brandCyan/10 rounded-full text-[8px] font-space text-blue-400">Gemini</span>
                </div>
              </div>
              <p class="text-xs text-textSecondary font-sora leading-relaxed">
                <strong class="text-red-400 font-medium">Problema:</strong> Processo de prospecção manual drena tempo comercial e gera falhas de digitação no funil.
              </p>
              <p class="text-xs text-textSecondary font-sora leading-relaxed">
                <strong class="text-brandCyan font-medium">Lógica:</strong> Captura automática de leads ➔ Personalização com IA ➔ Envio direto integrado ao Notion.
              </p>
              <a href="/automations#crm-inteligente" class="inline-flex items-center text-[10px] font-space font-bold text-brandCyan hover:text-white transition-colors mt-2 w-fit group">
                ⚡ VER CASO COMPLETO E SIMULAR <span class="ml-1 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            </div>

            <!-- Detalhes Criação de Software -->
            <div id="detail-project-software" class="project-drawer-detail hidden transition-all duration-300 opacity-0 scale-[0.98] flex flex-col gap-3 w-full">
              <div class="flex justify-between items-start gap-2">
                <h4 class="text-sm font-sora font-bold text-brandCyan">Menu Digital Personalizado</h4>
                <div class="flex gap-1">
                  <span class="px-2 py-0.5 bg-surface border border-brandCyan/10 rounded-full text-[8px] font-space text-blue-400">Node.js</span>
                  <span class="px-2 py-0.5 bg-surface border border-brandCyan/10 rounded-full text-[8px] font-space text-blue-400">APIs</span>
                </div>
              </div>
              <p class="text-xs text-textSecondary font-sora leading-relaxed">
                <strong class="text-red-400 font-medium">Problema:</strong> Atendimento manual em picos de demanda custa até 40% das conversões de reservas no comercial.
              </p>
              <p class="text-xs text-textSecondary font-sora leading-relaxed">
                <strong class="text-brandCyan font-medium">Lógica:</strong> Evolution API via Webhook ➔ Sincronização em banco assíncrono Node.js ➔ Despacho instantâneo do menu.
              </p>
              <a href="/automations#ecossistema-menu" class="inline-flex items-center text-[10px] font-space font-bold text-brandCyan hover:text-white transition-colors mt-2 w-fit group">
                ⚡ VER CASO COMPLETO E SIMULAR <span class="ml-1 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            </div>

            <!-- Detalhes Eficiência de Dados -->
            <div id="detail-project-data" class="project-drawer-detail hidden transition-all duration-300 opacity-0 scale-[0.98] flex flex-col gap-3 w-full">
              <div class="flex justify-between items-start gap-2">
                <h4 class="text-sm font-sora font-bold text-brandCyan">Pipeline de Higienização B2B</h4>
                <div class="flex gap-1">
                  <span class="px-2 py-0.5 bg-surface border border-brandCyan/10 rounded-full text-[8px] font-space text-blue-400">Python</span>
                  <span class="px-2 py-0.5 bg-surface border border-brandCyan/10 rounded-full text-[8px] font-space text-blue-400">Pandas</span>
                </div>
              </div>
              <p class="text-xs text-textSecondary font-sora leading-relaxed">
                <strong class="text-red-400 font-medium">Problema:</strong> Bases brutas duplicadas, com nulos e formatação bagunçada quebram pipelines comerciais e de marketing.
              </p>
              <p class="text-xs text-textSecondary font-sora leading-relaxed">
                <strong class="text-brandCyan font-medium">Lógica:</strong> Ingestão de bases xlsx/csv ➔ Fuzzy Matching e Pandas de higienização de nulos ➔ Carga limpa no banco.
              </p>
              <a href="/automations#purifier-engine" class="inline-flex items-center text-[10px] font-space font-bold text-brandCyan hover:text-white transition-colors mt-2 w-fit group">
                ⚡ VER CASO COMPLETO E SIMULAR <span class="ml-1 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    // Desktop Drawer
    const trigger = document.getElementById('project-trigger');
    const drawer = document.getElementById('project-drawer');
    const close = document.getElementById('close-drawer');

    // Mobile Menu
    const mobileTrigger = document.getElementById('mobile-menu-trigger');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileClose = document.getElementById('close-mobile-menu');
    const mobileProjectTrigger = document.getElementById('mobile-project-trigger');

    const toggleDrawer = (open) => {
      if (open) {
        drawer?.classList.remove('translate-y-[-100%]');
        drawer?.classList.add('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      } else {
        drawer?.classList.add('translate-y-[-100%]');
        drawer?.classList.remove('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = '';
      }
    };

    const toggleMobileMenu = (open) => {
      if (open) {
        mobileMenu?.classList.remove('translate-y-[-100%]');
        mobileMenu?.classList.add('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu?.classList.add('translate-y-[-100%]');
        mobileMenu?.classList.remove('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = '';
      }
    };

    // Event Listeners
    trigger?.addEventListener('click', () => toggleDrawer(true));
    close?.addEventListener('click', () => toggleDrawer(false));
    mobileTrigger?.addEventListener('click', () => toggleMobileMenu(true));
    mobileClose?.addEventListener('click', () => toggleMobileMenu(false));
    mobileProjectTrigger?.addEventListener('click', () => {
      toggleMobileMenu(false);
      setTimeout(() => toggleDrawer(true), 300);
    });

    // Drawer Project Switcher Logic
    const btnCrm = document.getElementById('btn-project-crm');
    const btnSoftware = document.getElementById('btn-project-software');
    const btnData = document.getElementById('btn-project-data');

    const detailCrm = document.getElementById('detail-project-crm');
    const detailSoftware = document.getElementById('detail-project-software');
    const detailData = document.getElementById('detail-project-data');

    const allButtons = [btnCrm, btnSoftware, btnData];
    const allDetails = [detailCrm, detailSoftware, detailData];

    const selectProject = (activeBtn, activeDetail) => {
      // Toggle button styles
      allButtons.forEach(btn => {
        if (btn === activeBtn) {
          btn?.classList.add('border-brandCyan', 'bg-brandCyan', 'text-textPrimary');
          btn?.classList.remove('border-white/5', 'bg-darkBg/40', 'text-textSecondary', 'hover:text-textPrimary');
        } else {
          btn?.classList.remove('border-brandCyan', 'bg-brandCyan', 'text-textPrimary');
          btn?.classList.add('border-white/5', 'bg-darkBg/40', 'text-textSecondary', 'hover:text-textPrimary');
        }
      });

      // Toggle details panels
      allDetails.forEach(detail => {
        if (detail === activeDetail) {
          detail?.classList.remove('hidden');
          setTimeout(() => {
            detail?.classList.remove('opacity-0', 'scale-[0.98]');
            detail?.classList.add('opacity-100', 'scale-100');
          }, 50);
        } else {
          detail?.classList.add('hidden');
          detail?.classList.remove('opacity-100', 'scale-100');
          detail?.classList.add('opacity-0', 'scale-[0.98]');
        }
      });
    };

    btnCrm?.addEventListener('click', () => selectProject(btnCrm, detailCrm));
    btnSoftware?.addEventListener('click', () => selectProject(btnSoftware, detailSoftware));
    btnData?.addEventListener('click', () => selectProject(btnData, detailData));
  });
</script>
