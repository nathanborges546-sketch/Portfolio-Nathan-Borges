---
// Navbar Estratégica: Foco em Conversão e Navegação Centralizada
---
<nav class="fixed top-0 left-0 w-full z-50 px-8 py-4 flex justify-between items-center bg-darkBg/80 backdrop-blur-xl border-b border-surface/50">
  
  <!-- Lado Esquerdo: Logo (Enlarged) -->
  <div class="flex-1 flex justify-start">
    <a href="/" class="hover:opacity-80 transition-opacity">
      <img src="/logo.png" width="160" height="80" alt="Nathan Borges" class="h-16 md:h-20 w-auto invert brightness-0" />
    </a>
  </div>

  <!-- Centro: Navegação Desktop -->
  <div class="flex-1 hidden md:flex justify-center">
    <ul class="flex items-center gap-8">
      <li class="relative group">
        <button id="project-trigger" class="text-textSecondary hover:text-textPrimary transition-colors text-sm font-sora flex items-center gap-2">
          Projetos
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" class="opacity-50 group-hover:rotate-180 transition-transform">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </li>
      <li><a href="/#metodologia" class="text-textSecondary hover:text-textPrimary transition-colors text-sm font-sora">Metodologia</a></li>
      <li><a href="/blog" class="text-textSecondary hover:text-textPrimary transition-colors text-sm font-sora">Blog</a></li>
    </ul>
  </div>

  <!-- Lado Direito: CTA Desktop & Mobile Trigger -->
  <div class="flex-1 flex justify-end items-center gap-4">
    <!-- Desktop CTA -->
    <a href="https://wa.me/5564993335277" target="_blank" rel="noopener noreferrer" class="hidden md:flex font-space text-xs tracking-[0.2em] bg-brandCyan text-textPrimary px-8 py-4 rounded-full hover:brightness-110 transition-all active:scale-95 uppercase font-bold shadow-[0_0_20px_rgba(28,105,183,0.3)]">
      CONVERSAR NO WHATSAPP
    </a>

    <!-- Mobile Burger (Visible only on mobile, right aligned) -->
    <button id="mobile-menu-trigger" aria-label="Abrir menu mobile" class="flex md:hidden text-textPrimary hover:text-brandCyan transition-colors p-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

</nav>

<!-- Mobile Menu (Overlay) -->
<div id="mobile-menu" class="fixed inset-0 z-[55] bg-darkBg translate-y-[-100%] transition-transform duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] pointer-events-none flex flex-col justify-center items-center md:hidden">
  <button id="close-mobile-menu" aria-label="Fechar menu mobile" class="absolute top-6 right-6 text-textPrimary hover:text-brandCyan transition-colors p-4">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <ul class="flex flex-col items-center gap-10 text-3xl font-sora font-bold">
    <li><a href="/" class="text-textPrimary hover:text-brandCyan transition-colors">Home</a></li>
    <li>
      <button id="mobile-project-trigger" class="text-textPrimary hover:text-brandCyan transition-colors flex items-center gap-3">
        Projetos
      </button>
    </li>
    <li><a href="/#metodologia" class="text-textPrimary hover:text-brandCyan transition-colors">Metodologia</a></li>
    <li><a href="/blog" class="text-textPrimary hover:text-brandCyan transition-colors">Blog</a></li>
    <li>
      <a href="https://wa.me/5564993335277" target="_blank" class="font-space text-lg bg-brandCyan text-textPrimary px-8 py-3 rounded-full">
        WHATSAPP
      </a>
    </li>
  </ul>
</div>

<!-- Gaveta de Projetos (Overlay) -->
<div id="project-drawer" class="fixed inset-0 z-[60] bg-darkBg translate-y-[-100%] transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] pointer-events-none overflow-hidden">
  <div class="h-full flex flex-col justify-center px-8 md:px-20 lg:px-40">
    <div class="flex justify-between items-start mb-12">
      <h2 class="text-textSecondary font-space text-xs tracking-[0.3em] uppercase mt-4">Eixos de Especialização</h2>
      <button id="close-drawer" aria-label="Fechar gaveta de projetos" class="text-textPrimary hover:text-brandCyan transition-colors p-4">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <a href="/ux" class="group flex flex-col items-start p-8 rounded-[32px] bg-surface border border-brandCyan/5 hover:border-brandCyan/20 transition-all">
        <span class="text-blue-400 font-space text-[10px] uppercase tracking-widest mb-4">Eixo UX Design</span>
        <h3 class="text-textPrimary text-3xl md:text-4xl font-sora font-bold mb-4 group-hover:text-brandCyan transition-colors">Interfaces & Sistemas</h3>
        <p class="text-textSecondary text-sm md:text-base leading-relaxed font-sora">Aplicações desenhadas para mitigar a carga cognitiva e anular a fricção do usuário.</p>
      </a>

      <a href="/automations" class="group flex flex-col items-start p-8 rounded-[32px] bg-surface border border-brandCyan/5 hover:border-brandCyan/20 transition-all">
        <span class="text-blue-400 font-space text-[10px] uppercase tracking-widest mb-4">Eixo Automação & IA</span>
        <h3 class="text-textPrimary text-3xl md:text-4xl font-sora font-bold mb-4 group-hover:text-brandCyan transition-colors">Arquitetura & Engenharia de IA</h3>
        <p class="text-textSecondary text-sm md:text-base leading-relaxed font-sora">Pipelines de dados autônomos e microsserviços resilientes em Python e Node.js.</p>
      </a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    // Desktop Drawer
    const trigger = document.getElementById('project-trigger');
    const drawer = document.getElementById('project-drawer');
    const close = document.getElementById('close-drawer');

    // Mobile Menu
    const mobileTrigger = document.getElementById('mobile-menu-trigger');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileClose = document.getElementById('close-mobile-menu');
    const mobileProjectTrigger = document.getElementById('mobile-project-trigger');

    const toggleDrawer = (open) => {
      if (open) {
        drawer?.classList.remove('translate-y-[-100%]');
        drawer?.classList.add('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      } else {
        drawer?.classList.add('translate-y-[-100%]');
        drawer?.classList.remove('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = '';
      }
    };

    const toggleMobileMenu = (open) => {
      if (open) {
        mobileMenu?.classList.remove('translate-y-[-100%]');
        mobileMenu?.classList.add('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu?.classList.add('translate-y-[-100%]');
        mobileMenu?.classList.remove('translate-y-0', 'pointer-events-auto');
        document.body.style.overflow = '';
      }
    };

    // Event Listeners
    trigger?.addEventListener('click', () => toggleDrawer(true));
    close?.addEventListener('click', () => toggleDrawer(false));
    mobileTrigger?.addEventListener('click', () => toggleMobileMenu(true));
    mobileClose?.addEventListener('click', () => toggleMobileMenu(false));
    mobileProjectTrigger?.addEventListener('click', () => {
      toggleMobileMenu(false);
      setTimeout(() => toggleDrawer(true), 300);
    });
  });
</script>
