---
// Componente de Tabs (Switcher) + Bento Grid - Versão Engenharia Aplicada
const automationsCases = [
  {
    title: "Sistema de Prospecção Automatizada e Extração de Dados",
    metric: "CRM Inteligente",
    desc: "Redução de 90% do ciclo de captação e prospecção B2B, através da automação da extração e preenchimento dos leads na base de dados e posteriormente o envio automático das mensagens via API.",
    tags: ["Python", "Streamlit", "Meta API", "Notion API"],
    link: "/nxt-os"
  },
  {
    title: "Menu Digital Personalizado",
    metric: "Criação de Software",
    desc: "Personalização de atendimento ao cliente para Moskato Camping - Albânia - Himarë.",
    tags: ["Node.js", "Webhooks", "REST APIs"],
    link: "/real-time"
  },
  {
    title: "Pipeline de Higienização de Dados B2B",
    metric: "Eficiência de Dados",
    desc: "Automação inteligente que limpa bases de dados confusas, corrige informações nulas e elimina duplicadas instantaneamente.",
    tags: ["Python", "Pandas", "Data Science"],
    link: "/clean-data"
  }
];

const uxCases = [
  {
    title: "Dashboard Analítico para Gestão de Dados de IA",
    metric: "Carga Cognitiva Mínima",
    desc: "Design de interface complexa focado em tomadores de decisão. Simplificação de 500+ data points diários.",
    tags: ["Figma", "Design System", "User Flows"],
    span: "md:col-span-2 md:row-span-2",
  },
  {
    title: "Redesign de Checkout e Fluxo de Entrada B2B",
    metric: "Zona do Polegar",
    desc: "Arquitetura de informação mobile-first e microcopy colaborativo para mitigação de erros humanos.",
    tags: ["UX Writing", "Heurísticas", "Prototipagem"],
    span: "md:col-span-1 md:row-span-1",
  }
];
---

<section id="projetos" class="py-32 px-6 md:px-12 bg-darkBg overflow-hidden">
  <div class="max-w-7xl mx-auto">
    
    <!-- Header e Tabs -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
      <div>
        <h2 class="text-textSecondary font-space text-xs tracking-[0.3em] uppercase mb-4">Portfólio Técnico</h2>
        <h3 class="text-3xl md:text-5xl font-sora font-bold text-textPrimary tracking-tight mb-4">Engenharia Aplicada</h3>
        <p class="text-textSecondary text-lg font-sora">Projetos que unem validação de dados, performance algorítmica e usabilidade.</p>
      </div>

      <div class="flex flex-wrap items-center gap-6 self-start md:self-auto">
        <div class="inline-flex p-1 bg-surface border border-brandCyan/10 rounded-full font-space">
          <button id="tab-auto" class="tab-btn active px-6 md:px-8 py-3 rounded-full text-xs md:text-sm font-medium transition-all text-white bg-brandCyan">
            AUTOMAÇÕES & CÓDIGO
          </button>
          <button id="tab-ux" class="tab-btn px-6 md:px-8 py-3 rounded-full text-xs md:text-sm font-medium transition-all text-textSecondary hover:text-textPrimary">
            UX & PRODUCT DESIGN
          </button>
        </div>
      </div>
    </div>

    <!-- Bento Grid / Carousel Container -->
    <div class="grid relative w-full max-w-full">
      
      <!-- Grid Automações: Carrossel Horizontal Dinâmico de Card Único -->
      <div id="grid-auto" class="[grid-area:1/1] w-full max-w-full relative transition-all duration-500 opacity-100 pointer-events-auto group/carousel">
        
        <!-- Carousel Nav Controls (Setas minimalistas nas laterais, flutuando verticalmente ao meio - Apenas Desktop) -->
        <button id="btn-carousel-prev" class="absolute -left-6 top-1/2 -translate-y-1/2 z-30 w-12 h-12 rounded-full bg-[#161b22]/90 backdrop-blur-sm border border-white/10 md:flex hidden items-center justify-center text-textSecondary hover:text-white hover:border-white/30 hover:bg-[#0b0e14] transition-all cursor-pointer active:scale-95 shadow-xl">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button id="btn-carousel-next" class="absolute -right-6 top-1/2 -translate-y-1/2 z-30 w-12 h-12 rounded-full bg-[#161b22]/90 backdrop-blur-sm border border-white/10 md:flex hidden items-center justify-center text-textSecondary hover:text-white hover:border-white/30 hover:bg-[#0b0e14] transition-all cursor-pointer active:scale-95 shadow-xl">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <!-- Carousel Track Window -->
        <div class="w-full overflow-hidden rounded-[36px] border border-brandCyan/5 bg-surface">
          <div id="carousel-track" class="flex flex-row w-full transition-transform duration-500 ease-[cubic-bezier(0.25,1,0.5,1)]">
            
            {automationsCases.map((c, index) => {
              const isActive = index === 0;
              return (
                <div 
                  data-slide-index={index}
                  class={`w-full shrink-0 flex flex-col md:flex-row gap-8 md:gap-12 p-6 md:p-12 transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] ${isActive ? 'opacity-100 scale-100' : 'opacity-20 scale-[0.98]'}`}
                >
                  <!-- Lado Esquerdo: Conteúdo Comercial -->
                  <div class="flex-1 flex flex-col justify-between gap-6">
                    <div class="flex flex-col gap-4">
                      <span class="font-space text-3xl md:text-5xl text-brandCyan font-bold tracking-tight">{c.metric}</span>
                      <h4 class="text-xl md:text-3xl font-sora font-bold text-textPrimary tracking-tight">{c.title}</h4>
                      <p class="text-textSecondary text-sm md:text-base leading-relaxed font-sora max-w-xl">{c.desc}</p>
                    </div>

                    <div>
                      <div class="flex flex-wrap gap-2 mb-8">
                        {c.tags.map(tag => (
                          <span class="px-3 py-1 bg-darkBg border border-brandCyan/10 rounded-full text-[9px] md:text-[10px] font-space text-blue-400">{tag}</span>
                        ))}
                      </div>
                      {c.link && (
                        <a 
                          href={c.link} 
                          class="inline-flex items-center justify-center px-6 py-3.5 md:px-8 md:py-4 bg-[#00f2fe] text-[#0b0e14] font-space font-bold rounded-xl hover:bg-white hover:text-[#0b0e14] transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_0_30px_rgba(0,242,254,0.45)] active:scale-95 uppercase tracking-wider text-xs w-fit group"
                        >
                          Abrir Simulador Interativo 
                          <span class="ml-2 group-hover:translate-x-1 transition-transform font-bold text-sm">→</span>
                        </a>
                      )}
                    </div>
                  </div>

                  <!-- Lado Direito: Preview Decorativo/Gráfico Premium -->
                  <div class="hidden md:flex flex-1 items-center justify-center relative overflow-hidden bg-darkBg/30 border border-white/5 rounded-2xl p-8">
                    <!-- Grid background -->
                    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff03_1px,transparent_1px),linear-gradient(to_bottom,#ffffff03_1px,transparent_1px)] bg-[size:16px_16px]"></div>
                    
                    <!-- UI Mocks correspondentes a cada projeto -->
                    {index === 0 && (
                      <div class="relative w-full max-w-[280px] aspect-[4/3] bg-surface/50 border border-white/5 rounded-2xl p-5 shadow-2xl flex flex-col justify-between">
                        <div class="flex justify-between items-center pb-3 border-b border-white/5">
                          <span class="text-[9px] font-space text-textSecondary uppercase tracking-widest font-bold">Evolution API Sync</span>
                          <span class="w-2 h-2 rounded-full bg-[#00f2fe] animate-pulse"></span>
                        </div>
                        <div class="flex flex-col gap-2 my-3">
                          <div class="h-1.5 w-2/3 bg-white/5 rounded"></div>
                          <div class="h-1.5 w-5/6 bg-white/5 rounded"></div>
                          <div class="h-1.5 w-1/2 bg-white/5 rounded"></div>
                        </div>
                        <div class="flex justify-between items-center text-[10px]">
                          <span class="text-textSecondary">Sincronização</span>
                          <span class="text-[#00f2fe] font-bold">100% Ativa</span>
                        </div>
                      </div>
                    )}

                    {index === 1 && (
                      <div class="relative w-full max-w-[280px] aspect-[4/3] bg-surface/50 border border-white/5 rounded-2xl p-5 shadow-2xl flex flex-col justify-between">
                        <div class="flex justify-between items-center pb-3 border-b border-white/5">
                          <span class="text-[9px] font-space text-textSecondary uppercase tracking-widest font-bold">Moskato Server</span>
                          <span class="text-[9px] text-[#00f2fe] font-bold">Local</span>
                        </div>
                        <div class="flex flex-col gap-2.5 my-3">
                          <div class="flex justify-between text-[10px]">
                            <span class="text-textSecondary">Albânia - Himarë</span>
                            <span class="text-textPrimary font-semibold">Online</span>
                          </div>
                          <div class="h-1.5 w-full bg-white/5 rounded"></div>
                          <div class="h-1.5 w-3/4 bg-white/5 rounded"></div>
                        </div>
                        <div class="text-[10px] text-textSecondary font-space">
                          Status: <span class="text-[#00f2fe] font-bold">100% Offline-First</span>
                        </div>
                      </div>
                    )}

                    {index === 2 && (
                      <div class="relative w-full max-w-[280px] aspect-[4/3] bg-surface/50 border border-white/5 rounded-2xl p-5 shadow-2xl flex flex-col justify-between">
                        <div class="flex justify-between items-center pb-3 border-b border-white/5">
                          <span class="text-[9px] font-space text-textSecondary uppercase tracking-widest font-bold">Data Purifier Engine</span>
                          <span class="text-[9px] text-[#00f2fe] font-bold">Python</span>
                        </div>
                        <div class="flex flex-col gap-2 my-3">
                          <div class="flex justify-between text-[10px]">
                            <span class="text-textSecondary">Registros Limpos</span>
                            <span class="text-textPrimary font-semibold">+1,204</span>
                          </div>
                          <div class="flex justify-between text-[10px]">
                            <span class="text-textSecondary">Duplicatas Resolvidas</span>
                            <span class="text-textPrimary font-semibold">100%</span>
                          </div>
                        </div>
                        <div class="flex justify-between items-center text-[10px]">
                          <span class="text-textSecondary">Eficiência</span>
                          <span class="text-[#00f2fe] font-bold">100% Puro</span>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              );
            })}

          </div>
        </div>

        <!-- Mobile Navigation Controls (Visível apenas no mobile, abaixo do card) -->
        <div class="flex md:hidden justify-center items-center gap-6 mt-6">
          <button id="btn-carousel-prev-mobile" class="w-10 h-10 rounded-full bg-[#161b22] border border-white/5 flex items-center justify-center text-textSecondary active:scale-95 cursor-pointer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <span id="carousel-indicator-mobile" class="text-xs font-space text-textSecondary tracking-widest font-bold">1 / 3</span>
          <button id="btn-carousel-next-mobile" class="w-10 h-10 rounded-full bg-[#161b22] border border-white/5 flex items-center justify-center text-textSecondary active:scale-95 cursor-pointer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

      </div>

      <!-- Grid UX: Mantém o layout bento tradicional para UX -->
      <div id="grid-ux" class="[grid-area:1/1] grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-500 opacity-0 pointer-events-none translate-y-4">
        {uxCases.map(c => (
          <div class={`group relative bg-surface rounded-[32px] p-8 border border-brandCyan/5 hover:border-brandCyan/30 transition-all duration-300 overflow-hidden flex flex-col justify-between ${c.span}`}>
            <div class="z-10">
              <p class="font-space text-2xl md:text-3xl text-brandCyan font-bold mb-6 uppercase tracking-tight">{c.metric}</p>
              <h4 class="text-xl md:text-2xl font-sora font-bold text-textPrimary mb-4">{c.title}</h4>
              <p class="text-textSecondary text-sm leading-relaxed mb-8 font-sora">{c.desc}</p>
            </div>

            <div class="z-10">
              <div class="flex flex-wrap gap-2">
                {c.tags.map(tag => (
                  <span class="px-3 py-1 bg-darkBg border border-brandCyan/10 rounded-full text-[10px] font-space text-blue-400">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- CTA de Conversão Técnica pós-projetos -->
    <div class="mt-20 flex flex-col items-center gap-6 opacity-0 animate-fade-in-up [animation-delay:600ms]">
      <p class="text-textSecondary font-sora text-sm">Gostou da abordagem técnica? Vamos aprofundar no seu projeto.</p>
      <button onclick="Calendly.initPopupWidget({url: 'https://calendly.com/nathanborges546/30min'});return false;" class="inline-flex items-center justify-center px-10 py-4 border border-blue-400 text-blue-400 font-space font-bold rounded-full hover:bg-brandCyan hover:text-white transition-all hover:scale-105 active:scale-95 uppercase tracking-widest text-xs">
        AGENDAR PAPO TÉCNICO
      </button>
    </div>

  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    // Outer Tab Switching (Automations vs UX)
    const tabAuto = document.getElementById('tab-auto');
    const tabUx = document.getElementById('tab-ux');
    const gridAuto = document.getElementById('grid-auto');
    const gridUx = document.getElementById('grid-ux');

    const switchTab = (activeTab) => {
      if (activeTab === 'auto') {
        tabAuto?.classList.add('bg-brandCyan', 'text-white');
        tabAuto?.classList.remove('text-textSecondary');
        tabUx?.classList.remove('bg-brandCyan', 'text-white');
        tabUx?.classList.add('text-textSecondary');

        gridAuto?.classList.replace('opacity-0', 'opacity-100');
        gridAuto?.classList.replace('pointer-events-none', 'pointer-events-auto');
        gridAuto?.classList.remove('translate-y-4');
        gridUx?.classList.replace('opacity-100', 'opacity-0');
        gridUx?.classList.replace('pointer-events-auto', 'pointer-events-none');
        gridUx?.classList.add('translate-y-4');
      } else {
        tabUx?.classList.add('bg-brandCyan', 'text-white');
        tabUx?.classList.remove('text-textSecondary');
        tabAuto?.classList.remove('bg-brandCyan', 'text-white');
        tabAuto?.classList.add('text-textSecondary');

        gridUx?.classList.replace('opacity-0', 'opacity-100');
        gridUx?.classList.replace('pointer-events-none', 'pointer-events-auto');
        gridUx?.classList.remove('translate-y-4');
        gridAuto?.classList.replace('opacity-100', 'opacity-0');
        gridAuto?.classList.replace('pointer-events-auto', 'pointer-events-none');
        gridAuto?.classList.add('translate-y-4');
      }
    };

    tabAuto?.addEventListener('click', () => switchTab('auto'));
    tabUx?.addEventListener('click', () => switchTab('ux'));

    // Carousel Auto cases state
    let activeCarouselIndex = 0;
    const slidesAuto = document.querySelectorAll('[data-slide-index]');
    const totalSlides = slidesAuto.length;
    const btnCarouselPrev = document.getElementById('btn-carousel-prev');
    const btnCarouselNext = document.getElementById('btn-carousel-next');
    const btnCarouselPrevMobile = document.getElementById('btn-carousel-prev-mobile');
    const btnCarouselNextMobile = document.getElementById('btn-carousel-next-mobile');
    const carouselIndicatorMobile = document.getElementById('carousel-indicator-mobile');
    const carouselTrack = document.getElementById('carousel-track');

    const renderCarousel = () => {
      // Shift track wrapper via horizontal percentage
      if (carouselTrack) {
        carouselTrack.style.transform = `translateX(-${activeCarouselIndex * 100}%)`;
      }

      // Add fade and scale micro transitions to the slides
      slidesAuto.forEach((slide, idx) => {
        if (idx === activeCarouselIndex) {
          slide.classList.remove('opacity-20', 'scale-[0.98]');
          slide.classList.add('opacity-100', 'scale-100');
        } else {
          slide.classList.remove('opacity-100', 'scale-100');
          slide.classList.add('opacity-20', 'scale-[0.98]');
        }
      });

      // Update mobile pagination text
      if (carouselIndicatorMobile) {
        carouselIndicatorMobile.textContent = `${activeCarouselIndex + 1} / ${totalSlides}`;
      }
    };

    const handlePrev = () => {
      activeCarouselIndex = (activeCarouselIndex - 1 + totalSlides) % totalSlides;
      renderCarousel();
    };

    const handleNext = () => {
      activeCarouselIndex = (activeCarouselIndex + 1) % totalSlides;
      renderCarousel();
    };

    btnCarouselPrev?.addEventListener('click', handlePrev);
    btnCarouselNext?.addEventListener('click', handleNext);
    btnCarouselPrevMobile?.addEventListener('click', handlePrev);
    btnCarouselNextMobile?.addEventListener('click', handleNext);
  });
</script>
