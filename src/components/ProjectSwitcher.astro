---
// Componente de Tabs (Switcher) + Bento Grid
const automationsCases = [
  {
    tag: "CASE 01",
    metric: "10h → 1h 05min",
    title: "Sistema de Prospecção de Alta Performance",
    desc: "Redução radical em pipelines comerciais. Extração inteligente e disparo seguro via Meta API.",
    tags: ["Python", "Streamlit", "Meta API"],
    span: "md:col-span-2 md:row-span-2",
  },
  {
    tag: "CASE 02",
    metric: "",
    title: "Integração B2B de Fluxo de Caixa",
    desc: "Sincronização em tempo real e arquitetura de dados resiliente para operação local em Himarë.",
    tags: ["Node.js", "Webhooks", "APIs"],
    span: "md:col-span-1 md:row-span-1",
  },
  {
    tag: "CASE 03",
    metric: "",
    title: "Purificação Automatizada de Leads",
    desc: "Script avançado de data cleansing para bases de dados exaustas, recuperando o CTR de campanhas corporativas.",
    tags: ["Pandas", "Regex"],
    span: "md:col-span-1 md:row-span-1",
  }
];

const uxCases = [
  {
    tag: "CASE 01",
    metric: "500+ Dados",
    title: "Dashboard de Gestão de Dados IA",
    desc: "Simplificação de data points diários para tomadores de decisão, focada em mitigar o estresse visual e a carga cognitiva.",
    tags: ["Figma", "Design System"],
    span: "md:col-span-2 md:row-span-2",
  },
  {
    tag: "CASE 02",
    metric: "",
    title: "Redesign de Checkout Conversivo",
    desc: "Otimização de CRO baseada em heurísticas e microcopy colaborativo para anular erros humanos e abandono de carrinho.",
    tags: ["UX Writing", "Heurísticas"],
    span: "md:col-span-1 md:row-span-1",
  },
  {
    tag: "CASE 03",
    metric: "",
    title: "Prototipagem de Ferramenta Interna",
    desc: "Interface sob medida para CRM customizado, otimizando a zona do polegar (Mobile-First) e a produtividade da equipe.",
    tags: ["Wireframing", "User Flows"],
    span: "md:col-span-1 md:row-span-1",
  }
];
---

<section id="projetos" class="py-32 px-6 md:px-20 lg:px-40 bg-darkBg">
  <div class="max-w-7xl mx-auto">
    
    <!-- Header e Tabs -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
      <div>
        <h2 class="text-3xl md:text-5xl font-sora font-bold text-textPrimary tracking-tight mb-4">O Ecossistema de Soluções</h2>
        <p class="text-textSecondary text-lg font-sora max-w-2xl">Alterne entre os eixos para entender como traduzo psicologia comportamental e código robusto em eficiência previsível.</p>
      </div>

      <div class="inline-flex p-1 bg-surface border border-white/5 rounded-xl md:rounded-full">
        <button id="tab-auto" class="tab-btn active px-6 md:px-8 py-3 rounded-lg md:rounded-full text-sm font-space font-medium transition-all text-darkBg bg-textPrimary">
          [ Automações & IA ]
        </button>
        <button id="tab-ux" class="tab-btn px-6 md:px-8 py-3 rounded-lg md:rounded-full text-sm font-space font-medium transition-all text-textSecondary hover:text-textPrimary">
          [ UX Design ]
        </button>
      </div>
    </div>

    <!-- Bento Grid Container -->
    <div class="relative min-h-[800px] md:min-h-[600px]">
      
      <!-- Grid Automações -->
      <div id="grid-auto" class="absolute inset-0 grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-6 transition-all duration-500 opacity-100 pointer-events-auto">
        {automationsCases.map(c => (
          <div class={`group relative bg-surface rounded-[24px] p-8 border border-white/5 hover:border-brandCyan/30 hover:bg-[#1a202a] transition-all duration-300 overflow-hidden flex flex-col justify-between ${c.span}`}>
            <div class="flex justify-between items-start w-full mb-8">
               <span class="font-space text-xs text-brandCyan tracking-widest">{c.tag}</span>
               <div class="p-2 opacity-0 group-hover:opacity-100 transition-opacity">
                 <svg class="w-6 h-6 text-brandCyan rotate-45 group-hover:rotate-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
               </div>
            </div>
            
            {c.metric && (
               <div class="mb-auto">
                 <h2 class="font-space font-bold text-4xl md:text-5xl lg:text-6xl text-textPrimary tracking-tighter mb-4">{c.metric}</h2>
               </div>
            )}

            <div class="mt-auto">
              <h3 class="text-xl md:text-2xl font-sora font-medium text-textPrimary mb-3 group-hover:text-brandCyan transition-colors">{c.title}</h3>
              <p class="text-textSecondary text-sm leading-relaxed mb-6 font-sora">{c.desc}</p>
              
              <div class="flex flex-wrap gap-2 mt-auto">
                {c.tags.map(tag => (
                  <span class="px-3 py-1.5 bg-darkBg border border-white/5 rounded-md text-[11px] font-space text-brandCyan/80 tracking-wide uppercase">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Grid UX -->
      <div id="grid-ux" class="absolute inset-0 grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-6 transition-all duration-500 opacity-0 pointer-events-none translate-y-4">
        {uxCases.map(c => (
          <div class={`group relative bg-surface rounded-[24px] p-8 border border-white/5 hover:border-white/20 hover:bg-[#1a202a] transition-all duration-300 overflow-hidden flex flex-col justify-between ${c.span}`}>
            <div class="flex justify-between items-start w-full mb-8">
               <span class="font-space text-xs text-textSecondary tracking-widest">{c.tag}</span>
               <div class="p-2 opacity-0 group-hover:opacity-100 transition-opacity">
                 <svg class="w-6 h-6 text-textPrimary rotate-45 group-hover:rotate-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
               </div>
            </div>

            {c.metric && (
               <div class="mb-auto">
                 <h2 class="font-space font-bold text-4xl md:text-5xl lg:text-6xl text-textPrimary tracking-tighter mb-4">{c.metric}</h2>
               </div>
            )}

            <div class="mt-auto">
              <h3 class="text-xl md:text-2xl font-sora font-medium text-textPrimary mb-3">{c.title}</h3>
              <p class="text-textSecondary text-sm leading-relaxed mb-6 font-sora">{c.desc}</p>
              
              <div class="flex flex-wrap gap-2 mt-auto">
                {c.tags.map(tag => (
                  <span class="px-3 py-1.5 bg-darkBg border border-white/5 rounded-md text-[11px] font-space text-textSecondary tracking-wide uppercase">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const tabAuto = document.getElementById('tab-auto');
    const tabUx = document.getElementById('tab-ux');
    const gridAuto = document.getElementById('grid-auto');
    const gridUx = document.getElementById('grid-ux');

    const switchTab = (activeTab) => {
      const isAuto = activeTab === 'auto';
      
      // Estilos das Tabs
      tabAuto?.classList.toggle('text-darkBg', isAuto);
      tabAuto?.classList.toggle('bg-textPrimary', isAuto);
      tabAuto?.classList.toggle('text-textSecondary', !isAuto);
      tabAuto?.classList.toggle('hover:text-textPrimary', !isAuto);

      tabUx?.classList.toggle('text-darkBg', !isAuto);
      tabUx?.classList.toggle('bg-textPrimary', !isAuto);
      tabUx?.classList.toggle('text-textSecondary', isAuto);
      tabUx?.classList.toggle('hover:text-textPrimary', isAuto);

      // Visibilidade dos Grids
      gridAuto?.classList.toggle('opacity-100', isAuto);
      gridAuto?.classList.toggle('opacity-0', !isAuto);
      gridAuto?.classList.toggle('pointer-events-auto', isAuto);
      gridAuto?.classList.toggle('pointer-events-none', !isAuto);
      gridAuto?.classList.toggle('translate-y-4', !isAuto);

      gridUx?.classList.toggle('opacity-100', !isAuto);
      gridUx?.classList.toggle('opacity-0', isAuto);
      gridUx?.classList.toggle('pointer-events-auto', !isAuto);
      gridUx?.classList.toggle('pointer-events-none', isAuto);
      gridUx?.classList.toggle('translate-y-4', isAuto);
    };

    tabAuto?.addEventListener('click', () => switchTab('auto'));
    tabUx?.addEventListener('click', () => switchTab('ux'));
  });
</script>
