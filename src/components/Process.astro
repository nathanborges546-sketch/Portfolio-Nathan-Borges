---
// Seção Metodologia - Como agrego valor ao time (Squad Focus)
const steps = [
  {
    title: "Imersão & Diagnóstico",
    desc: "Analiso os gargalos do produto e a dor real do usuário final. Código sem contexto gera desperdício de stack.",
  },
  {
    title: "Arquitetura & Design de Fricção Zero",
    desc: "Desenho a topologia do sistema e os protótipos de interface, garantindo validação de escopo antes da primeira linha de código.",
  },
  {
    title: "Desenvolvimento Limpo & Integração",
    desc: "Implemento a solução com foco em performance (INP < 200ms), modularidade e documentação clara para o restante do time de engenharia.",
  },
  {
    title: "Evolução & Blindagem (GEO)",
    desc: "Monitoro a integridade das APIs e a adaptabilidade do conteúdo para os novos motores de busca generativos, garantindo que o sistema nunca fique obsoleto.",
  }
];
---
<section id="metodologia" class="py-32 px-6 md:px-20 lg:px-40 bg-darkBg border-t border-surface/30">
  <div class="max-w-7xl mx-auto">
    <div class="mb-24">
      <h2 class="text-3xl md:text-5xl font-sora font-bold text-textPrimary tracking-tight mb-6">Como eu agrego valor ao time</h2>
      <p class="text-textSecondary text-lg max-w-2xl font-sora">
        Minha abordagem de desenvolvimento segue um ciclo previsível, limpo e focado em engenharia Human-First.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      {steps.map((step, index) => (
        <div class="flex flex-col relative group">
          <span class="text-brandCyan/10 font-space text-8xl font-bold absolute -top-12 -left-4 select-none pointer-events-none group-hover:text-brandCyan/20 transition-colors">
            0{index + 1}
          </span>
          <div class="relative z-10 pt-4">
            <h3 class="text-textPrimary font-sora text-xl font-bold mb-4">{step.title}</h3>
            <p class="text-textSecondary text-sm leading-relaxed font-sora">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
