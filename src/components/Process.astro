---
// Seção do Processo Consultivo (Weyrich style)
const steps = [
  {
    title: "Diagnóstico & UX Research",
    desc: "Entendo o gargalo e a dor do usuário. Não adianta automatizar se a interface for confusa.",
    icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
  },
  {
    title: "Arquitetura & Prototipagem",
    desc: "Desenho o fluxo lógico e a interface em alta fidelidade para validação visual.",
    icon: "M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"
  },
  {
    title: "Desenvolvimento & Integração",
    desc: "Construo a solução conectando as APIs (Python/Node) garantindo um sistema robusto.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
  },
  {
    title: "Manutenção Evolutiva",
    desc: "Suporte contínuo para atualizações de APIs e refinamento de usabilidade.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
  }
];
---
<section class="py-32 px-10 md:px-20 lg:px-40 bg-[#07090d]">
  <div class="max-w-7xl mx-auto">
    <div class="mb-20">
      <h2 class="text-3xl md:text-5xl font-sans font-bold text-off-white tracking-tight mb-6">O Fluxo Híbrido</h2>
      <p class="text-off-white/50 text-lg max-w-2xl">
        Um processo consultivo que une a profundidade da pesquisa de experiência de usuário com a força bruta da engenharia de dados.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="flex flex-col group">
          <div class="w-12 h-12 rounded-full bg-card-dark border border-white/10 flex items-center justify-center mb-8 group-hover:border-cyan-accent/50 transition-colors">
            <svg class="w-5 h-5 text-cyan-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={step.icon} />
            </svg>
          </div>
          <span class="text-off-white/30 font-mono text-sm mb-4 block">0{index + 1}</span>
          <h3 class="text-off-white font-sans text-xl font-semibold mb-4">{step.title}</h3>
          <p class="text-off-white/50 text-sm leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
