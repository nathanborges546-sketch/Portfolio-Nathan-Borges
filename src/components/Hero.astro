---
import { Image } from 'astro:assets';
import profileImg from '../assets/foto nathan.jpg';
---

<header class="relative min-h-screen flex flex-col justify-center px-8 overflow-hidden bg-darkBg pt-32 pb-20">
  <div class="max-w-7xl mx-auto z-10 w-full">
    <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-12 lg:gap-24 items-center">
      
      <!-- Coluna de Texto: Alinhada horizontalmente com o quadro da foto -->
      <div class="order-2 lg:order-1 flex flex-col justify-center items-start text-left h-full">
        <!-- Rating & Social Proof -->
        <div class="flex items-center gap-3 mb-8 opacity-0 animate-fade-in-up">
          <div class="flex text-brandCyan">
            {[1, 2, 3, 4, 5].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <span class="text-textPrimary font-space text-sm font-bold">4,9/5</span>
          <span class="text-textSecondary font-space text-xs uppercase tracking-widest border-l border-white/10 pl-3">+150 clientes satisfeitos</span>
        </div>

        <h1 class="font-sora text-4xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-textPrimary leading-[1.1] mb-14 opacity-0 animate-fade-in-up [animation-delay:100ms]">
          Construindo a <span class="text-brandCyan">infraestrutura de IA</span> e a <span class="text-brandCyan">clareza de UX</span> que escalam produtos digitais.
        </h1>

        <p class="font-sora text-lg md:text-xl text-textSecondary max-w-2xl leading-[1.8] opacity-0 animate-fade-in-up [animation-delay:200ms]">
          Engenheiro de Software Sênior especializado em arquitetar automações robustas e designs antifricção. Traduzo requisitos de negócios complexos em códigos limpos, escaláveis e focados na psicologia do usuário.
        </p>
      </div>

      <!-- Coluna de Perfil: Centralizada tanto no mobile quanto no desktop -->
      <div class="order-1 lg:order-2 flex flex-col items-center gap-6 opacity-0 animate-fade-in-up [animation-delay:400ms] justify-self-center lg:justify-self-end">
        
        <!-- Foto com Moldura Tech e Zoom -->
        <div class="relative group cursor-zoom-in" id="photo-zoom-trigger">
          <div class="absolute -inset-2 bg-brandCyan/20 rounded-[24px] blur-sm opacity-50 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative p-1 bg-darkBg border-[5px] border-brandCyan/40 rounded-[22px] shadow-[0_0_30px_rgba(28,105,183,0.15)] overflow-hidden">
            <Image src={profileImg} id="profile-img" alt="Nathan Borges" width={192} fetchpriority="high" loading="eager" class="w-32 h-32 md:w-48 md:h-48 rounded-[18px] object-cover transition-transform duration-500 group-hover:scale-105" />
            <!-- Tech Accents -->
            <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-brandCyan rounded-tl-lg"></div>
            <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-brandCyan rounded-br-lg"></div>
          </div>
        </div>

        <!-- Nome e Habilidades -->
        <div class="flex flex-col items-center gap-4 w-full">
          <h2 class="text-textPrimary font-sora text-2xl font-bold tracking-tight">Nathan Borges</h2>
          
          <!-- Habilidades em 3 Colunas -->
          <div class="grid grid-cols-3 gap-1.5 w-full max-w-[290px] xs:max-w-[320px] sm:max-w-[450px]">
            {["Criativo", "Organizado", "Estratégico", "Experiente", "Profissional", "Pontual"].map((skill) => (
              <span class="px-1 py-1.5 bg-surface border border-white/5 rounded-lg text-textSecondary font-space text-[8px] sm:text-[9px] uppercase tracking-tighter cursor-default hover:border-brandCyan/30 hover:text-textPrimary transition-colors text-center flex items-center justify-center min-h-[36px] sm:min-h-[40px]">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Tagline de Experiência -->
        <div class="flex items-center gap-4 py-4 px-6 bg-brandCyan/5 border border-brandCyan/10 rounded-2xl w-full lg:w-max mt-4 sm:whitespace-nowrap">
          <div class="w-10 h-10 rounded-full bg-brandCyan/20 flex items-center justify-center text-brandCyan shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <div class="flex flex-col">
            <p class="text-textPrimary font-sora font-bold text-sm leading-tight sm:leading-none">Mais de 7 anos construindo autoridade digital</p>
            <p class="text-blue-400 font-space text-[10px] uppercase tracking-widest leading-none mt-1">Senior Software Engineer & UX Specialist</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Modal de Zoom (Hidden by default) -->
  <div id="zoom-modal" class="fixed inset-0 z-[100] bg-darkBg/95 backdrop-blur-xl flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <button id="close-zoom" aria-label="Fechar zoom da foto" class="absolute top-10 right-10 text-textPrimary hover:text-brandCyan p-4">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <Image src={profileImg} alt="Nathan Borges Zoom" width={640} class="max-w-[90%] max-h-[80%] rounded-[32px] border-[5px] border-brandCyan/40 shadow-2xl object-cover shadow-brandCyan/10" />
  </div>

  <!-- Background Ambient Light -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brandCyan/5 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const trigger = document.getElementById('photo-zoom-trigger');
    const modal = document.getElementById('zoom-modal');
    const close = document.getElementById('close-zoom');

    trigger?.addEventListener('click', () => {
      modal?.classList.remove('opacity-0', 'pointer-events-none');
      modal?.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    });

    const closeModal = () => {
      modal?.classList.add('opacity-0', 'pointer-events-none');
      modal?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    };

    close?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  });
</script>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up { animation: fade-in-up 1s cubic-bezier(0.23, 1, 0.32, 1) forwards; }
</style>
