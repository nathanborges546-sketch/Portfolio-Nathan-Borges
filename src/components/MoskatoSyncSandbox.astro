---
// src/components/MoskatoSyncSandbox.astro
---

<div class="w-full flex flex-col font-sora mt-4 opacity-0 animate-fade-in-up [animation-delay:200ms]">

  <!-- Top Info Panel -->
  <div class="mb-8 border border-white/5 rounded-2xl overflow-hidden bg-white/[0.01] shadow-2xl">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-white/5 p-5 bg-[#0b0e14]/30">
      <div class="flex items-center gap-3">
        <span class="font-space text-[10px] bg-white/5 text-[#8b949e] px-3 py-1 rounded-full border border-white/5 tracking-wider font-semibold">LOCAL GATEWAY</span>
        <h3 class="text-sm font-bold tracking-tight text-[#f0f6fc]">Node.js Sync Broker • Himarë</h3>
      </div>
      <div class="flex gap-3">
        <span class="font-space text-[10px] text-emerald-400 bg-emerald-400/10 px-3 py-1 rounded-full border border-emerald-400/20 tracking-wider font-semibold flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> ONLINE
        </span>
      </div>
    </div>
  </div>

  <!-- Panels Container -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-stretch">

    <!-- Left Panel: Edge Client (POS Simulator) -->
    <div class="flex flex-col justify-between bg-[#0b0e14]/60 p-6 rounded-2xl border border-white/5 shadow-inner">
      <div>
        <div class="flex justify-between items-center mb-6">
          <h4 class="font-bold text-base tracking-tight text-[#f0f6fc] flex items-center gap-2">
            <i class="fa-solid fa-mobile-screen text-[#00AEEF]"></i> Simulador de POS (Cliente)
          </h4>
          <span class="font-space text-[10px] text-[#00AEEF] border border-[#00AEEF]/20 bg-[#00AEEF]/10 px-2 py-0.5 rounded-md">Frontend</span>
        </div>
        
        <p class="text-xs text-[#8b949e] mb-6 leading-relaxed">
          Simule o envio de um pedido através do dispositivo do cliente. Os dados são enviados para o servidor local (offline-first).
        </p>

        <!-- Mock Menu Interface -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-4 mb-6">
          <div class="flex justify-between items-center mb-4 pb-2 border-b border-white/5">
            <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Identificação</span>
            <span class="font-space font-bold text-[#f0f6fc] bg-[#161b22] px-3 py-1 rounded border border-white/10">Mesa 5</span>
          </div>

          <div class="space-y-3">
            <div class="flex justify-between items-center text-sm font-body">
              <span class="text-[#f0f6fc]">1x Burger Moskato Especial</span>
              <span class="text-gray-400 font-space font-bold">650 L</span>
            </div>
            <div class="flex justify-between items-center text-sm font-body">
              <span class="text-[#f0f6fc]">1x Spaghetti Carbonara</span>
              <span class="text-gray-400 font-space font-bold">700 L</span>
            </div>
            <div class="flex justify-between items-center text-sm font-body">
              <span class="text-[#f0f6fc]">2x Korça Beer Ice Cold</span>
              <span class="text-gray-400 font-space font-bold">500 L</span>
            </div>
          </div>

          <div class="flex justify-between items-center mt-5 pt-3 border-t border-white/5">
            <span class="font-space text-xs text-gray-400 font-bold uppercase tracking-wider">Total</span>
            <span class="font-space text-lg text-[#00AEEF] font-black">1850 LEKE</span>
          </div>
        </div>
      </div>

      <!-- Send Action -->
      <button id="btn-trigger-webhook" class="w-full bg-[#00AEEF] text-white font-space font-bold text-xs tracking-wider uppercase py-4 px-4 rounded-xl transition-all duration-300 hover:brightness-110 active:scale-[0.98] shadow-[0_0_15px_rgba(0,174,239,0.2)] cursor-pointer">
        ⚡ Transmitir via Webhook
      </button>
    </div>

    <!-- Right Panel: Kitchen Monitor & Sync Broker -->
    <div class="bg-[#0b0e14] rounded-2xl p-6 border border-white/5 flex flex-col justify-between shadow-inner">
      <div class="flex justify-between items-center border-b border-white/5 pb-4 mb-4">
        <h4 class="font-bold text-base tracking-tight text-[#f0f6fc] flex items-center gap-2">
          <i class="fa-solid fa-fire-burner text-[#F15A24]"></i> Kitchen Console & Sync
        </h4>
        <div class="flex gap-2">
          <button id="btn-audio-toggle" class="font-space text-[10px] text-gray-400 border border-white/10 bg-white/5 px-3 py-1 rounded-md hover:bg-white/10 transition-colors uppercase tracking-widest font-semibold flex items-center gap-1.5">
            <i id="audio-icon" class="fa-solid fa-volume-xmark text-red-400"></i> Som: Off
          </button>
        </div>
      </div>

      <!-- Sync Terminal Log -->
      <div class="font-space text-[10px] text-gray-500 mb-4 h-16 flex flex-col justify-end">
        <div id="log-1" class="transition-all duration-300">✓ Websocket Broker: Listening on :8080</div>
        <div id="log-2" class="transition-all duration-300">✓ Cloud DB Connection: Alive</div>
        <div id="log-3" class="text-amber-400/70 animate-pulse mt-1 transition-all duration-300">⏳ Aguardando payload de webhooks locais...</div>
      </div>

      <!-- Kitchen Ticket Container -->
      <div class="flex-1 border border-white/5 bg-[#161b22]/40 rounded-xl p-5 relative overflow-hidden flex flex-col justify-center min-h-[220px]">
        
        <!-- Empty State -->
        <div id="kitchen-empty-state" class="absolute inset-0 flex flex-col items-center justify-center text-center opacity-100 transition-opacity duration-500">
          <div class="w-12 h-12 rounded-full border border-white/5 bg-white/5 flex items-center justify-center mb-3">
            <i class="fa-solid fa-utensils text-gray-500 text-xl"></i>
          </div>
          <span class="font-sora font-semibold text-gray-400 text-sm">Fila Vazia</span>
          <span class="font-space text-[10px] text-gray-600 mt-1 uppercase tracking-widest">Aguardando Pedidos</span>
        </div>

        <!-- Active Order Ticket -->
        <div id="kitchen-active-ticket" class="absolute inset-0 flex flex-col p-5 opacity-0 pointer-events-none scale-95 transition-all duration-500 bg-[#0b0e14]">
          <div class="flex justify-between items-start mb-3">
            <div>
              <span class="text-[10px] font-space text-gray-500 uppercase tracking-widest font-bold">Tempo Gasto: <span id="kitchen-timer" class="text-[#F15A24]">00:00</span></span>
              <h5 class="text-xl font-bold font-header text-white italic tracking-tight mt-0.5">#1042</h5>
            </div>
            <div class="text-right">
              <span class="font-space font-black text-lg text-[#00AEEF]">Mesa 5</span>
              <div><span class="text-[9px] font-bold bg-[#F15A24]/10 text-[#F15A24] border border-[#F15A24]/20 px-2 py-0.5 rounded-full uppercase tracking-widest animate-pulse">Preparando</span></div>
            </div>
          </div>
          
          <div class="flex-1 space-y-1.5 font-body text-xs text-gray-300">
            <div class="flex gap-2 items-center"><i class="fa-regular fa-circle text-gray-600 text-[10px]"></i> 1x Burger Moskato Especial</div>
            <div class="flex gap-2 items-center"><i class="fa-regular fa-circle text-gray-600 text-[10px]"></i> 1x Spaghetti Carbonara</div>
            <div class="flex gap-2 items-center"><i class="fa-regular fa-circle text-gray-600 text-[10px]"></i> 2x Korça Beer Ice Cold</div>
          </div>

          <button id="btn-complete-order" class="mt-4 w-full bg-[#F15A24] text-white font-space font-bold text-xs tracking-wider uppercase py-3 rounded-xl transition-all duration-300 hover:brightness-110 active:scale-[0.98] shadow-[0_0_15px_rgba(241,90,36,0.15)] flex justify-center items-center gap-2">
            <i class="fa-solid fa-check-double"></i> Concluir & Cloud Sync
          </button>
        </div>
      </div>

    </div>
  </div>

  <!-- Modal ROI de Alta Performance -->
  <div id="sync-roi-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0b0e14]/80 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500">
    <div class="bg-[#161b22] border border-white/10 rounded-3xl p-6 max-w-lg w-full shadow-2xl transform scale-95 transition-all duration-500 flex flex-col gap-5" id="sync-roi-modal-content">
      
      <div class="flex items-start justify-between">
        <div>
          <span class="font-space text-[10px] text-emerald-400 uppercase tracking-widest font-semibold">Pipeline de Integração</span>
          <h4 class="text-xl font-bold text-[#f0f6fc] mt-1 tracking-tight">Sincronização Ponto a Ponto</h4>
        </div>
        <div class="w-8 h-8 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-sm">✓</div>
      </div>

      <p class="text-xs text-[#8b949e] leading-relaxed">
        A adoção da arquitetura orientada a eventos (<strong class="text-[#f0f6fc]">Node.js + Webhooks</strong>) transformou a operação local na Albânia. O sistema atua de forma nativa e rápida em modo <strong class="text-[#f0f6fc]">Offline-First</strong> para a equipe do restaurante.
      </p>

      <div class="grid grid-cols-2 gap-3 font-space my-1">
        <div class="bg-[#0b0e14]/50 border border-white/5 p-4 rounded-xl flex flex-col items-center text-center">
          <div class="text-[10px] text-[#00AEEF] uppercase tracking-wider font-bold mb-1">Confiabilidade</div>
          <div class="text-2xl font-bold text-[#f0f6fc]">100%</div>
          <div class="text-[10px] text-[#8b949e] mt-1">Uptime Local (Mesmo sem internet)</div>
        </div>
        <div class="bg-[#F15A24]/5 border border-[#F15A24]/10 p-4 rounded-xl flex flex-col items-center text-center">
          <div class="text-[10px] text-[#F15A24] uppercase tracking-wider font-bold mb-1">Latência Cloud Sync</div>
          <div class="text-2xl font-bold text-[#F15A24]">18<span class="text-sm">ms</span></div>
          <div class="text-[10px] text-[#F15A24]/70 mt-1">Sincronização em Background</div>
        </div>
      </div>

      <p class="text-xs text-[#8b949e] leading-relaxed">
        Enquanto a cozinha despacha o pedido imediatamente sem travamentos, o broker de microsserviço concilia o inventário, finanças e comissões diretamente no Notion CRM e banco de dados em nuvem em milissegundos.
      </p>

      <button id="btn-close-sync-modal" class="w-full bg-white/10 text-white hover:bg-white/15 font-space font-semibold text-xs tracking-wider uppercase py-3 px-4 rounded-xl transition-all duration-300 mt-2 border border-white/5">
        Explorar Nova Simulação
      </button>
    </div>
  </div>

</div>

<script>
  document.addEventListener('astro:page-load', () => {
    // Buttons
    const btnTrigger = document.getElementById('btn-trigger-webhook') as HTMLButtonElement;
    const btnAudio = document.getElementById('btn-audio-toggle') as HTMLButtonElement;
    const audioIcon = document.getElementById('audio-icon');
    const btnComplete = document.getElementById('btn-complete-order') as HTMLButtonElement;
    
    // UI Elements
    const log3 = document.getElementById('log-3');
    const emptyState = document.getElementById('kitchen-empty-state');
    const activeTicket = document.getElementById('kitchen-active-ticket');
    const kitchenTimer = document.getElementById('kitchen-timer');

    // Modal
    const modal = document.getElementById('sync-roi-modal');
    const modalContent = document.getElementById('sync-roi-modal-content');
    const btnCloseModal = document.getElementById('btn-close-sync-modal');

    let audioEnabled = false;
    let timerInterval: any = null;
    let secondsElapsed = 0;

    // Helper sleep
    const sleep = (ms: number) => new Promise(res => setTimeout(res, ms));

    // Audio Context Setup (Web Audio API)
    function playMoskatoChime() {
      if (!audioEnabled) return;
      try {
        const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        
        // Note 1: C5
        let osc1 = audioCtx.createOscillator();
        let gain1 = audioCtx.createGain();
        osc1.connect(gain1);
        gain1.connect(audioCtx.destination);
        osc1.type = 'sine';
        osc1.frequency.setValueAtTime(523.25, audioCtx.currentTime); 
        gain1.gain.setValueAtTime(0.2, audioCtx.currentTime);
        gain1.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.45);
        osc1.start(audioCtx.currentTime);
        osc1.stop(audioCtx.currentTime + 0.45);
        
        // Note 2: E5
        let osc2 = audioCtx.createOscillator();
        let gain2 = audioCtx.createGain();
        osc2.connect(gain2);
        gain2.connect(audioCtx.destination);
        osc2.type = 'sine';
        osc2.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.15); 
        gain2.gain.setValueAtTime(0.2, audioCtx.currentTime + 0.15);
        gain2.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.6);
        osc2.start(audioCtx.currentTime + 0.15);
        osc2.stop(audioCtx.currentTime + 0.6);
      } catch (e) {
        console.warn("Audio blocked by browser policy.", e);
      }
    }

    // Toggle Audio
    btnAudio?.addEventListener('click', () => {
      audioEnabled = !audioEnabled;
      if (audioEnabled) {
        audioIcon!.className = "fa-solid fa-volume-high text-emerald-400";
        btnAudio.innerHTML = `<i id="audio-icon" class="fa-solid fa-volume-high text-emerald-400"></i> Som: On`;
        playMoskatoChime();
      } else {
        audioIcon!.className = "fa-solid fa-volume-xmark text-red-400";
        btnAudio.innerHTML = `<i id="audio-icon" class="fa-solid fa-volume-xmark text-red-400"></i> Som: Off`;
      }
    });

    // Formatting Timer
    function updateTimer() {
      if (!kitchenTimer) return;
      const mins = Math.floor(secondsElapsed / 60).toString().padStart(2, '0');
      const secs = (secondsElapsed % 60).toString().padStart(2, '0');
      kitchenTimer.innerText = `${mins}:${secs}`;
      secondsElapsed++;
    }

    // Fluxo 1: Enviar via Webhook
    btnTrigger?.addEventListener('click', async () => {
      btnTrigger.disabled = true;
      btnTrigger.innerHTML = `<i class="fa-solid fa-circle-notch animate-spin"></i> Emitindo Evento...`;
      btnTrigger.classList.add('opacity-80', 'cursor-not-allowed');
      
      if (log3) {
        log3.className = "text-[#00AEEF] transition-all duration-300";
        log3.innerHTML = `> [POST] /api/v1/webhook - Payload { table: 5, items: 3 } recebido.`;
      }

      await sleep(600);

      if (log3) {
        log3.innerHTML = `> Emitindo Websocket para os nós locais...`;
      }

      await sleep(400);

      // Play Chime and reveal Kitchen Ticket
      playMoskatoChime();
      
      if (emptyState && activeTicket) {
        emptyState.classList.add('opacity-0', 'pointer-events-none');
        activeTicket.classList.remove('opacity-0', 'pointer-events-none', 'scale-95');
        activeTicket.classList.add('opacity-100', 'scale-100');
      }

      if (log3) {
        log3.innerHTML = `> <span class="text-emerald-400">Sucesso: Sincronização Local (0ms). Cozinha acionada.</span>`;
      }

      btnTrigger.innerHTML = `✓ Pedido Emitido Localmente`;
      btnTrigger.classList.replace('bg-[#00AEEF]', 'bg-white/10');
      btnTrigger.classList.replace('text-white', 'text-[#8b949e]');

      secondsElapsed = 0;
      updateTimer();
      timerInterval = setInterval(updateTimer, 1000);
    });

    // Fluxo 2: Concluir na Cozinha e Cloud Sync
    btnComplete?.addEventListener('click', async () => {
      clearInterval(timerInterval);
      btnComplete.disabled = true;
      btnComplete.innerHTML = `<i class="fa-solid fa-circle-notch animate-spin"></i> Conciliando Cloud Database...`;
      btnComplete.classList.replace('bg-[#F15A24]', 'bg-[#F15A24]/60');
      btnComplete.classList.remove('hover:brightness-110');

      if (log3) {
        log3.innerHTML = `> <span class="text-[#F15A24]">Fired Cloud Webhook: { status: 'ready', target: 'Cloud CRM' }</span>`;
      }

      await sleep(1000);

      btnComplete.innerHTML = `✓ Status: Dorëzuar (Pronto)`;
      btnComplete.classList.replace('bg-[#F15A24]/60', 'bg-emerald-500');
      
      if (log3) {
        log3.innerHTML = `> <span class="text-emerald-400">✓ CRM Sincronizado. Latência: 18ms. Consistência: 100%.</span>`;
      }

      await sleep(800);

      // Show ROI Modal
      if (modal && modalContent) {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modalContent.classList.remove('scale-95');
        modalContent.classList.add('scale-100');
      }
    });

    // Close Modal -> Reset State
    btnCloseModal?.addEventListener('click', () => {
      if (modal && modalContent) {
        modal.classList.add('opacity-0', 'pointer-events-none');
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-95');
      }

      // Quick reset visual state
      setTimeout(() => {
        if (emptyState && activeTicket) {
          activeTicket.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
          activeTicket.classList.remove('opacity-100', 'scale-100');
          emptyState.classList.remove('opacity-0', 'pointer-events-none');
        }
        
        btnTrigger.disabled = false;
        btnTrigger.classList.remove('opacity-80', 'cursor-not-allowed', 'bg-white/10', 'text-[#8b949e]');
        btnTrigger.classList.add('bg-[#00AEEF]', 'text-white');
        btnTrigger.innerHTML = `⚡ Transmitir via Webhook`;

        btnComplete.disabled = false;
        btnComplete.classList.remove('bg-emerald-500');
        btnComplete.classList.add('bg-[#F15A24]', 'hover:brightness-110');
        btnComplete.innerHTML = `<i class="fa-solid fa-check-double"></i> Concluir & Cloud Sync`;

        if (log3) {
          log3.className = "text-amber-400/70 animate-pulse mt-1 transition-all duration-300";
          log3.innerHTML = `⏳ Aguardando payload de webhooks locais...`;
        }
      }, 400);
    });

  });
</script>
