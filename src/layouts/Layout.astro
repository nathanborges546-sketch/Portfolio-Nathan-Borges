---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Engenharia de interfaces e automações em Python." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Pré-carregamento das fontes variáveis para performance editorial -->
		<link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous">
		
		<!-- Calendly Widget CSS -->
		<link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
		
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- View Transitions para navegação cinematográfica -->
		<ViewTransitions />
	</head>
	<body class="bg-deep-blue text-off-white min-h-screen relative font-sans selection:bg-cyan-accent selection:text-deep-blue antialiased">
		<Navbar />
		
		<main>
			<slot />
		</main>

		<!-- Calendly Widget JS -->
		<script is:inline src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
	</body>
</html>
