---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Engenharia de interfaces e automações em Python." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Pré-carregamento das fontes para garantir LCP < 1.5s e evitar CLS -->
		<link rel="preload" href="/fonts/SpaceGrotesk-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous">
		<link rel="preload" href="/fonts/Sora-ExtraBold.woff2" as="font" type="font/woff2" crossorigin="anonymous">
		<link rel="preload" href="/fonts/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous">
		<link rel="preload" href="/fonts/RobotoMono-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous">
		
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Habilitando View Transitions API -->
		<ViewTransitions />
	</head>
	<body class="bg-midnight-navy text-white min-h-screen relative font-body selection:bg-cyan-electric selection:text-midnight-navy">
		<Navbar />
		<!-- Malha de grid blueprint -->
		<div class="fixed inset-0 z-[-1] bg-blueprint bg-[length:60px_60px] opacity-40"></div>
		
		<slot />
	</body>
</html>
