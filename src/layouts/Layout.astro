---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Engenharia da Conversão Digital." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Otimização LCP: Preconnect e Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
		
		<!-- Calendly Widget CSS -->
		<link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
		
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- View Transitions para navegação cinematográfica -->
		<ViewTransitions />

		<style is:global>
			html, body {
				cursor: url('/cursor.svg') 0 0, auto !important;
				min-height: 100vh;
			}
			a, button, [role="button"], #photo-zoom-trigger {
				cursor: url('/cursor.svg') 0 0, pointer !important;
			}
		</style>
	</head>
	<body class="bg-darkBg text-textPrimary min-h-screen relative font-sora selection:bg-brandCyan selection:text-darkBg antialiased">
		<Navbar />
		
		<main>
			<slot />
		</main>

		<!-- Calendly Widget JS -->
		<script is:inline src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
	</body>
</html>
