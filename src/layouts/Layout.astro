		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/logo.png" />
		
		<!-- Meta Tags Meta/Social -->
