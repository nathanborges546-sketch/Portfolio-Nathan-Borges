		<meta property="og:title" content={title} />
		<meta property="og:image" content="/logo.png" />
		<meta property="og:description" content="Nathan Borges - Senior Software Engineer & UX Specialist. Arquitetando sistemas de alta performance e interfaces antifricção." />
		
		<meta name="generator" content={Astro.generator} />
